---
import Layout from "./Layout.astro";
import AppHeader from "../components/shared/AppHeader.astro";
import AppFooter from "../components/shared/AppFooter.astro";
import Container from "../components/shared/Container.astro";
import "../styles/global.css";
import "../styles/company.css";

export interface Props {
  title: string;
  description: string;
  author: string;
  date: string;
  tags?: string[];
  image?: string;
  product?: "ksctl" | "kubmin" | "company";
  headings?: { depth: number; slug: string; text: string }[];
}

const props = Astro.props;
const {
  title = "Untitled",
  description = "",
  author = "ksctl Team",
  date = new Date().toISOString().split("T")[0],
  tags = [],
  image = "/ksctl-logo.svg",
  product = "company",
  headings = [],
} = props;

const initials = author
  .split(" ")
  .map((n: string) => n[0])
  .join("")
  .slice(0, 2)
  .toUpperCase();

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout
  title={`${title} — ksctl Blog`}
  description={description}
  image={image}
>
  <AppHeader />
  <main class="blog-post-page">
    <!-- Grid background -->
    <div class="blog-grid-bg" aria-hidden="true"></div>

    <!-- Decorative glow -->
    <div class="blog-post-glow" aria-hidden="true"></div>

    <Container>
      <div class="blog-post-layout">
        <article class="blog-post-article">
          <!-- ── Breadcrumb ── -->
          <nav class="blog-breadcrumb">
            <a href="/">Home</a>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" />
            </svg>
            <a href="/blog">Blog</a>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" />
            </svg>
            <span>{title}</span>
          </nav>

          <!-- ── Header ── -->
          <header class="blog-post-header">
            <!-- Product badge -->
            {product !== "company" && (
              <span class="blog-post-badge">
                {product === "ksctl" ? "ksctl CLI" : "kubmin"}
              </span>
            )}

            <h1 class="blog-post-title">{title}</h1>
            <p class="blog-post-desc">{description}</p>

            <!-- Meta row -->
            <div class="blog-post-meta">
              <div class="blog-post-author">
                <span class="blog-post-avatar">{initials}</span>
                <span class="blog-post-author-name">{author}</span>
              </div>
              <span class="blog-post-dot" aria-hidden="true">·</span>
              <time datetime={new Date(date).toISOString().split("T")[0]}>
                {formattedDate}
              </time>
              {tags.length > 0 && (
                <>
                  <span class="blog-post-dot" aria-hidden="true">·</span>
                  <div class="blog-post-tags">
                    {tags.map((tag: string) => (
                      <span class="blog-post-tag">{tag}</span>
                    ))}
                  </div>
                </>
              )}
            </div>
          </header>

          <!-- ── Featured image ── -->
          {image && image !== "/ksctl-logo.svg" && (
            <div class="blog-post-image-wrap">
              <img src={image} alt={title} class="blog-post-image" />
            </div>
          )}

          <!-- ── Divider ── -->
          <div class="blog-post-divider" role="presentation"></div>

          <!-- ── Content ── -->
          <div class="blog-post-content">
            <slot />
          </div>

          <!-- ── Footer ── -->
          <footer class="blog-post-footer">
            <div class="blog-post-footer-inner">
              <div class="blog-post-footer-author">
                <span class="blog-post-footer-avatar">{initials}</span>
                <div>
                  <p class="blog-post-footer-name">{author}</p>
                  <p class="blog-post-footer-date">Published on {formattedDate}</p>
                </div>
              </div>
              <a href="/blog" class="blog-post-back-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="19" y1="12" x2="5" y2="12"/>
                  <polyline points="12 19 5 12 12 5"/>
                </svg>
                Back to Blog
              </a>
            </div>
          </footer>
        </article>

        <!-- ── Table of Contents ── -->
        {headings.filter((h: any) => h.depth <= 3).length > 1 && (
          <aside class="blog-post-toc" x-data>
            <nav class="blog-post-toc-inner">
              <span class="blog-post-toc-label">On this page</span>
              <ul class="blog-post-toc-list">
                {headings
                  .filter((h: any) => h.depth <= 3)
                  .map((h: any) => (
                    <li class="blog-post-toc-item" data-depth={h.depth}>
                      <a href={`#${h.slug}`} class="blog-post-toc-link">{h.text}</a>
                    </li>
                  ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>
    </Container>
  </main>
  <AppFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════════════
     BLOG POST — Editorial Reading Experience
     Uses only company.css CSS variables
     ═══════════════════════════════════════════════ */

  /* ── Page Background ── */
  .blog-grid-bg {
    position: fixed;
    inset: 0;
    z-index: -10;
    pointer-events: none;
    background-image:
      linear-gradient(to right, var(--ksctl-grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--ksctl-grid-line) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .blog-post-glow {
    position: fixed;
    top: -10rem;
    right: -10rem;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-ksctl-primary) 8%, transparent), transparent 70%);
    pointer-events: none;
    z-index: -5;
  }

  .blog-post-page {
    min-height: 100vh;
    padding-top: 7rem;
    padding-bottom: 4rem;
  }

  /* ── Breadcrumb ── */
  .blog-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-ksctl-muted-foreground);
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .blog-breadcrumb a {
    color: var(--color-ksctl-muted-foreground);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-breadcrumb a:hover {
    color: var(--color-ksctl-primary);
  }

  .blog-breadcrumb svg {
    width: 0.875rem;
    height: 0.875rem;
    opacity: 0.4;
    flex-shrink: 0;
  }

  .blog-breadcrumb span {
    color: var(--color-ksctl-foreground);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300px;
  }

  /* ── Header ── */
  .blog-post-header {
    max-width: 42rem;
    margin: 0 auto 2.5rem;
  }

  .blog-post-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
    color: #fff;
  }

  .blog-post-badge {
    color: var(--color-ksctl-primary-foreground);
    background: var(--color-ksctl-primary);
  }

  .blog-post-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--color-ksctl-foreground);
    margin-bottom: 1rem;
  }

  .blog-post-desc {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-ksctl-muted-foreground);
    margin-bottom: 1.5rem;
  }

  @media (min-width: 768px) {
    .blog-post-desc {
      font-size: 1.25rem;
    }
  }

  .blog-post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: var(--color-ksctl-muted-foreground);
  }

  .blog-post-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .blog-post-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--color-ksctl-primary-foreground);
    background: linear-gradient(135deg, var(--color-ksctl-primary), color-mix(in srgb, var(--color-ksctl-primary) 60%, #fff));
    flex-shrink: 0;
  }

  .blog-post-author-name {
    font-weight: 600;
    color: var(--color-ksctl-foreground);
  }

  .blog-post-dot {
    opacity: 0.4;
  }

  .blog-post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .blog-post-tag {
    display: inline-flex;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-ksctl-primary) 100%, #000 20%);
    background: color-mix(in srgb, var(--color-ksctl-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ksctl-primary) 15%, transparent);
  }

  /* ── Featured image ── */
  .blog-post-image-wrap {
    border-radius: 1rem;
    overflow: hidden;
    margin: 0 auto 2.5rem;
    border: 1px solid var(--color-ksctl-border);
    max-width: 48rem;
  }

  .blog-post-image {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Divider ── */
  .blog-post-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-ksctl-border),
      transparent
    );
    margin: 0 auto 2.5rem;
    max-width: 48rem;
  }

  /* ── Content ── */
  .blog-post-content {
    max-width: 42rem;
    margin: 0 auto;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-ksctl-foreground);
  }

  .blog-post-content :global(h2),
  .blog-post-content :global(h3),
  .blog-post-content :global(h4) {
    scroll-margin-top: 6rem;
  }

  .blog-post-content :global(h2) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-ksctl-foreground);
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-ksctl-border);
  }

  .blog-post-content :global(h3) {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.375rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ksctl-foreground);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .blog-post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .blog-post-content :global(a) {
    color: var(--color-ksctl-primary);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ksctl-primary) 30%, transparent);
    transition: border-color 0.2s ease;
  }

  .blog-post-content :global(a:hover) {
    border-bottom-color: var(--color-ksctl-primary);
  }

  .blog-post-content :global(strong) {
    font-weight: 600;
    color: var(--color-ksctl-foreground);
  }

  .blog-post-content :global(code) {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.875em;
    padding: 0.125em 0.375em;
    border-radius: 0.375rem;
    background: var(--color-ksctl-muted);
    color: var(--color-ksctl-foreground);
  }

  .blog-post-content :global(pre) {
    background: var(--color-ksctl-muted);
    border: 1px solid var(--color-ksctl-border);
    border-radius: 0.75rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .blog-post-content :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    color: var(--color-ksctl-foreground);
  }

  .blog-post-content :global(blockquote) {
    border-left: 3px solid var(--color-ksctl-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-ksctl-muted-foreground);
    font-style: italic;
  }

  .blog-post-content :global(img) {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid var(--color-ksctl-border);
    margin: 1.5rem 0;
  }

  .blog-post-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--color-ksctl-border);
    margin: 2rem 0;
  }

  .blog-post-content :global(ul),
  .blog-post-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-post-content :global(li) {
    margin-bottom: 0.375rem;
  }

  .blog-post-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .blog-post-content :global(th) {
    background: var(--color-ksctl-muted);
    padding: 0.625rem 0.75rem;
    text-align: left;
    font-weight: 600;
    color: var(--color-ksctl-foreground);
    border: 1px solid var(--color-ksctl-border);
  }

  .blog-post-content :global(td) {
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-ksctl-border);
    color: var(--color-ksctl-muted-foreground);
  }

  /* ── Footer ── */
  .blog-post-footer {
    margin-top: 4rem;
    margin-left: auto;
    margin-right: auto;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-ksctl-border);
    max-width: 42rem;
  }

  .blog-post-footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    justify-content: space-between;
    align-items: flex-start;
  }

  @media (min-width: 640px) {
    .blog-post-footer-inner {
      flex-direction: row;
      align-items: center;
    }
  }

  .blog-post-footer-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .blog-post-footer-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-ksctl-primary-foreground);
    background: linear-gradient(135deg, var(--color-ksctl-primary), color-mix(in srgb, var(--color-ksctl-primary) 60%, #fff));
    flex-shrink: 0;
  }

  .blog-post-footer-name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-ksctl-foreground);
  }

  .blog-post-footer-date {
    font-size: 0.8125rem;
    color: var(--color-ksctl-muted-foreground);
  }

  .blog-post-back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--color-ksctl-primary);
    background: color-mix(in srgb, var(--color-ksctl-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ksctl-primary) 20%, transparent);
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .blog-post-back-btn:hover {
    background: color-mix(in srgb, var(--color-ksctl-primary) 20%, transparent);
    border-color: color-mix(in srgb, var(--color-ksctl-primary) 40%, transparent);
  }

  /* ── ToC Layout ── */
  .blog-post-layout {
    display: flex;
    gap: 2rem;
    align-items: flex-start;
  }

  .blog-post-article {
    max-width: 48rem;
    margin: 0 auto;
    flex: 1;
    min-width: 0;
  }

  /* ── Table of Contents ── */
  .blog-post-toc {
    display: none;
    position: sticky;
    top: 7rem;
    width: 14rem;
    flex-shrink: 0;
    max-height: calc(100vh - 10rem);
    overflow-y: auto;
    padding-top: 0.5rem;
  }

  @media (min-width: 1024px) {
    .blog-post-toc {
      display: block;
    }
  }

  .blog-post-toc-inner {
    padding-left: 1rem;
    border-left: 1px solid var(--color-ksctl-border);
  }

  .blog-post-toc-label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-ksctl-muted-foreground);
    margin-bottom: 0.75rem;
  }

  .blog-post-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .blog-post-toc-item {
    margin-bottom: 0.25rem;
  }

  .blog-post-toc-item[data-depth="3"] {
    padding-left: 0.75rem;
  }

  .blog-post-toc-link {
    display: block;
    font-size: 0.8125rem;
    line-height: 1.4;
    padding: 0.25rem 0;
    color: var(--color-ksctl-muted-foreground);
    text-decoration: none;
    transition: color 0.2s ease;
    word-break: break-word;
  }

  .blog-post-toc-link:hover {
    color: var(--color-ksctl-primary);
  }

  .blog-post-toc-link:where(:target),
  .blog-post-toc-item:has(.blog-post-toc-link:target) .blog-post-toc-link {
    color: var(--color-ksctl-primary);
    font-weight: 500;
  }
</style>
