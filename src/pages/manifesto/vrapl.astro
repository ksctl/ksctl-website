---
import AppHeader from "../../components/shared/AppHeader.astro";
import AppFooter from "../../components/shared/AppFooter.astro";
import Container from "../../components/shared/Container.astro";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import "../../styles/kubmin.css";
import {
  meta,
  hero,
  problem,
  principles,
  whatWeveDone,
  theAsk,
  cta,
  signatories,
  references,
} from "@/data/vrapl";
---

<Layout title={meta.title} description={meta.description} theme="kubmin">
  <AppHeader variant="light" />
  <main class="mb-0" style="background: var(--color-kubmin-base); color: var(--color-kubmin-text);">

    <!-- HERO -->
    <section class="relative min-h-[70vh] flex items-center overflow-hidden km-wash-tl pt-32 pb-20" style="background: var(--color-kubmin-base);">
      <div class="km-blob km-blob-iris" style="width: 36rem; height: 36rem; top: -8rem; left: -6rem;"></div>
      <div class="km-blob km-blob-foam" style="width: 28rem; height: 28rem; bottom: -10rem; right: -6rem; opacity: .35;"></div>
      <div class="absolute inset-0 km-dotgrid pointer-events-none"></div>
      <div class="absolute inset-0 km-grain opacity-[0.18] pointer-events-none"></div>

      <Container class="relative z-10">
        <div class="max-w-4xl mx-auto text-center">
          <div class="km-stagger km-stagger-1 flex items-center justify-center mb-10">
            <span class="km-eyebrow">{hero.label}</span>
          </div>

          <h1 class="km-stagger km-stagger-2 text-5xl sm:text-6xl md:text-7xl leading-[1.02] font-medium tracking-tight mb-8" style="color: var(--color-kubmin-text);">
            {hero.headlines.map((line) => (
              <span class="block">{line}</span>
            ))}
            <span class="block km-italic km-grad-iris">
              {hero.headlineAccent}
            </span>
          </h1>

          <p class="km-stagger km-stagger-3 text-lg md:text-xl leading-relaxed max-w-3xl mx-auto" style="color: var(--color-kubmin-subtle-text);">
            {hero.subheadline}
          </p>
        </div>
      </Container>
    </section>

    <!-- THE PROBLEM -->
    <section class="py-28 md:py-32 relative" style="background: var(--color-kubmin-overlay); border-top: 1px solid var(--color-kubmin-border);">
      <div class="absolute inset-0 km-grain opacity-[0.15] pointer-events-none"></div>
      <Container class="relative z-10">
        <div class="max-w-3xl mx-auto">
          <span class="km-eyebrow mb-6">ch. 01 · the problem</span>
          <h2 class="mt-6 text-3xl md:text-5xl font-medium tracking-tight leading-[1.05] mb-12" style="color: var(--color-kubmin-text);">
            {problem.heading}
          </h2>
          <div class="space-y-6">
            {problem.paragraphs.map((p) => (
              <p class="text-lg leading-relaxed" style="color: var(--color-kubmin-subtle-text);">{p}</p>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- PRINCIPLES -->
    <section class="py-28 md:py-32" style="background: var(--color-kubmin-base); border-top: 1px solid var(--color-kubmin-border);">
      <Container>
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-16">
            <span class="km-eyebrow" style="justify-content: center;">ch. 02 · principles</span>
            <h2 class="mt-6 text-3xl md:text-5xl font-medium tracking-tight" style="color: var(--color-kubmin-text);">
              {principles.heading}
              <span class="km-italic km-grad-iris">{" "}{principles.headingAccent}</span>
            </h2>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {principles.items.map((item) => (
              <article class="km-paper km-lift rounded-2xl p-7">
                <div class="flex items-start gap-5">
                  <span class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center km-mono text-sm font-medium" style="background: var(--color-kubmin-primary-100); color: var(--color-kubmin-primary-700); border: 1px solid var(--color-kubmin-primary-200);">
                    {item.number}
                  </span>
                  <div>
                    <h3 class="text-lg font-medium mb-2" style="color: var(--color-kubmin-text);">{item.title}</h3>
                    <p class="text-sm leading-relaxed" style="color: var(--color-kubmin-subtle-text);">{item.description}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- WHY WE WROTE THIS -->
    <section class="py-28" style="background: var(--color-kubmin-overlay); border-top: 1px solid var(--color-kubmin-border);">
      <Container>
        <div class="max-w-3xl mx-auto">
          <div class="relative km-paper rounded-3xl p-8 md:p-12" style="background: linear-gradient(135deg, var(--color-kubmin-primary-50), var(--color-kubmin-surface)); border-color: var(--color-kubmin-primary-200);">
            <div class="absolute -top-3 left-8">
              <span class="km-mono text-[10px] uppercase tracking-[0.22em] px-3 py-1 rounded-full" style="background: var(--color-kubmin-base); color: var(--color-kubmin-primary-700); border: 1px solid var(--color-kubmin-primary-200);">
                Our story
              </span>
            </div>
            <h2 class="text-2xl md:text-4xl font-medium tracking-tight mb-6 mt-2" style="color: var(--color-kubmin-text);">
              {whatWeveDone.heading}
            </h2>
            <p class="text-lg leading-relaxed" style="color: var(--color-kubmin-subtle-text);">
              {whatWeveDone.before}<a href={whatWeveDone.kubminHref} target="_blank" rel="noopener noreferrer" class="font-semibold underline underline-offset-2" style="color: var(--color-kubmin-primary-700);">{whatWeveDone.kubminLabel}</a>{whatWeveDone.after}
            </p>
          </div>
        </div>
      </Container>
    </section>

    <!-- THE ASK -->
    <section class="py-28 md:py-32" style="background: var(--color-kubmin-base); border-top: 1px solid var(--color-kubmin-border);">
      <Container>
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-16">
            <span class="km-eyebrow" style="justify-content: center;">ch. 03 · the ask</span>
            <h2 class="mt-6 text-3xl md:text-5xl font-medium tracking-tight" style="color: var(--color-kubmin-text);">
              {theAsk.heading}
            </h2>
          </div>

          <div class="space-y-6">
            {theAsk.items.map((group, i) => (
              <article class="km-paper rounded-2xl p-7 md:p-9">
                <h3 class="text-xl font-medium mb-6 flex items-center gap-3" style="color: var(--color-kubmin-text);">
                  <span class="km-mono text-[10px] uppercase tracking-[0.22em]" style="color: var(--color-kubmin-subtle-text);">0{i + 1}</span>
                  <span class="km-dot" style="background: var(--color-kubmin-energy);"></span>
                  {group.title}
                </h3>
                <ul class="space-y-4">
                  {group.points.map((point) => (
                    <li class="flex items-start gap-3" style="color: var(--color-kubmin-subtle-text);">
                      <svg class="h-5 w-5 mt-0.5 shrink-0" style="color: var(--color-kubmin-primary-700);" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      <span class="leading-relaxed">{point}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- SIGNATORIES -->
    <section class="py-24" style="background: var(--color-kubmin-overlay); border-top: 1px solid var(--color-kubmin-border);">
      <Container>
        <div class="max-w-3xl mx-auto text-center">
          <span class="km-eyebrow" style="justify-content: center;">signatories</span>
          <h2 class="mt-6 text-2xl md:text-4xl font-medium tracking-tight mb-4" style="color: var(--color-kubmin-text);">
            {signatories.heading}
          </h2>
          <p class="mb-10" style="color: var(--color-kubmin-subtle-text);">
            {signatories.description}
          </p>

          <div class="flex flex-wrap items-center justify-center gap-3">
            {signatories.list.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                class="km-paper km-lift inline-flex items-center gap-2 px-5 py-3 rounded-xl"
              >
                <span class="font-medium" style="color: var(--color-kubmin-text);">{s.name}</span>
                <span class="text-xs km-mono" style="color: var(--color-kubmin-subtle-text);">({s.role})</span>
              </a>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- CTA -->
    <section class="relative py-32 md:py-40 overflow-hidden" style="background: var(--color-kubmin-base); border-top: 1px solid var(--color-kubmin-border);">
      <div class="km-blob km-blob-iris" style="width: 40rem; height: 40rem; top: -8rem; left: 50%; transform: translateX(-50%); opacity: .45;"></div>
      <div class="km-blob km-blob-gold" style="width: 26rem; height: 26rem; bottom: -8rem; right: 8%; opacity: .35;"></div>
      <div class="absolute inset-0 km-dotgrid opacity-60 pointer-events-none"></div>

      <Container class="relative z-10">
        <div class="max-w-3xl mx-auto text-center flex flex-col items-center gap-8">
          <h2 class="text-4xl md:text-6xl font-medium tracking-tight leading-[1.02]" style="color: var(--color-kubmin-text);">
            {cta.heading}
          </h2>
          <p class="text-lg km-italic max-w-2xl" style="color: var(--color-kubmin-subtle-text);">
            {cta.description}
          </p>
          <div class="flex flex-col sm:flex-row items-center gap-4 mt-4">
            {cta.actions.map((action) => (
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  "km-btn",
                  action.variant === "primary" ? "km-btn-primary" : "km-btn-ghost",
                ]}
              >
                {action.text}
              </a>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <!-- REFERENCES -->
    <section class="py-24" style="background: var(--color-kubmin-overlay); border-top: 1px solid var(--color-kubmin-border);">
      <Container>
        <div class="max-w-3xl mx-auto">
          <span class="km-eyebrow">addendum · references</span>
          <h2 class="mt-6 text-2xl md:text-3xl font-medium tracking-tight mb-10" style="color: var(--color-kubmin-text);">
            {references.heading}
          </h2>
          <ol class="space-y-4">
            {references.items.map((ref, i) => (
              <li class="flex items-start gap-4 text-sm" style="color: var(--color-kubmin-subtle-text);">
                <span class="km-mono text-[10px] tracking-[0.22em] uppercase pt-1 shrink-0" style="color: var(--color-kubmin-subtle-text);">
                  [{String(i + 1).padStart(2, '0')}]
                </span>
                <span>
                  <a href={ref.url} target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 font-medium" style="color: var(--color-kubmin-primary-700);">
                    {ref.title}
                  </a>
                  <span style="color: var(--color-kubmin-subtle-text);"> — {ref.authors}</span>
                </span>
              </li>
            ))}
          </ol>
        </div>
      </Container>
    </section>

  </main>
  <AppFooter variant="default" />
</Layout>
