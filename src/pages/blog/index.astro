---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import AppHeader from "../../components/shared/AppHeader.astro";
import AppFooter from "../../components/shared/AppFooter.astro";
import Container from "../../components/shared/Container.astro";
import "../../styles/global.css";
import "../../styles/company.css";

// Get all blog posts from content collection, sorted by date descending
const blogEntries = await getCollection("blog");
const posts = blogEntries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const meta = {
  title: "Blog — ksctl",
  description: "Deep dives, releases, and stories from the ksctl team.",
};

// Extract top tags across all posts (for future filter UI, keeping it data-driven)
const allTags = [...new Set(posts.flatMap((p) => p.data.tags || []))].slice(0, 6);
---

<Layout title={meta.title} description={meta.description}>
  <AppHeader />
  <main class="blog-index">
    <!-- Grid background -->
    <div class="blog-grid-bg" aria-hidden="true"></div>

    <!-- Decorative hero glow -->
    <div class="blog-hero-glow" aria-hidden="true"></div>

    <Container>
      <!-- ── Page Header ── -->
      <header class="blog-header">
        <div class="blog-header-inner">

          <!-- Eyebrow label -->
          <span class="blog-eyebrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5A2.5 2.5 0 0 1 4 19.5Z"/>
              <path d="M8 7h8M8 11h6M8 15h4"/>
            </svg>
            Blog
          </span>

          <!-- Main title -->
          <h1 class="blog-title">
            The ksctl <span class="blog-title-accent">Blog</span>
          </h1>

          <!-- Description -->
          <p class="blog-description">{meta.description}</p>

          <!-- Divider -->
          <div class="blog-header-divider" role="presentation"></div>
        </div>
      </header>

      <!-- ── Blog Posts ── -->
      {posts.length === 0 ? (
        <div class="blog-empty">
          <div class="blog-empty-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
          </div>
          <h3 class="blog-empty-title">No posts yet</h3>
          <p class="blog-empty-text">Blog posts are coming soon. Stay tuned!</p>
        </div>
      ) : (
        <div class="blog-posts-grid">
          {posts.map((post, index) => {
            const { title, description, author, date, tags = [], image, product } = post.data;
            const url = `/blog/${post.slug}/`;
            const initials = (author || "ksctl Team").split(' ').map(n => n[0]).join('').slice(0, 2).toUpperCase();

            return (
              <article
                class="blog-card"
                style={`animation-delay: ${0.1 + index * 0.1}s`}
              >
                <a href={url} class="blog-card-link">
                  <!-- Featured image -->
                  <div class="blog-card-media">
                    {image ? (
                      <img
                        src={image}
                        alt={title}
                        loading={index < 2 ? "eager" : "lazy"}
                        class="blog-card-img"
                      />
                    ) : (
                      <div class="blog-card-img-placeholder">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.75" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5A2.5 2.5 0 0 1 4 19.5Z"/>
                          <path d="M8 7h8M8 11h6M8 15h4"/>
                        </svg>
                      </div>
                    )}
                  </div>

                  <!-- Card body -->
                  <div class="blog-card-body">
                    <!-- Meta row: date + tags -->
                    <div class="blog-card-meta">
                      <time datetime={new Date(date).toISOString().split('T')[0]} class="blog-card-date">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                          <line x1="3" y1="10" x2="21" y2="10"/>
                        </svg>
                        {date}
                      </time>

                      {tags.slice(0, 2).map((tag: string) => (
                        <span class="blog-card-tag" key={tag}>{tag}</span>
                      ))}
                    </div>

                    <!-- Title -->
                    <h2 class="blog-card-title">{title}</h2>

                    <!-- Description -->
                    <p class="blog-card-desc">{description}</p>

                    <!-- Author -->
                    <div class="blog-card-author">
                      <span class="blog-card-avatar">{initials}</span>
                      <span class="blog-card-author-name">{author}</span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      )}

      <!-- ── Newsletter CTA ── -->
      {posts.length > 0 && (
        <aside class="blog-newsletter-cta">
          <div class="blog-newsletter-inner">
            <h3 class="blog-newsletter-title">Get notified about new posts</h3>
            <p class="blog-newsletter-text">
              Insights on sustainable Kubernetes, cost optimization, and green cloud infrastructure delivered to your inbox.
            </p>
            <div class="blog-newsletter-form">
              <input
                type="email"
                placeholder="Enter your email"
                class="blog-newsletter-input"
                disabled
              />
              <button type="button" class="blog-newsletter-btn" disabled>
                Subscribe
              </button>
            </div>
            <p class="blog-newsletter-note">Newsletter is disabled in development mode.</p>
          </div>
        </aside>
      )}
    </Container>
  </main>
  <AppFooter />
</Layout>

<style>
  /* ═══════════════════════════════════════════════
     BLOG INDEX — Editorial Magazine Aesthetic
     Uses only company.css CSS variables
     ═══════════════════════════════════════════════ */

  /* ── Page Background ── */
  .blog-grid-bg {
    position: fixed;
    inset: 0;
    z-index: -10;
    pointer-events: none;
    background-image:
      linear-gradient(to right, var(--ksctl-grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--ksctl-grid-line) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .blog-hero-glow {
    position: absolute;
    top: 5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse at center, var(--ksctl-hero-glow) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
    z-index: -5;
  }

  @media (min-width: 768px) {
    .blog-hero-glow {
      width: 900px;
      height: 400px;
    }
  }

  /* ── Header ── */
  .blog-header {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .blog-header-inner {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
  }

  .blog-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    margin-bottom: 1.5rem;
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ksctl-primary);
    background: color-mix(in srgb, var(--color-ksctl-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ksctl-primary) 20%, transparent);
  }

  .blog-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--color-ksctl-foreground);
    margin-bottom: 1.25rem;
  }

  .blog-title-accent {
    color: var(--color-ksctl-primary);
  }

  .blog-description {
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-ksctl-muted-foreground);
    max-width: 36rem;
    margin: 0 auto 2.5rem;
  }

  @media (min-width: 768px) {
    .blog-description {
      font-size: 1.25rem;
    }
  }

  .blog-header-divider {
    width: 3rem;
    height: 3px;
    margin: 0 auto;
    border-radius: 2px;
    background: linear-gradient(90deg,
      var(--color-ksctl-primary),
      color-mix(in srgb, var(--color-ksctl-primary) 30%, transparent)
    );
  }

  /* ── Posts Grid ── */
  .blog-posts-grid {
    display: grid;
    gap: 2.5rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 640px) {
    .blog-posts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .blog-posts-grid {
      gap: 3rem;
    }
  }

  /* ── Blog Card ── */
  .blog-card {
    opacity: 0;
    animation: blog-card-enter 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .blog-card:nth-child(1) { animation-delay: 0.1s; }
  .blog-card:nth-child(2) { animation-delay: 0.2s; }
  .blog-card:nth-child(3) { animation-delay: 0.3s; }
  .blog-card:nth-child(4) { animation-delay: 0.4s; }
  .blog-card:nth-child(5) { animation-delay: 0.5s; }
  .blog-card:nth-child(6) { animation-delay: 0.6s; }

  @keyframes blog-card-enter {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .blog-card-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  /* ── Card Media ── */
  .blog-card-media {
    position: relative;
    aspect-ratio: 16 / 10;
    border-radius: 1rem;
    overflow: hidden;
    background: var(--color-ksctl-muted);
    margin-bottom: 1.25rem;
    border: 1px solid var(--color-ksctl-border);
    transition: border-color 0.3s ease;
  }

  .blog-card-link:hover .blog-card-media {
    border-color: var(--color-ksctl-primary);
  }

  .blog-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .blog-card-link:hover .blog-card-img {
    transform: scale(1.04);
  }

  .blog-card-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ksctl-muted-foreground);
    opacity: 0.3;
  }

  /* ── Card Body ── */
  .blog-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .blog-card-date {
    display: inline-flex;
    align-items: center;
    gap: 0.3125rem;
    font-size: 0.8125rem;
    color: var(--color-ksctl-muted-foreground);
    white-space: nowrap;
  }

  .blog-card-date svg {
    opacity: 0.6;
  }

  .blog-card-tag {
    display: inline-flex;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 500;
    color: color-mix(in srgb, var(--color-ksctl-primary) 100%, #000 20%);
    background: color-mix(in srgb, var(--color-ksctl-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-ksctl-primary) 15%, transparent);
  }

  .blog-card-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-ksctl-foreground);
    margin-bottom: 0.625rem;
    transition: color 0.3s ease;
  }

  @media (min-width: 768px) {
    .blog-card-title {
      font-size: 1.375rem;
    }
  }

  .blog-card-link:hover .blog-card-title {
    color: var(--color-ksctl-primary);
  }

  .blog-card-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-ksctl-muted-foreground);
    margin-bottom: 1.25rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card-author {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-ksctl-border);
  }

  .blog-card-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 9999px;
    font-size: 0.5625rem;
    font-weight: 700;
    color: var(--color-ksctl-primary-foreground);
    background: linear-gradient(135deg, var(--color-ksctl-primary), color-mix(in srgb, var(--color-ksctl-primary) 60%, #fff));
    flex-shrink: 0;
  }

  .blog-card-author-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-ksctl-muted-foreground);
  }

  /* ── Empty State ── */
  .blog-empty {
    text-align: center;
    padding: 6rem 1rem;
  }

  .blog-empty-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 9999px;
    background: var(--color-ksctl-muted);
    color: var(--color-ksctl-muted-foreground);
    margin-bottom: 1.5rem;
  }

  .blog-empty-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ksctl-foreground);
    margin-bottom: 0.5rem;
  }

  .blog-empty-text {
    color: var(--color-ksctl-muted-foreground);
  }

  /* ── Newsletter CTA ── */
  .blog-newsletter-cta {
    margin-top: 2rem;
    margin-bottom: 3rem;
    padding: 3rem 2rem;
    border-radius: 1.25rem;
    background: var(--color-ksctl-muted);
    border: 1px solid var(--color-ksctl-border);
    text-align: center;
  }

  .blog-newsletter-inner {
    max-width: 32rem;
    margin: 0 auto;
  }

  .blog-newsletter-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-ksctl-foreground);
    margin-bottom: 0.5rem;
  }

  .blog-newsletter-text {
    font-size: 0.9375rem;
    color: var(--color-ksctl-muted-foreground);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .blog-newsletter-form {
    display: flex;
    gap: 0.5rem;
    max-width: 26rem;
    margin: 0 auto;
  }

  .blog-newsletter-input {
    flex: 1;
    padding: 0.625rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-family: inherit;
    color: var(--color-ksctl-foreground);
    background: var(--color-ksctl-background);
    border: 1px solid var(--color-ksctl-border);
    outline: none;
  }

  .blog-newsletter-input::placeholder {
    color: var(--color-ksctl-muted-foreground);
    opacity: 0.6;
  }

  .blog-newsletter-btn {
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    font-family: inherit;
    color: var(--color-ksctl-primary-foreground);
    background: var(--color-ksctl-primary);
    border: none;
    cursor: not-allowed;
    opacity: 0.7;
    white-space: nowrap;
  }

  .blog-newsletter-note {
    font-size: 0.75rem;
    color: var(--color-ksctl-muted-foreground);
    opacity: 0.6;
    margin-top: 0.75rem;
  }
</style>
