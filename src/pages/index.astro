---
import AppHeader from "../components/AppHeader.astro";
import AppFooter from "../components/AppFooter.astro";
import HeroHome from "../components/HeroHome.astro";
import MissionVision from "../components/MissionVision.astro";
import CompanyValues from "../components/CompanyValues.astro";
import ProductHighlights from "../components/ProductHighlights.astro";
// import Stats from "../components/Stats.astro";
import CallToAction from "../components/CallToAction.astro";
import TeamMembers from "../components/TeamMembers.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import "../styles/company.css";
import { meta } from "@/data/home";
---

<Layout title={meta.title} image="/images/og-main.png">
  <!-- Page-wide grid background -->
  <div class="fixed inset-0 -z-10 pointer-events-none bg-global-background"></div>
  <div class="fixed inset-0 -z-10 pointer-events-none bg-[linear-gradient(to_right,var(--ksctl-grid-line)_1px,transparent_1px),linear-gradient(to_bottom,var(--ksctl-grid-line)_1px,transparent_1px)] bg-[size:40px_40px]"></div>

  <AppHeader />
  <main>
    <HeroHome />
    <ProductHighlights />
    <MissionVision />
    <CompanyValues />
    <TeamMembers />
    <CallToAction />
  </main>
  <AppFooter />
</Layout>
