---
import AppHeader from "../components/shared/AppHeader.astro";
import AppFooter from "../components/shared/AppFooter.astro";
import Layout from "../layouts/Layout.astro";
import Container from "../components/shared/Container.astro";
import AboutCompany from "../components/about/AboutCompany.astro";
import MissionVision from "../components/shared/MissionVision.astro";
import TeamMembers from "../components/shared/TeamMembers.astro";
import "../styles/global.css";
import "../styles/company.css";
import { meta } from "@/data/about";
---

<Layout title={meta.title} image="/images/og-main.png">
  <!-- Page-wide grid background -->
  <div class="fixed inset-0 -z-10 pointer-events-none bg-global-background"></div>
  <div class="fixed inset-0 -z-10 pointer-events-none bg-[linear-gradient(to_right,var(--ksctl-grid-line)_1px,transparent_1px),linear-gradient(to_bottom,var(--ksctl-grid-line)_1px,transparent_1px)] bg-[size:40px_40px]"></div>

  <AppHeader />
  <main class="pt-28">
    <!-- Redirect to home #team anchor -->
    <section id="team" class="relative py-24">
      <Container>
        <!-- Page Header -->
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h1 class="text-5xl md:text-6xl font-bold text-ksctl-foreground mb-6">
            {meta.heading} <span class="text-ksctl-primary">{meta.headingHighlight}</span>
          </h1>
          <p class="text-xl text-ksctl-muted-foreground">
            {meta.subheading}
          </p>
        </div>

        <AboutCompany />
        <MissionVision />
        <TeamMembers />
      </Container>
    </section>
  </main>
  <AppFooter />
</Layout>
