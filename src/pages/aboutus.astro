---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import AboutCompany from "../components/AboutCompany.astro";
import TeamMembers from "../components/TeamMembers.astro";
import "../styles/global.css";
---

<Layout title="About ksctl — Sustainable Infrastructure Tooling">
  <main class="space-y-24 mb-24 pt-28 bg-ksctl-bg min-h-screen">
    <Container>
      <div class="text-center max-w-3xl mx-auto space-y-4">
        <h1 class="text-4xl font-mono font-bold text-ksctl-text-primary uppercase tracking-tight">About ksctl</h1>
        <p class="text-lg text-ksctl-text-secondary font-mono">
          Building tools that make workload efficiency the default, not an afterthought.
        </p>
      </div>
    </Container>
    <AboutCompany />
    <TeamMembers />
  </main>
</Layout>
