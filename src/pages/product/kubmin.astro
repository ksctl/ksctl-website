---
import AppHeader from "../../components/shared/AppHeader.astro";
import AppFooter from "../../components/shared/AppFooter.astro";
import HeroKubmin from "../../components/kubmin/Hero.astro";
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import "../../styles/kubmin.css";
import { meta } from "@/data/kubmin";

import KubminProblem from "../../components/kubmin/Problem.astro";
import KubminDemo from "../../components/kubmin/Demo.astro";
import KubminFeatures from "../../components/kubmin/Features.astro";
import KubminEnergy from "../../components/kubmin/Energy.astro";
import KubminMeasurementUnit from "../../components/kubmin/MeasurementUnit.astro";
import KubminHowItWorks from "../../components/kubmin/HowItWorks.astro";
import KubminComparison from "../../components/kubmin/Comparison.astro";
import KubminPricing from "../../components/kubmin/Pricing.astro";
import KubminTrust from "../../components/kubmin/Trust.astro";
import KubminFAQ from "../../components/kubmin/FAQ.astro";
import KubminCTA from "../../components/kubmin/CTA.astro";
---

<Layout title={meta.title} description={meta.description} theme="kubmin" image="/images/og-kubmin.png">
  <AppHeader variant="light" />
  <main class="mb-0">
    <HeroKubmin />
    <KubminProblem />
    <KubminDemo />
    <KubminFeatures />
    <KubminEnergy />
    <KubminMeasurementUnit />
    <KubminHowItWorks />
    <KubminComparison />
    <KubminPricing />
    <KubminTrust />
    <KubminCTA />
    <KubminFAQ />
  </main>
  <AppFooter variant="default" />
</Layout>

<script>
  // subtle scroll-reveal for section headings and cards (skips hero — it staggers itself)
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const targets = new Set<Element>(
      document.querySelectorAll("main section:not(#home) h2, main section:not(#home) .km-paper, main section:not(#home) .km-lift"),
    );
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          entry.target.classList.add("km-in");
          observer.unobserve(entry.target);
        }
      },
      { threshold: 0.12, rootMargin: "0px 0px -5% 0px" },
    );
    for (const el of targets) {
      el.classList.add("km-reveal");
      el.addEventListener(
        "animationend",
        () => el.classList.remove("km-reveal", "km-in"),
        { once: true },
      );
      observer.observe(el);
    }
  }
</script>
