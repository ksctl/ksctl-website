---
import Container from "./Container.astro";
import { hero } from "@/data/kli";
---

<div class="relative overflow-hidden z-0" id="home">
  <!-- Angled grid background — prominent -->
  <div class="absolute inset-0 w-full h-full pointer-events-none hero-grid-bg"></div>

  <!-- Top radial glow -->
  <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[1000px] h-[600px] bg-[radial-gradient(ellipse,_var(--color-primary)_0%,_transparent_65%)] opacity-[0.12] pointer-events-none"></div>

  <Container>
    <div class="relative pt-32 md:pt-40 pb-8">
      <!-- Centered text content -->
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="hero-stagger hero-stagger-1 inline-flex items-center gap-2 rounded-full bg-primary/[0.08] border border-primary/15 px-5 py-2 text-sm font-medium text-primary mb-10">
          <img src={hero.logo} alt="kli logo" class="h-6 w-auto" />
          <span>{hero.productName}</span>
        </div>

        <!-- Main heading — massive display type -->
        <h1 class="hero-stagger hero-stagger-2 text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[1.05] mb-8">
          <span class="text-foreground">{hero.tagline.split('K8s')[0]}</span>
          <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">K8s cluster Ops</span>
          <span class="text-foreground"> by single command</span>
        </h1>

        <!-- Description -->
        <p class="hero-stagger hero-stagger-3 text-lg md:text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto mb-10">
          {hero.description}
        </p>

        <!-- CTAs -->
        <div class="hero-stagger hero-stagger-4 flex flex-wrap items-center justify-center gap-4 mb-6">
          <a
            href={hero.primaryCta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-center h-13 px-8 rounded-xl bg-primary text-primary-foreground font-semibold shadow-lg shadow-primary/25 transition-all duration-300 hover:shadow-xl hover:shadow-primary/35 hover:-translate-y-0.5"
          >
            <span class="flex items-center gap-2">
              {hero.primaryCta.text}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </span>
          </a>

          <a
            href={hero.secondaryCta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center justify-center h-13 px-8 rounded-xl border border-border text-foreground font-semibold transition-all duration-300 hover:border-primary/40 hover:-translate-y-0.5"
          >
            <span class="flex items-center gap-2">
              {hero.secondaryCta.text}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </span>
          </a>

          <a
            href={hero.githubLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center h-13 w-13 rounded-xl border border-border text-foreground transition-all duration-300 hover:border-primary/40 hover:-translate-y-0.5 hover:text-primary"
            aria-label="View on GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8"/>
            </svg>
          </a>
        </div>

        <!-- Install command bar — centered -->
        <div class="hero-stagger hero-stagger-4 flex justify-center mb-14">
          <div class="relative group/command max-w-lg w-full">
            <div class="flex bg-gray-900 rounded-lg overflow-hidden border border-gray-700/50 shadow-xl">
              <div class="flex-grow px-5 py-3.5 font-mono text-sm text-gray-300 truncate">
                <span class="text-green-400">$</span> {hero.installCommand}
              </div>
              <button
                id="copyButton"
                class="px-4 flex items-center justify-center bg-gray-800 hover:bg-gray-700 transition-colors border-l border-gray-700 cursor-pointer"
                aria-label="Copy to clipboard"
              >
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="h-4 w-4 text-gray-300">
                  <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
                  <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
                </svg>
              </button>
            </div>
            <div id="copyMessage" class="absolute -bottom-7 left-0 text-sm text-green-600 opacity-0 transition-opacity">
              Copied to clipboard!
            </div>
          </div>
        </div>
      </div>

      <!-- Full-width Terminal Preview — floating with perspective -->
      <div class="hero-stagger hero-stagger-5 relative max-w-5xl mx-auto">
        <!-- Dramatic glow behind terminal -->
        <div class="absolute -inset-8 bg-gradient-to-b from-primary/20 via-primary/8 to-transparent rounded-3xl blur-3xl"></div>

        <div class="relative hero-terminal-float">
          <!-- Terminal window -->
          <div class="bg-gray-900 rounded-xl shadow-2xl shadow-gray-900/30 overflow-hidden border border-gray-700/80">
            <div class="flex items-center bg-gray-800 px-4 py-3 border-b border-gray-700/80">
              <div class="flex space-x-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="ml-4 text-gray-400 text-sm font-mono">kli cluster create</div>
            </div>
            <div class="p-6 font-mono text-sm text-gray-300">
              <div class="mb-3">
                <span class="text-green-400">$</span> {hero.terminal.command}
              </div>
              <div class="text-gray-500 mb-2">Initializing cluster...</div>

              {hero.terminal.steps.map((step) => (
                <div class="flex items-start mb-1.5">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400 mr-2 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <div>
                    <span class="text-blue-400">{step.text}</span>
                    {step.details && (
                      <div class="flex items-center mt-1 ml-1">
                        <span class="inline-block w-2 h-2 rounded-full bg-green-400 mr-1.5"></span>
                        <span class="text-xs text-green-400/90">{step.details.split(' | ')[0]}</span>
                        <span class="mx-2 text-gray-600">|</span>
                        <span class="inline-block w-2 h-2 rounded-full bg-blue-400 mr-1.5"></span>
                        <span class="text-xs text-blue-400/90">{step.details.split(' | ')[1]}</span>
                      </div>
                    )}
                  </div>
                </div>
              ))}

              <div class="border-t border-gray-700/50 my-3 pt-3">
                <div class="flex items-center text-green-400 font-medium">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  {hero.terminal.successText}
                </div>
                <div class="text-gray-500 mt-1.5 text-sm">
                  <span class="text-blue-400/90">{hero.terminal.stats.split(' | ')[0]}</span> | <span class="text-green-400/90">{hero.terminal.stats.split(' | ')[1]}</span>
                </div>
              </div>
              <div class="flex items-center mt-1">
                <span class="text-green-400">$</span> <span class="ml-1.5 animate-pulse">&#9612;</span>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </Container>
</div>

<style>
/* Prominent angled grid */
.hero-grid-bg {
  background-image:
    linear-gradient(65deg, var(--color-border) 1px, transparent 1px),
    linear-gradient(-25deg, var(--color-border) 1px, transparent 1px);
  background-size: 60px 60px;
  opacity: 0.6;
  mask-image: radial-gradient(ellipse 85% 75% at 50% 40%, black 35%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, black 30%, transparent 70%);
}

/* Terminal perspective float */
.hero-terminal-float {
  transform: perspective(2000px) rotateX(4deg);
  transition: transform 0.5s ease;
}
.hero-terminal-float:hover {
  transform: perspective(2000px) rotateX(1deg);
}

/* Staggered fade-in */
.hero-stagger {
  opacity: 0;
  transform: translateY(24px);
  animation: heroFadeUp 0.7s ease-out forwards;
}
.hero-stagger-1 { animation-delay: 0.05s; }
.hero-stagger-2 { animation-delay: 0.15s; }
.hero-stagger-3 { animation-delay: 0.3s; }
.hero-stagger-4 { animation-delay: 0.45s; }
.hero-stagger-5 { animation-delay: 0.6s; }

@keyframes heroFadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>

<script>
  import { hero } from "@/data/kli";
  const copyButton = document.getElementById("copyButton");
  const copyMessage = document.getElementById("copyMessage");
  const url = hero.installCommand;

  if (copyButton) {
    copyButton.addEventListener("click", () => {
      navigator.clipboard.writeText(url).then(() => {
        if (copyMessage) {
          copyMessage.style.opacity = "1";
          setTimeout(() => {
            copyMessage.style.opacity = "0";
          }, 2000);
        }
      });
    });
  }
</script>
