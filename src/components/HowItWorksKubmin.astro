---
import Container from "./Container.astro";
---

<section id="how-it-works" class="py-16 sm:py-24">
  <Container>
    <div class="text-center mb-16">
      <h2 class="text-3xl font-mono font-bold text-ksctl-text-primary uppercase tracking-tight">How it works</h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative">
      <!-- Connection Lines (desktop) -->
      <div class="hidden md:block absolute top-12 left-[20%] right-[20%] h-[1px] bg-gray-800 -z-10"></div>
      
      <!-- Step 1 -->
      <div class="space-y-6 text-center">
        <div class="w-12 h-12 rounded-full bg-primary text-black font-mono font-bold text-xl flex items-center justify-center mx-auto ring-8 ring-[#0a0a0a]">
          1
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-mono font-bold text-ksctl-text-primary">Install in One Command</h3>
          <div class="bg-[#0d1117] p-3 rounded border border-gray-800 text-xs font-mono text-primary text-left">
            kubectl apply -f kubmin.yaml
          </div>
          <p class="text-ksctl-text-secondary font-mono text-sm leading-relaxed">
            No agents, no sidecars, no config files. Runs as a lightweight service in your cluster.
          </p>
        </div>
      </div>
      
      <!-- Step 2 -->
      <div class="space-y-6 text-center">
        <div class="w-12 h-12 rounded-full bg-primary text-black font-mono font-bold text-xl flex items-center justify-center mx-auto ring-8 ring-[#0a0a0a]">
          2
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-mono font-bold text-ksctl-text-primary">Metrics Start Flowing</h3>
          <p class="text-ksctl-text-secondary font-mono text-sm leading-relaxed pt-2">
            Kubmin collects CPU, memory, and energy consumption data using RAPL and kernel-level instrumentation.
          </p>
        </div>
      </div>
      
      <!-- Step 3 -->
      <div class="space-y-6 text-center">
        <div class="w-12 h-12 rounded-full bg-primary text-black font-mono font-bold text-xl flex items-center justify-center mx-auto ring-8 ring-[#0a0a0a]">
          3
        </div>
        <div class="space-y-4">
          <h3 class="text-xl font-mono font-bold text-ksctl-text-primary">See What You're Wasting</h3>
          <p class="text-ksctl-text-secondary font-mono text-sm leading-relaxed pt-2">
            Real-time dashboards show SCI scores, efficiency trends, and cost savings opportunities per workload.
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>
