---
import Container from "./Container.astro";

// Only show newsletter in production mode
const isProduction = import.meta.env.PROD;
---

<footer class="relative bg-ksctl-bg pt-16 pb-12 border-t border-gray-800/50 font-mono">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>

  <Container>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 lg:gap-8">
      <!-- Logo and description -->
      <div class="md:col-span-3 lg:col-span-3">
        <div class="flex items-center space-x-2.5 mb-4">
          <img src="/ksctl-logo.svg" alt="ksctl logo" class="h-8 w-auto brightness-110" />
          <h2 class="text-2xl font-bold text-ksctl-text-primary">ksctl</h2>
        </div>
        <p class="text-ksctl-text-secondary mb-6 max-w-sm text-sm">
           Workload efficiency for a better cloud.
        </p>
        <div class="flex space-x-4">
          <a
            href="https://github.com/ksctl"
            target="_blank"
            rel="noopener"
            class="text-ksctl-text-secondary hover:text-primary transition-colors duration-300"
            aria-label="GitHub"
          >
            <span class="sr-only">GitHub</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path>
            </svg>
          </a>
          <a
            href="https://x.com/ksctl_org"
            target="_blank"
            rel="noopener"
            class="text-ksctl-text-secondary hover:text-primary transition-colors duration-300"
            aria-label="Twitter"
          >
            <span class="sr-only">Twitter</span>
            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5" viewBox="0 0 16 16">
              <path d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"></path>
            </svg>
          </a>
          <a
            href="https://discord.ksctl.com"
            target="_blank"
            rel="noopener"
            class="text-ksctl-text-secondary hover:text-primary transition-colors duration-300"
            aria-label="Discord"
          >
            <span class="sr-only">Discord</span>
            <svg fill="currentColor" class="w-5 h-5" viewBox="0 0 24 24">
              <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Community -->
      <div class="md:col-span-2">
        <h3 class="text-sm font-semibold text-ksctl-text-primary uppercase tracking-wider mb-4">Community</h3>
        <ul class="space-y-3">
          <li><a href="https://discord.ksctl.com/" target="_blank" rel="noopener" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">Discord</a></li>
          <li><a href="https://x.com/ksctl_org" target="_blank" rel="noopener" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">Twitter</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div class="md:col-span-2">
        <h3 class="text-sm font-semibold text-ksctl-text-primary uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-3">
          <li><a href="/aboutus" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">About</a></li>
          <li><a href="/blog" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">Blog</a></li>
          <li><a href="/pricing" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">Pricing</a></li>
        </ul>
      </div>

      <!-- Products -->
      <div class="md:col-span-2">
        <h3 class="text-sm font-semibold text-ksctl-text-primary uppercase tracking-wider mb-4">Products</h3>
        <ul class="space-y-3">
          <li><a href="/product/kubmin" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">Kubmin</a></li>
          <li><a href="/product/kli" class="text-sm text-ksctl-text-secondary hover:text-primary transition-colors duration-300">kli</a></li>
        </ul>
      </div>

      <!-- Newsletter signup -->
      <div class="md:col-span-3">
        <h3 class="text-sm font-semibold text-ksctl-text-primary uppercase tracking-wider mb-4">Stay Updated</h3>
        <p class="text-ksctl-text-secondary mb-4 text-sm">Efficiency metrics and product updates.</p>

        {isProduction ? (
        <!-- Brevo Form Integration -->
        <div id="sib-form-container" class="sib-form-container">
          <div id="error-message" class="sib-form-message-panel" style="font-size:12px; text-align:left; display:none;">
            <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
              <span class="sib-form-message-panel__inner-text">
                Error. Please try again.
              </span>
            </div>
          </div>
          <div id="success-message" class="sib-form-message-panel" style="font-size:12px; text-align:left; display:none;">
            <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
              <span class="sib-form-message-panel__inner-text">
                Subscribed!
              </span>
            </div>
          </div>
          <div id="sib-container" class="sib-container--large sib-container--vertical" style="background: transparent !important; border: none !important; padding: 0 !important;">
            <form id="sib-form" method="POST" action="https://9e93b949.sibforms.com/serve/MUIFAFGJdVnKkVMYnQH-6Aw7bv5Ett7qljPd-BlxN9c6j3pA7G8n3XTYyWPnrBmdGfEafSkaZJkQErwCi-wnWFurIfhrUVgaSwLaMzCrKmdUezXhk-zJB6Q4sleZdAYy7DB9EhgHK49VVEC0PymDRcBR_3Mza_yHn1iLTuLZasTh9D19QoBLpJhXYwJp5pKjIhtOzPrdsX0KbzvOmg==" data-type="subscription">
              <div class="sib-input sib-form-block mb-3">
                <div class="form__entry entry_block">
                  <div class="form__label-row">
                    <div class="entry__field">
                      <input
                        class="input w-full px-3 py-2 rounded border border-gray-800 bg-[#0d1117] text-ksctl-text-primary focus:outline-none focus:ring-1 focus:ring-primary/50 text-sm"
                        type="text"
                        id="EMAIL"
                        name="EMAIL"
                        autocomplete="off"
                        placeholder="Email address"
                        data-required="true"
                        required
                      />
                    </div>
                  </div>
                </div>
              </div>
              <div class="sib-captcha sib-form-block mb-3">
                <div class="form__entry entry_block">
                  <div class="form__label-row">
                    <div class="cf-turnstile g-recaptcha scale-75 origin-left" data-sitekey="0x4AAAAAACEW9pOFvA0Drq8K" id="sib-captcha" data-callback="handleCaptchaResponse" data-language="en"></div>
                  </div>
                </div>
              </div>
              <div class="sib-form-block">
                <button
                  class="sib-form-block__button sib-form-block__button-with-loader w-full px-3 py-2 rounded bg-primary hover:bg-primary/90 text-black font-bold text-sm transition-colors duration-300"
                  form="sib-form"
                  type="submit"
                >
                  <span class="sib-form-block__button-text uppercase tracking-wider">Join</span>
                </button>
              </div>
              <input type="text" name="email_address_check" value="" class="input--hidden" style="display: none;">
              <input type="hidden" name="locale" value="en">
            </form>
          </div>
        </div>
        ) : (
        <div class="flex flex-col gap-2 opacity-50">
          <input
            type="email"
            placeholder="Email address"
            class="w-full px-3 py-2 rounded border border-gray-800 bg-[#0d1117] text-sm"
            disabled
          />
          <button
            type="button"
            class="w-full px-3 py-2 rounded bg-primary/20 text-black font-bold text-sm cursor-not-allowed uppercase tracking-wider"
            disabled
          >
            Join
          </button>
        </div>
        )}
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-gray-800">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-xs text-ksctl-text-secondary">
          &copy; {new Date().getFullYear()} ksctl. Built for a green cloud.
        </p>
        <div class="flex items-center space-x-6">
          <a href="https://status.ksctl.com/" target="_blank" rel="noopener" class="text-xs text-ksctl-text-secondary hover:text-primary transition-colors">Status</a>
          <a href="#" class="text-xs text-ksctl-text-secondary hover:text-primary transition-colors">Privacy</a>
          <a href="#" class="text-xs text-ksctl-text-secondary hover:text-primary transition-colors">Terms</a>
          <a href="#" class="text-xs text-ksctl-text-secondary hover:text-primary transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </Container>
</footer>
