---
import Container from "./Container.astro";
import { features } from "@/data/kli";
---

<div id="features" class="py-24 bg-gradient-to-b from-background to-muted/30 relative overflow-hidden">
  <!-- Background decorations -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 rounded-full bg-gradient-to-br from-primary/10 to-secondary/5 blur-3xl animate-float-slow"></div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 rounded-full bg-gradient-to-tr from-secondary/10 to-accent/5 blur-3xl animate-float"></div>
    <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-full h-full bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-transparent to-muted/70 opacity-80 dark:opacity-60"></div>
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/20 to-transparent"></div>
  </div>

  <Container>
    <div class="relative text-center max-w-3xl mx-auto mb-20">
      <span class="inline-flex items-center rounded-full px-3 py-1.5 text-sm font-medium bg-accent text-accent-foreground mb-6 border border-primary/20">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
        </svg>
        {features.badge}
      </span>

      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-foreground mb-6 tracking-tight">
        <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">{features.heading.split(' ')[0]}</span> {features.heading.split(' ').slice(1).join(' ')}
      </h2>

      <p class="text-xl text-muted-foreground">
        {features.subheading}
      </p>
    </div>

    <div class="grid gap-10 lg:grid-cols-2 xl:grid-cols-4">
      <!-- Feature Card 1 -->
      <div class="group relative bg-card rounded-2xl transition-all duration-300
          hover:shadow-2xl hover:shadow-primary/15 dark:hover:shadow-primary/10 hover:-translate-y-1 border border-border overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary to-secondary transform origin-left scale-x-0
            transition-transform duration-300 group-hover:scale-x-100"></div>
        <div class="relative p-8">
          <div class="w-16 h-16 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center mb-6
              group-hover:bg-gradient-to-br group-hover:from-primary group-hover:to-secondary transition-all duration-300 shadow-lg shadow-primary/5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-primary group-hover:text-primary-foreground transition-colors duration-300">
              <path d="M11.7 2.805a.75.75 0 01.6 0A60.65 60.65 0 0122.83 8.72a.75.75 0 01-.231 1.337 49.949 49.949 0 00-9.902 3.912l-.003.002-.34.18a.75.75 0 01-.707 0A50.009 50.009 0 007.5 12.174v-.224c0-.131.067-.248.172-.311a54.614 54.614 0 014.653-2.52.75.75 0 00-.65-1.352 56.129 56.129 0 00-4.78 2.589 1.858 1.858 0 00-.859 1.228 49.803 49.803 0 00-4.634-1.527.75.75 0 01-.231-1.337A60.653 60.653 0 0111.7 2.805z" />
              <path d="M13.06 15.473a48.45 48.45 0 017.666-3.282c.134 1.414.22 2.843.255 4.285a.75.75 0 01-.46.71 47.878 47.878 0 00-8.105 4.342.75.75 0 01-.832 0 47.877 47.877 0 00-8.104-4.342.75.75 0 01-.461-.71c.035-1.442.121-2.87.255-4.286A48.4 48.4 0 016 13.18v1.27a1.5 1.5 0 00-.14 2.508c-.09.38-.222.753-.397 1.11.452.213.901.434 1.346.661a6.729 6.729 0 00.551-1.608 1.5 1.5 0 00.14-2.67v-.645a48.549 48.549 0 013.44 1.668 2.25 2.25 0 002.12 0z" />
              <path d="M4.462 19.462c.42-.419.753-.89 1-1.394.453.213.902.434 1.347.661a6.743 6.743 0 01-1.286 1.794.75.75 0 11-1.06-1.06z" />
            </svg>
          </div>

          <h3 class="text-xl font-bold text-foreground mb-3 group-hover:text-primary transition-colors">
            {features.items[0].title}
          </h3>

          <p class="text-muted-foreground mb-6">
            {features.items[0].description}
          </p>

          <div class="pt-4 border-t border-border">
            <div class="flex items-center justify-between">
              <code class="inline-block text-sm bg-accent text-accent-foreground py-1.5 px-3 rounded font-mono font-semibold">
                {features.items[0].command}
              </code>
            </div>
          </div>
        </div>
      </div>


      <!-- Feature Card 2 -->
      <div class="group relative bg-card rounded-2xl transition-all duration-300
          hover:shadow-2xl hover:shadow-kli-tech/15 dark:hover:shadow-kli-tech/10 hover:-translate-y-1 border border-border overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-kli-tech transform origin-left scale-x-0
            transition-transform duration-300 group-hover:scale-x-100"></div>
        <div class="relative p-8">
          <div class="w-16 h-16 rounded-xl bg-kli-tech-muted flex items-center justify-center mb-6
              group-hover:bg-kli-tech transition-all duration-300 shadow-lg shadow-kli-tech/5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-kli-tech group-hover:text-white transition-colors duration-300">
              <path d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z" />
            </svg>
          </div>

          <h3 class="text-xl font-bold text-foreground mb-3 group-hover:text-kli-tech transition-colors" set:html={features.items[1].title.replace(' ', ' <br>')} />

          <p class="text-muted-foreground mb-6" set:html={features.items[1].description.replace('. ', '.<br>')} />

          <div class="flex flex-col gap-2 pt-4 border-t border-border">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-muted-foreground">{(features.items[1] as any).stats.label}</span>
              <span class="text-xs font-medium text-kli-tech">{(features.items[1] as any).stats.value}</span>
            </div>
            <div class="w-full bg-muted rounded-full h-2">
              <div class="bg-kli-tech h-2 rounded-full animate-pulse-slow" style={`width: ${(features.items[1] as any).stats.percentage}%`}></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Card 3 -->
      <div class="group relative bg-card rounded-2xl transition-all duration-300
          hover:shadow-2xl hover:shadow-kli-info/15 dark:hover:shadow-kli-info/10 hover:-translate-y-1 border border-border overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-kli-info transform origin-left scale-x-0
            transition-transform duration-300 group-hover:scale-x-100"></div>
        <div class="relative p-8">
          <div class="w-16 h-16 rounded-xl bg-kli-info-muted flex items-center justify-center mb-6
              group-hover:bg-kli-info transition-all duration-300 shadow-lg shadow-kli-info/5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-kli-info group-hover:text-white transition-colors duration-300">
              <path fill-rule="evenodd" d="M12 1.5a.75.75 0 01.75.75V4.5a.75.75 0 01-1.5 0V2.25A.75.75 0 0112 1.5zM5.636 4.136a.75.75 0 011.06 0l1.592 1.591a.75.75 0 01-1.061 1.06l-1.591-1.59a.75.75 0 010-1.061zm12.728 0a.75.75 0 010 1.06l-1.591 1.592a.75.75 0 01-1.06-1.061l1.59-1.591a.75.75 0 011.061 0zm-6.816 4.496a.75.75 0 01.82.311l5.228 7.917a.75.75 0 01-.777 1.148l-2.097-.43 1.045 3.9a.75.75 0 01-1.45.388l-1.044-3.899-1.601 1.42a.75.75 0 01-1.247-.606l.569-9.47a.75.75 0 01.554-.68z" clip-rule="evenodd" />
            </svg>
          </div>

          <h3 class="text-xl font-bold text-foreground mb-3 group-hover:text-kli-info transition-colors">
            {features.items[2].title}
          </h3>

          <p class="text-muted-foreground mb-6">
            {features.items[2].description}
          </p>

          <div class="pt-4 border-t border-border">
            <div class="flex items-center justify-between mb-2">
              <div class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 mr-1.5 text-kli-info">
                  <path d="M4.5 3.75a3 3 0 00-3 3v.75h21v-.75a3 3 0 00-3-3h-15z" />
                  <path fill-rule="evenodd" d="M22.5 9.75h-21v7.5a3 3 0 003 3h15a3 3 0 003-3v-7.5zm-18 3.75a.75.75 0 01.75-.75h6a.75.75 0 010 1.5h-6a.75.75 0 01-.75-.75zm.75 2.25a.75.75 0 000 1.5h3a.75.75 0 000-1.5h-3z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm font-medium text-muted-foreground">{(features.items[2] as any).stats[0].label}</span>
              </div>
              <div class="flex items-center px-2.5 py-0.5 rounded-full bg-kli-info-muted">
                <span class="text-xs font-semibold text-kli-info">{(features.items[2] as any).stats[0].value}</span>
              </div>
            </div>
            <div class="flex items-center justify-between">
              <div class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 mr-1.5 text-kli-info">
                  <path fill-rule="evenodd" d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM6.262 6.072a8.25 8.25 0 1010.562-.766 4.5 4.5 0 01-1.318 1.357L14.25 7.5l.165.33a.809.809 0 01-1.086 1.085l-.604-.302a1.125 1.125 0 00-1.298.21l-.132.131c-.439.44-.439 1.152 0 1.591l.296.296c.256.257.622.374.98.314l1.17-.195c.323-.054.654.036.905.245l1.33 1.108c.32.267.46.694.358 1.1a8.7 8.7 0 01-2.288 4.04l-.723.724a1.125 1.125 0 01-1.298.21l-.153-.076a1.125 1.125 0 01-.622-1.006v-1.089c0-.298-.119-.585-.33-.796l-1.347-1.347a1.125 1.125 0 01-.21-1.298L9.75 12l-1.64-1.64a6 6 0 01-1.676-3.257l-.172-1.03z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm font-medium text-muted-foreground">{(features.items[2] as any).stats[1].label}</span>
              </div>
              <div class="flex items-center px-2.5 py-0.5 rounded-full bg-kli-info-muted">
                <span class="text-xs font-semibold text-kli-info">{(features.items[2] as any).stats[1].value}</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature Card 4 -->
      <div class="group relative bg-card rounded-2xl transition-all duration-300
          hover:shadow-2xl hover:shadow-kli-eco/15 dark:hover:shadow-kli-eco/10 hover:-translate-y-1 border border-border overflow-hidden">
        <div class="absolute inset-x-0 top-0 h-1 bg-kli-eco transform origin-left scale-x-0
            transition-transform duration-300 group-hover:scale-x-100"></div>
        <div class="relative p-8">
          <div class="w-16 h-16 rounded-xl bg-kli-eco-muted flex items-center justify-center mb-6
              group-hover:bg-kli-eco transition-all duration-300 shadow-lg shadow-kli-eco/5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8 text-kli-eco group-hover:text-white transition-colors duration-300">
              <path fill-rule="evenodd" d="M12.963 2.286a.75.75 0 00-1.071-.136 9.742 9.742 0 00-3.539 6.177A7.547 7.547 0 016.648 6.61a.75.75 0 00-1.152.082A9 9 0 1015.68 4.534a7.46 7.46 0 01-2.717-2.248zM15.75 14.25a3.75 3.75 0 11-7.313-1.172c.628.465 1.35.81 2.133 1a5.99 5.99 0 011.925-3.545 3.75 3.75 0 013.255 3.717z" clip-rule="evenodd" />
            </svg>
          </div>

          <h3 class="text-xl font-bold text-foreground mb-3 group-hover:text-kli-eco transition-colors">
            {features.items[3].title}
          </h3>

          <p class="text-muted-foreground mb-6">
            {features.items[3].description}
          </p>
          
          <div class="pt-4 border-t border-border">
            <div class="flex flex-col gap-2">
              {((features.items[3] as any).bullets || []).map((bullet: string) => (
                <div class="flex items-center">
                  <div class="w-2 h-2 rounded-full bg-kli-eco mr-2"></div>
                  <span class="text-sm text-muted-foreground">{bullet}</span>
                </div>
              ))}
            </div>
          
            <a
              href={(features.items[3] as any).link.href}
              class="inline-flex items-center mt-4 text-kli-eco hover:text-kli-eco/80 transition-colors font-medium"
            >
              <span>{(features.items[3] as any).link.text}</span>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="w-5 h-5 ml-2 transform transition-transform duration-300 group-hover:translate-x-1"
              >
                <path
                  fill-rule="evenodd"
                  d="M12.97 3.97a.75.75 0 011.06 0l7.5 7.5a.75.75 0 010 1.06l-7.5 7.5a.75.75 0 11-1.06-1.06l6.22-6.22H3a.75.75 0 010-1.5h16.19l-6.22-6.22a.75.75 0 010-1.06z"
                  clip-rule="evenodd"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- CLI Demo Section -->
    <div class="mt-24 rounded-3xl shadow-2xl overflow-hidden relative">
      <div class="absolute inset-0 bg-gradient-to-br from-gray-900 via-gray-900 to-primary/30"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent opacity-60"></div>
      
      <!-- Top decorative line -->
      <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-primary/50 to-transparent"></div>

      <div class="relative z-10 p-8 md:p-12">
        <div class="max-w-screen-xl mx-auto">
          <div class="md:flex items-center justify-between gap-12">
            <div class="md:w-1/2 mb-10 md:mb-0">
              <div class="inline-flex items-center rounded-full px-3 py-1 text-sm font-medium bg-primary/10 text-primary dark:bg-primary/20 dark:text-primary mb-6 border border-primary/10 dark:border-primary/30">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
                {features.cliDemo.badge}
              </div>
              
              <h3 class="text-3xl md:text-4xl font-bold text-white mb-6 leading-tight" set:html={features.cliDemo.heading.replace(', ', ', <br />')} />
              
              <p class="text-gray-300 text-lg mb-8">
                {features.cliDemo.description}
              </p>
              
              <div class="space-y-4">
                {features.cliDemo.bullets.map(bullet => (
                  <div class="flex items-start">
                    <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gradient-to-br from-kli-eco to-kli-tech flex items-center justify-center mr-3">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    <span class="text-gray-300">{bullet}</span>
                  </div>
                ))}
              </div>
              
              <div class="mt-10">
                <a 
                  href={features.cliDemo.cta.href}
                  class="inline-flex items-center px-6 py-3 rounded-lg bg-white/10 hover:bg-white/20 transition-colors border border-white/10 text-white font-medium"
                >
                  <span>{features.cliDemo.cta.text}</span>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
                  </svg>
                </a>
              </div>
            </div>

            <div class="md:w-1/2 xl:w-2/5">
              <div class="bg-gray-900 rounded-xl shadow-2xl overflow-hidden border border-gray-700/80">
                <div class="flex items-center bg-gray-800/80 px-4 py-2.5 border-b border-gray-700/80">
                  <div class="flex space-x-1.5">
                    <div class="w-3 h-3 rounded-full bg-red-500"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                    <div class="w-3 h-3 rounded-full bg-green-500"></div>
                  </div>
                  <div class="ml-4 text-gray-300 text-sm font-mono">kli-terminal</div>
                </div>
                <div class="p-5 font-mono text-sm text-gray-300">
                  <div class="mb-2">
                    <span class="text-green-400">$</span> {features.cliDemo.terminal.command}
                  </div>
                  <div class="text-gray-500 mb-3">Initializing cluster creation...</div>
                  
                  {features.cliDemo.terminal.steps.map(step => (
                    <div class="flex items-start mb-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-400 mr-2 mt-0.5 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      <span class={step.color === 'blue' ? 'text-kli-tech' : step.color === 'green' ? 'text-green-400' : 'text-gray-300'}>{step.text}</span>
                    </div>
                  ))}
                  
                  <div class="border-t border-gray-700/50 my-3 pt-3">
                    <div class="text-green-400 font-medium flex items-center">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      {features.cliDemo.terminal.successText}
                    </div>
                    <div class="text-sm text-gray-400 mt-2">
                      {features.cliDemo.terminal.note}
                    </div>
                  </div>
                  <div class="mt-3">
                    <span class="text-green-400">$</span> <span class="animate-pulse">▌</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</div>

<style>
  .animate-pulse-slow {
    animation: pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }
</style>
