---
import Container from "./Container.astro";
import { hero } from "@/data/home";
---

<div class="relative overflow-hidden z-0 min-h-screen flex flex-col" id="home">
  <!-- Light: radial spotlight — white center, emerald edges -->
  <div class="absolute inset-0 z-0 pointer-events-none dark:hidden" style="background: radial-gradient(125% 125% at 50% 10%, var(--color-global-background) 40%, var(--ksctl-hero-glow) 100%);"></div>

  <!-- Dark: radial glow accent -->
  <div class="absolute inset-0 pointer-events-none hidden dark:block bg-[radial-gradient(circle_560px_at_50%_200px,var(--ksctl-hero-glow),transparent)]"></div>

  <!-- Main content — grows to fill space, centers vertically -->
  <div class="relative z-10 flex-1 flex items-center">
    <Container>
    <div class="w-full pt-32 md:pt-44 pb-8">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="hero-stagger hero-stagger-1 inline-flex items-center gap-2 rounded-full bg-ksctl-card dark:bg-white/[0.06] backdrop-blur-sm px-4 py-2 text-sm font-medium text-global-foreground dark:text-ksctl-primary mb-8 border border-ksctl-border dark:border-ksctl-primary/10 shadow-sm">
          <div class="flex items-center justify-center w-5 h-5 rounded-full bg-ksctl-primary/15 dark:bg-ksctl-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-ksctl-primary dark:text-primary-foreground" viewBox="0 0 20 20" fill="currentColor">
              <path d="M10.894 2.553a1 1 0 00-1.788 0l-7 14a1 1 0 001.169 1.409l5-1.429A1 1 0 009 15.571V11a1 1 0 112 0v4.571a1 1 0 00.725.962l5 1.428a1 1 0 001.17-1.408l-7-14z"/>
            </svg>
          </div>
          <span>{hero.badge}</span>
        </div>

        <!-- Main Heading -->
        <h1 class="hero-stagger hero-stagger-2 text-5xl md:text-7xl lg:text-[5.25rem] font-bold tracking-tight leading-[1.08] mb-8">
          <span class="hero-headline-text">
            {hero.headline}
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="hero-stagger hero-stagger-3 mt-6 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto hero-sub-text">
          {hero.subheadline}
        </p>

        <!-- CTA -->
        <div class="hero-stagger hero-stagger-4 mt-12 flex flex-wrap items-center justify-center gap-4">
          <a
            href={hero.primaryCta.href}
            class="group flex items-center justify-center h-13 px-8 rounded-xl bg-ksctl-primary text-primary-foreground font-medium shadow-md shadow-ksctl-primary/20 transition-all duration-300 hover:shadow-lg hover:shadow-ksctl-primary/30 hover:-translate-y-0.5 active:translate-y-0"
          >
            <span class="flex items-center gap-2">
              Let's explore
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </div>
    </Container>
  </div>

  <!-- Hero bottom strip — pushes to bottom via mt-auto -->
  <div class="hero-stagger hero-stagger-5 relative z-10 mt-auto pb-8 pt-6">
    <div class="max-w-5xl mx-auto px-6 flex flex-col items-center gap-5">

      <!-- Label -->
      <p class="text-xs font-medium tracking-widest uppercase text-global-foreground/50 dark:text-white/40">Works across major cloud providers</p>

      <!-- Cloud provider logos — all inline SVG, uniform h-5 -->
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        <!-- AWS -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 512" class="h-5 w-auto opacity-50 dark:opacity-30 dark:invert" aria-label="AWS">
          <path fill="currentColor" d="M180.4 203c-.7 22.7 10.6 32.7 10.9 39.1a8.2 8.2 0 0 1 -4.1 6.3l-12.8 9a10.7 10.7 0 0 1 -5.6 1.9c-.4 0-8.2 1.8-20.5-25.6a78.6 78.6 0 0 1 -62.6 29.5c-16.3 .9-60.4-9.2-58.1-56.2-1.6-38.3 34.1-62.1 70.9-60.1 7.1 0 21.6 .4 47 6.3v-15.6c2.7-26.5-14.7-47-44.8-43.9-2.4 0-19.4-.5-45.8 10.1-7.4 3.4-8.3 2.8-10.8 2.8-7.4 0-4.4-21.5-2.9-24.2 5.2-6.4 35.9-18.4 65.9-18.2a76.9 76.9 0 0 1 55.7 17.3 70.3 70.3 0 0 1 17.7 52.4l0 69.3zM94 235.4c32.4-.5 46.2-20 49.3-30.5 2.5-10.1 2.1-16.4 2.1-27.4-9.7-2.3-23.6-4.9-39.6-4.9-15.2-1.1-42.8 5.6-41.7 32.3-1.2 16.8 11.1 31.4 30 30.5zm170.9 23.1c-7.9 .7-11.5-4.9-12.7-10.4l-49.8-164.7c-1-2.8-1.6-5.7-1.9-8.6a4.6 4.6 0 0 1 3.9-5.3c.2 0-2.1 0 22.3 0 8.8-.9 11.6 6 12.6 10.4l35.7 140.8 33.2-140.8c.5-3.2 2.9-11.1 12.8-10.2h17.2c2.2-.2 11.1-.5 12.7 10.4l33.4 142.6L421 80.1c.5-2.2 2.7-11.4 12.7-10.4h19.7c.9-.1 6.2-.8 5.3 8.6-.4 1.9 3.4-10.7-52.8 169.9-1.2 5.5-4.8 11.1-12.7 10.4h-18.7c-10.9 1.2-12.5-9.7-12.7-10.8L328.7 110.7l-32.8 137c-.2 1.1-1.7 11.9-12.7 10.8h-18.3zm273.5 5.6c-5.9 0-33.9-.3-57.4-12.3a12.8 12.8 0 0 1 -7.8-11.9v-10.8c0-8.5 6.2-6.9 8.8-5.9 10 4.1 16.5 7.1 28.8 9.6 36.7 7.5 52.8-2.3 56.7-4.5 13.2-7.8 14.2-25.7 5.3-35-10.5-8.8-15.5-9.1-53.1-21-4.6-1.3-43.7-13.6-43.8-52.4-.6-28.2 25.1-56.2 69.5-56 12.7 0 46.4 4.1 55.6 15.6 1.4 2.1 2 4.6 1.9 7v10.1c0 4.4-1.6 6.7-4.9 6.7-7.7-.9-21.4-11.2-49.2-10.8-6.9-.4-39.9 .9-38.4 25-.4 19 26.6 26.1 29.7 26.9 36.5 11 48.7 12.8 63.1 29.6 17.1 22.3 7.9 48.3 4.4 55.4-19.1 37.5-68.4 34.4-69.3 34.4zm40.2 104.9c-70 51.7-171.7 79.3-258.5 79.3A469.1 469.1 0 0 1 2.8 327.5c-6.5-5.9-.8-14 7.2-9.5a637.4 637.4 0 0 0 316.9 84.1 630.2 630.2 0 0 0 241.6-49.6c11.8-5 21.8 7.8 10.1 16.4zm29.2-33.3c-9-11.5-59.3-5.4-81.8-2.7-6.8 .8-7.9-5.1-1.8-9.5 40.1-28.2 105.9-20.1 113.4-10.6 7.6 9.5-2.1 75.4-39.6 106.9-5.8 4.9-11.3 2.3-8.7-4.1 8.4-21.3 27.4-68.5 18.4-80z"/>
        </svg>
        <!-- Azure -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 -28.5 256 256" class="h-5 w-auto opacity-50 dark:opacity-30 dark:invert" aria-label="Azure">
          <path fill="currentColor" d="M118.431947,187.698037 C151.322003,181.887937 178.48731,177.08008 178.799309,177.013916 L179.366585,176.893612 L148.31513,139.958881 C131.236843,119.644776 117.26369,102.945381 117.26369,102.849118 C117.26369,102.666861 149.32694,14.3716012 149.507189,14.057257 C149.567455,13.952452 171.38747,51.62411 202.400338,105.376064 C231.435152,155.699606 255.372949,197.191547 255.595444,197.580359 L255.999996,198.287301 L157.315912,198.274572 L58.6318456,198.261895 L118.431947,187.698073 L118.431947,187.698037 Z M-4.03864498e-06,176.434723 C-4.03864498e-06,176.382721 14.631291,150.983941 32.5139844,119.992969 L65.0279676,63.6457518 L102.919257,31.8473052 C123.759465,14.3581634 140.866667,0.0274832751 140.935253,0.00062917799 C141.003839,-0.0247829554 140.729691,0.665213042 140.326034,1.53468179 C139.922377,2.40415053 121.407304,42.1170321 99.1814268,89.7855264 L58.7707514,176.455514 L29.3853737,176.492355 C13.2234196,176.512639 -4.03864498e-06,176.486664 -4.03864498e-06,176.434703 L-4.03864498e-06,176.434723 Z" />
        </svg>
        <!-- GCP -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="h-5 w-auto opacity-50 dark:opacity-30 dark:invert" aria-label="Google Cloud">
          <path fill="currentColor" fill-rule="evenodd" d="M11.87 3.465l-.002-.003a5.935 5.935 0 00-5.586-1.217 5.89 5.89 0 00-3.98 4.092 4.206 4.206 0 00-.149 6.792 4.255 4.255 0 002.558.87h6.52a4.234 4.234 0 004.078-2.961A4.2 4.2 0 0013.637 6.3a5.835 5.835 0 00-1.767-2.835zm-7.828 7.78c.21.095.438.16.67.16l6.518.002c.9 0 1.63-.725 1.63-1.619s-.73-1.619-1.63-1.619v-.323a3.226 3.226 0 00-1.187-2.56h-.002c-1.339-1.078-3.305-.912-4.465.354l-.014.015c.996.2 1.897.751 2.525 1.568L6.198 9.101a1.63 1.63 0 00-3.097.439 1.617 1.617 0 00.942 1.704l-.001.001z" clip-rule="evenodd"/>
        </svg>
      </div>

      <!-- Feature trait pills — 2 col on mobile, 4 on md+ -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-x-8 gap-y-3">
        <span class="flex items-center gap-1.5 text-xs font-medium text-global-foreground/60 dark:text-white/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-ksctl-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/>
          </svg>
          Sustainable
        </span>
        <span class="flex items-center gap-1.5 text-xs font-medium text-global-foreground/60 dark:text-white/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-ksctl-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          Energy Efficient
        </span>
        <span class="flex items-center gap-1.5 text-xs font-medium text-global-foreground/60 dark:text-white/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-ksctl-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/>
          </svg>
          Cloud Agnostic
        </span>
        <span class="flex items-center gap-1.5 text-xs font-medium text-global-foreground/60 dark:text-white/50">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-ksctl-primary shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Any Workload
        </span>
      </div>

    </div>
  </div>
</div>

<style>
.hero-headline-text {
  color: var(--color-global-foreground);
}
.dark .hero-headline-text {
  background: linear-gradient(to right, var(--color-ksctl-foreground), var(--color-ksctl-primary), var(--color-ksctl-foreground));
  background-size: 200% 100%;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: gradient-shift 8s ease-in-out infinite;
}

.hero-sub-text {
  color: var(--color-global-foreground);
}
.dark .hero-sub-text {
  color: var(--color-ksctl-muted-foreground);
}

.hero-stagger {
  opacity: 0;
  transform: translateY(16px);
  animation: heroFadeUp 0.7s ease-out forwards;
}
.hero-stagger-1 { animation-delay: 0.1s; }
.hero-stagger-2 { animation-delay: 0.25s; }
.hero-stagger-3 { animation-delay: 0.4s; }
.hero-stagger-4 { animation-delay: 0.55s; }
.hero-stagger-5 { animation-delay: 0.7s; }

@keyframes heroFadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes gradient-shift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
</style>
