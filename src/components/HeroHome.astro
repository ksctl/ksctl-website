---
import Container from "./Container.astro";
---

<section id="hero" class="relative pt-32 pb-16 sm:pt-48 sm:pb-24">
  <Container>
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <h1 class="text-4xl sm:text-6xl lg:text-7xl font-mono font-bold text-ksctl-text-primary leading-[1.1] tracking-tight">
        Your workloads waste more money and energy than you think. <span class="text-primary underline decoration-primary/30">Kubmin proves it.</span>
      </h1>
      
      <p class="text-lg sm:text-xl text-ksctl-text-secondary font-mono max-w-2xl mx-auto leading-relaxed">
        Track cost waste, energy consumption, and efficiency regressions across your Kubernetes clusters.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <a href="#" class="w-full sm:w-auto px-8 py-4 rounded bg-primary text-black font-mono font-bold text-lg hover:bg-primary/90 transition-all shadow-lg shadow-primary/20">
          Get Started Free
        </a>
        <a href="#how-it-works" class="w-full sm:w-auto px-8 py-4 rounded border border-gray-800 text-ksctl-text-primary font-mono font-bold text-lg hover:bg-gray-800/50 transition-all">
          See How It Works ↓
        </a>
      </div>
      
      <div class="pt-12">
        <p class="text-ksctl-text-secondary font-mono text-sm">
          Also: <a href="/product/kli" class="text-ksctl-text-primary hover:text-primary underline decoration-primary/30 transition-colors">kli — our open-source K8s cluster CLI</a>
        </p>
      </div>
    </div>
  </Container>
</section>
