---
import Container from "./Container.astro";

interface Props {
  variant?: "light" | "dark";
}

const { variant = "light" } = Astro.props;
const isDark = variant === "dark";
const currentPath = Astro.url.pathname;

function isActivePath(linkPath: string) {
  if (linkPath === '/') return currentPath === '/';
  return currentPath.startsWith(linkPath);
}

const navigation = {
  links: [
    { type: "link", to: "/product/kli", label: "kli" },
    { type: "link", to: "/product/kubmin", label: "kubmin" },
    { type: "link", to: "/manifesto/vrapl", label: "Manifesto" }
  ]
};
---

<script>
  let isToggled = false;
  const navlinks = document.querySelector("#navlinks");
  const hamburger = document.querySelector("#hamburger");
  const layer = document.querySelector("#navLayer");
  const links = [...navlinks.querySelector("ul").children];

  function toggleNavlinks() {
    if (isToggled) {
      navlinks.classList.add(
        "!visible",
        "!scale-100",
        "!opacity-100",
        "!lg:translate-y-0"
      );
      hamburger.classList.add("toggled");
      layer.classList.add("origin-top", "scale-y-100");
    } else {
      navlinks.classList.remove(
        "!visible",
        "!scale-100",
        "!opacity-100",
        "!lg:translate-y-0"
      );
      hamburger.classList.remove("toggled");
      layer.classList.remove("origin-top", "scale-y-100");
    }
  }
  hamburger.addEventListener("click", () => {
    isToggled = !isToggled;
    toggleNavlinks();
  });

  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      // Only close menu when clicking an actual navigation link, not dropdown toggles
      const target = e.target.closest("a[href], button");
      if (target && target.tagName === "A") {
        isToggled = false;
        toggleNavlinks();
      }
    });
  });

  // Scroll-based floating nav
  const nav = document.getElementById("mainNav");
  const isDarkNav = nav?.dataset.variant === "dark";

  function updateNav() {
    if (!nav) return;
    const scrolled = window.scrollY > 40;

    if (scrolled) {
      nav.classList.add("nav-floating", "backdrop-blur-xl");
      nav.classList.add(isDarkNav ? "nav-scrolled-dark" : "nav-scrolled-light");
    } else {
      nav.classList.remove("nav-floating", "backdrop-blur-xl", "nav-scrolled-dark", "nav-scrolled-light");
    }
  }

  window.addEventListener("scroll", updateNav, { passive: true });
  updateNav();
</script>

<header>
  <nav
    id="mainNav"
    data-variant={variant}
    class="fixed z-40 w-full transition-all duration-500 border border-transparent min-h-0"
  >
    <Container>
      <div
        class="relative flex flex-wrap items-center justify-between gap-6 py-2.5 md:gap-0 md:py-3"
      >
        <div class="relative z-20 flex w-full justify-between md:px-0 lg:w-max">
          <a href="/" aria-label="logo" class="flex items-center space-x-2.5 group">
              <img
                src="/ksctl-logo.svg"
                alt="ksctl logo"
                width="32"
                height="32"
                class:list={[isDark && "invert"]}
              />
            <span class:list={["text-xl font-bold tracking-tight", isDark ? "text-white" : "text-global-foreground"]}>ksctl</span>
          </a>

          <div class="relative flex max-h-10 items-center lg:hidden">
            <button
              aria-label="humburger"
              id="hamburger"
              class="relative -mr-6 p-6"
            >
              <div
                aria-hidden="true"
                id="line"
                class:list={["m-auto h-0.5 w-5 rounded transition duration-300", isDark ? "bg-white" : "bg-global-foreground"]}
              >
              </div>
              <div
                aria-hidden="true"
                id="line2"
                class:list={["m-auto mt-2 h-0.5 w-5 rounded transition duration-300", isDark ? "bg-white" : "bg-global-foreground"]}
              >
              </div>
            </button>
          </div>
        </div>
        <div
          id="navLayer"
          aria-hidden="true"
          class:list={["fixed inset-0 z-10 h-screen w-screen origin-bottom scale-y-0 backdrop-blur-2xl transition duration-500 lg:hidden", isDark ? "bg-black/90" : "bg-background/80"]}
        >
        </div>
        <div
          id="navlinks"
          x-data="{ dropdownOpen: false, mobileDropdownOpen: false }"
          @click.away="dropdownOpen = false"
          class:list={[
            "w-max right-1 invisible absolute top-full z-20 origin-top-right translate-y-1 scale-90 flex-col flex-wrap justify-center gap-6 rounded-xl border p-6 opacity-0 shadow-2xl transition-all duration-300 lg:visible lg:relative lg:flex lg:w-auto lg:translate-y-0 lg:scale-100 lg:flex-row lg:items-center lg:gap-0 lg:border-none lg:bg-transparent lg:p-0 lg:opacity-100 lg:shadow-none lg:py-3",
            isDark
              ? "border-white/10 bg-[#1a1a1a] shadow-black/30"
              : "border-global-border bg-global-card shadow-global-foreground/10"
          ]}
        >
          <div
            class:list={["w-full lg:w-auto lg:pr-4 lg:pt-0", isDark ? "text-white" : "text-global-foreground"]}
          >
            <ul
              class="flex flex-col gap-6 tracking-wide lg:flex-row lg:gap-0 lg:text-sm"
            >
              {
                navigation.links.map((link) => {
                  if (link.type === "dropdown") {
                    return (
                      <li class="relative">
                        {/* Desktop Dropdown */}
                        <div class="hidden lg:block">
                          <button
                            @mouseenter="dropdownOpen = true"
                            @mouseleave="dropdownOpen = false"
                            class="hover:text-global-primary flex items-center transition font-medium md:px-4"
                          >
                            <span>{link.label}</span>
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                            </svg>
                          </button>

                          {/* Dropdown Menu */}
                          <div
                            x-show="dropdownOpen"
                            @mouseenter="dropdownOpen = true"
                            @mouseleave="dropdownOpen = false"
                            x-transition:enter="transition ease-out duration-200"
                            x-transition:enter-start="opacity-0 translate-y-1"
                            x-transition:enter-end="opacity-100 translate-y-0"
                            x-transition:leave="transition ease-in duration-150"
                            x-transition:leave-start="opacity-100 translate-y-0"
                            x-transition:leave-end="opacity-0 translate-y-1"
                            class:list={["absolute left-0 mt-2 w-64 rounded-xl shadow-xl overflow-hidden", isDark ? "bg-[#1a1a1a] border border-white/10" : "bg-global-card border border-global-border"]}
                            style="display: none;"
                          >
                            {link.items.map((item) => (
                              <a
                                href={item.to}
                                class:list={[
                                  "block px-4 py-3 transition-colors duration-200",
                                  isDark ? "hover:bg-white/[0.06]" : "hover:bg-global-muted/50",
                                  isActivePath(item.to) && (isDark ? "bg-white/[0.04]" : "bg-global-primary/5")
                                ]}
                              >
                                <div class="flex items-start justify-between">
                                  <div>
                                    <div class:list={[
                                      "font-semibold",
                                      isActivePath(item.to) ? "text-global-primary" : (isDark ? "text-white" : "text-global-foreground")
                                    ]}>
                                      {item.label}
                                    </div>
                                    <div class:list={["text-xs mt-0.5", isDark ? "text-gray-400" : "text-global-muted-foreground"]}>
                                      {item.description}
                                    </div>
                                  </div>
                                  {item.badge && (
                                    <span class="text-xs px-2 py-0.5 rounded-full bg-global-primary/10 text-global-primary font-medium ml-2">
                                      {item.badge}
                                    </span>
                                  )}
                                </div>
                              </a>
                            ))}
                          </div>
                        </div>

                        {/* Mobile Accordion */}
                        <div class="lg:hidden">
                          <button
                            @click="mobileDropdownOpen = !mobileDropdownOpen"
                            class="w-full hover:text-global-primary flex items-center justify-between transition font-medium"
                          >
                            <span>{link.label}</span>
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              class="h-4 w-4 transition-transform duration-200"
                              :class="{'rotate-180': mobileDropdownOpen}"
                              viewBox="0 0 20 20"
                              fill="currentColor"
                            >
                              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"/>
                            </svg>
                          </button>

                          <div
                            x-show="mobileDropdownOpen"
                            x-transition:enter="transition ease-out duration-200"
                            x-transition:enter-start="opacity-0 -translate-y-1"
                            x-transition:enter-end="opacity-100 translate-y-0"
                            class="mt-3 ml-4 space-y-3 border-l-2 border-global-primary/20 pl-4"
                            style="display: none;"
                          >
                            {link.items.map((item) => (
                              <a
                                href={item.to}
                                class:list={[
                                  "block text-sm transition-colors duration-200",
                                  isActivePath(item.to)
                                    ? "text-global-primary font-semibold"
                                    : "text-global-muted-foreground hover:text-global-primary"
                                ]}
                              >
                                <div class="font-medium">{item.label}</div>
                                {item.badge && (
                                  <span class="text-xs text-global-primary">{item.badge}</span>
                                )}
                              </a>
                            ))}
                          </div>
                        </div>
                      </li>
                    );
                  } else {
                    return (
                      <li>
                        <a
                          href={link.to}
                          target={link.external ? "_blank" : undefined}
                          rel={link.external ? "noopener noreferrer" : undefined}
                          class:list={[
                            "block transition font-medium md:px-4",
                            isActivePath(link.to)
                              ? "text-global-primary"
                              : "hover:text-global-primary"
                          ]}
                        >
                          <span>{link.label}</span>
                        </a>
                      </li>
                    );
                  }
                })
              }
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </nav>
</header>

<style>
  @reference "tailwindcss";

  #toggle_nav:checked ~ div #hamburger #line {
    @apply translate-y-1.5 rotate-45;
  }

  #toggle_nav:checked ~ div #hamburger #line2 {
    @apply -translate-y-1 -rotate-45;
  }

  .toggled div:first-child {
    @apply translate-y-1.5 rotate-45;
  }
  .toggled div:last-child {
    @apply -translate-y-1 -rotate-45;
  }

  /* Floating pill on scroll */
  .nav-floating {
    top: 12px;
    left: 16px;
    right: 16px;
    width: auto;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  @media (min-width: 768px) {
    .nav-floating {
      left: 32px;
      right: 32px;
    }
  }

  @media (min-width: 1024px) {
    .nav-floating {
      left: 48px;
      right: 48px;
      max-width: 1200px;
      margin-left: auto;
      margin-right: auto;
    }
  }

  /* Scrolled state backgrounds */
  .nav-scrolled-light {
    background-color: color-mix(in srgb, var(--color-global-background) 82%, transparent);
    border-color: color-mix(in srgb, var(--color-global-border) 30%, transparent);
  }
  .nav-scrolled-dark {
    background-color: rgba(10, 10, 10, 0.75);
    border-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
  }
</style>
