---
const { post } = Astro.props;
---

<a href={`/blog/${post.slug}`} class="block group">
  <article class="p-6 rounded-lg border border-gray-800 bg-[#0d1117] hover:border-primary/50 transition-colors space-y-4">
    <div class="flex items-center gap-4 text-xs font-mono text-ksctl-text-secondary">
      <time datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      <span>•</span>
      <span>{post.data.author}</span>
    </div>
    
    <h2 class="text-xl font-mono font-bold text-ksctl-text-primary group-hover:text-primary transition-colors">
      {post.data.title}
    </h2>
    
    <p class="text-ksctl-text-secondary font-mono text-sm leading-relaxed line-clamp-2">
      {post.data.description}
    </p>
    
    <div class="pt-2">
      <span class="text-primary font-mono text-xs font-bold uppercase tracking-wider">Read More →</span>
    </div>
  </article>
</a>
