---
import Container from "./Container.astro";
import BrowserMockup from "./BrowserMockup.astro";
import { hero } from "@/data/kubmin";
---

<div class="relative min-h-screen overflow-hidden bg-kubmin-dark" id="home">
  <!-- Gradient blobs — warm amber/emerald/teal on black, animated -->
  <div class="flex flex-col items-end absolute -right-60 -top-10 blur-xl z-0">
    <div class="h-[10rem] rounded-full w-[60rem] bg-gradient-to-b blur-[6rem] from-kubmin-cost to-kubmin-emerald-600 kubmin-blob kubmin-blob-1"></div>
    <div class="h-[10rem] rounded-full w-[90rem] bg-gradient-to-b blur-[6rem] from-kubmin-orange to-kubmin-yellow kubmin-blob kubmin-blob-2"></div>
    <div class="h-[10rem] rounded-full w-[60rem] bg-gradient-to-b blur-[6rem] from-kubmin-emerald-600 to-kubmin-cyan kubmin-blob kubmin-blob-3"></div>
  </div>

  <!-- Animated grid overlay -->
  <div class="absolute inset-0 z-0 pointer-events-none kubmin-grid"></div>

  <!-- Floating orbs with glow -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="kubmin-orb kubmin-orb-1"></div>
    <div class="kubmin-orb kubmin-orb-2"></div>
    <div class="kubmin-orb kubmin-orb-3"></div>
    <div class="kubmin-orb kubmin-orb-4"></div>
    <div class="kubmin-orb kubmin-orb-5"></div>
    <div class="kubmin-orb kubmin-orb-6"></div>
  </div>

  <!-- Shooting meteors -->
  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden">
    <div class="kubmin-meteor kubmin-meteor-1"></div>
    <div class="kubmin-meteor kubmin-meteor-2"></div>
    <div class="kubmin-meteor kubmin-meteor-3"></div>
  </div>

  <!-- Aurora band -->
  <div class="absolute inset-0 z-0 pointer-events-none kubmin-aurora"></div>

  <!-- Noise/grain texture overlay -->
  <div class="absolute inset-0 z-0 opacity-[0.35] pointer-events-none hero-noise"></div>

  <!-- Content -->
  <div class="relative z-10">
    <Container>
      <div class="pt-32 md:pt-40 pb-8">
        <div class="max-w-4xl mx-auto text-center">
          <!-- Badge -->
          <div class="hero-stagger hero-stagger-1 mx-auto flex max-w-fit items-center justify-center space-x-3 rounded-full bg-white/[0.08] border border-white/[0.12] px-6 py-3 backdrop-blur-sm mb-10">
            <img src={hero.logo} alt="kubmin logo" class="h-6 w-auto" />
            <span class="text-base font-medium text-white/90">{hero.productName}</span>
          </div>

          <!-- Headline -->
          <h1 class="hero-stagger hero-stagger-2 text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[1.05] mb-8 text-white">
            Deploy fast and know what each one costs in <span class="text-transparent bg-clip-text bg-gradient-to-r from-kubmin-orange via-kubmin-cost to-kubmin-yellow">money</span> and <span class="text-transparent bg-clip-text bg-gradient-to-r from-kubmin-emerald-400 via-kubmin-energy to-kubmin-cyan">efficiency</span>
          </h1>

          <!-- Punchline — bold subheading with emphasis on "Kubmin does." -->
          <p class="hero-stagger hero-stagger-3 text-xl md:text-2xl lg:text-3xl font-bold tracking-tight text-white/80 mb-5">
            Everyone ships faster with AI. Nobody checks the cost.<br class="hidden sm:inline" />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-kubmin-orange via-kubmin-cost to-kubmin-yellow">Kubmin does.</span>
          </p>

          <!-- Explanation -->
          <p class="hero-stagger hero-stagger-3 text-lg md:text-xl text-kubmin-neutral-400 leading-relaxed max-w-2xl mx-auto mb-10">
            {hero.explain}
          </p>

          <!-- CTA -->
          <div class="hero-stagger hero-stagger-4 flex items-center justify-center mb-5">
            <a
              href={hero.cta.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group h-12 rounded-full px-10 text-base font-semibold text-white transition-all duration-300 flex items-center justify-center gap-2 hero-cta-gradient hover:scale-105 hover:shadow-[--shadow-kubmin-cost-glow]"
            >
              {hero.cta.text}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </a>
          </div>

          <!-- Trust Badges -->
          <div class="hero-stagger hero-stagger-4 flex flex-wrap items-center justify-center gap-3 mb-16">
            {hero.trustBadges.map((badge) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/[0.06] text-xs font-medium text-white/70 border border-white/[0.08]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-kubmin-emerald-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {badge}
              </span>
            ))}
          </div>
        </div>

        <!-- Floating Mockup -->
        <div class="hero-stagger hero-stagger-5 relative max-w-6xl mx-auto">
          <!-- White glow behind mockup -->
          <div class="absolute inset-0 rounded bg-white blur-[10rem] opacity-[0.08]"></div>

          <div class="relative hero-mockup-float">
            <BrowserMockup
              imageSrc={hero.screenshot.src}
              imageAlt={hero.screenshot.alt}
              addressBarText={hero.screenshot.browserUrl}
              loading="eager"
              className="shadow-2xl shadow-black/50"
            />
          </div>
        </div>
      </div>
    </Container>
  </div>
</div>

<style>
/* Gradient CTA button — matches the background blobs */
.hero-cta-gradient {
  background: linear-gradient(135deg, var(--color-kubmin-blue), var(--color-kubmin-cost), var(--color-kubmin-energy));
  background-size: 200% 200%;
  animation: ctaShift 4s ease-in-out infinite;
}
@keyframes ctaShift {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* Animated blob drift */
.kubmin-blob {
  will-change: transform;
}
.kubmin-blob-1 {
  animation: blobDrift1 22s ease-in-out infinite;
}
.kubmin-blob-2 {
  animation: blobDrift2 26s ease-in-out infinite;
}
.kubmin-blob-3 {
  animation: blobDrift3 20s ease-in-out infinite;
}

@keyframes blobDrift1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-150px, 60px) scale(1.2); }
  66% { transform: translate(100px, -40px) scale(0.85); }
}
@keyframes blobDrift2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(180px, -80px) scale(1.15); }
  66% { transform: translate(-120px, 50px) scale(0.88); }
}
@keyframes blobDrift3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(-130px, -70px) scale(1.25); }
  66% { transform: translate(160px, 40px) scale(0.82); }
}

/* Noise texture via SVG filter */
.hero-noise {
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px 128px;
}

/* Mockup perspective float */
.hero-mockup-float {
  transform: perspective(2000px) rotateX(5deg);
  transition: transform 0.6s ease;
}
.hero-mockup-float:hover {
  transform: perspective(2000px) rotateX(1deg);
}

/* Staggered fade-in */
.hero-stagger {
  opacity: 0;
  transform: translateY(28px);
  animation: heroFadeUp 0.8s ease-out forwards;
}
.hero-stagger-1 { animation-delay: 0.05s; }
.hero-stagger-2 { animation-delay: 0.15s; }
.hero-stagger-3 { animation-delay: 0.28s; }
.hero-stagger-4 { animation-delay: 0.4s; }
.hero-stagger-5 { animation-delay: 0.55s; }

@keyframes heroFadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Animated grid overlay — visible on dark bg */
.kubmin-grid {
  background-image:
    linear-gradient(rgba(245,158,11,0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(245,158,11,0.1) 1px, transparent 1px);
  background-size: 80px 80px;
  animation: kubminGridShift 25s linear infinite;
  mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 70% 50% at 50% 30%, black 20%, transparent 70%);
}
@keyframes kubminGridShift {
  0% { transform: translate(0, 0); }
  100% { transform: translate(80px, 80px); }
}

/* Floating orbs — amber and emerald glow */
.kubmin-orb {
  position: absolute;
  border-radius: 50%;
  will-change: transform, opacity;
}
.kubmin-orb-1 {
  width: 8px; height: 8px; left: 15%; top: 25%;
  background: rgba(245,158,11,0.9);
  box-shadow: 0 0 20px 8px rgba(245,158,11,0.4), 0 0 60px 20px rgba(245,158,11,0.15);
  animation: kubminOrbFloat 7s ease-in-out infinite;
}
.kubmin-orb-2 {
  width: 6px; height: 6px; left: 70%; top: 18%;
  background: rgba(16,185,129,0.9);
  box-shadow: 0 0 16px 6px rgba(16,185,129,0.4), 0 0 50px 16px rgba(16,185,129,0.12);
  animation: kubminOrbFloat 9s ease-in-out infinite; animation-delay: 2s;
}
.kubmin-orb-3 {
  width: 10px; height: 10px; left: 35%; top: 60%;
  background: rgba(245,158,11,0.8);
  box-shadow: 0 0 24px 10px rgba(245,158,11,0.3), 0 0 70px 24px rgba(245,158,11,0.1);
  animation: kubminOrbFloat 11s ease-in-out infinite; animation-delay: 4s;
}
.kubmin-orb-4 {
  width: 5px; height: 5px; left: 55%; top: 45%;
  background: rgba(16,185,129,0.8);
  box-shadow: 0 0 14px 5px rgba(16,185,129,0.35);
  animation: kubminOrbFloat 8s ease-in-out infinite; animation-delay: 1s;
}
.kubmin-orb-5 {
  width: 7px; height: 7px; left: 85%; top: 40%;
  background: rgba(6,182,212,0.8);
  box-shadow: 0 0 18px 7px rgba(6,182,212,0.3);
  animation: kubminOrbFloat 10s ease-in-out infinite; animation-delay: 3s;
}
.kubmin-orb-6 {
  width: 6px; height: 6px; left: 48%; top: 12%;
  background: rgba(245,158,11,0.8);
  box-shadow: 0 0 16px 6px rgba(245,158,11,0.3);
  animation: kubminOrbFloat 12s ease-in-out infinite; animation-delay: 5s;
}

@keyframes kubminOrbFloat {
  0%, 100% { transform: translate(0, 0); opacity: 0.4; }
  25% { transform: translate(40px, -30px); opacity: 1; }
  50% { transform: translate(-20px, -60px); opacity: 0.6; }
  75% { transform: translate(30px, 20px); opacity: 1; }
}

/* Shooting meteor streaks — amber colored */
.kubmin-meteor {
  position: absolute;
  width: 140px;
  height: 2px;
  border-radius: 2px;
  background: linear-gradient(90deg, rgba(245,158,11,0.9), transparent);
  transform: rotate(-35deg);
  will-change: transform, opacity;
}
.kubmin-meteor-1 { top: 12%; right: -140px; animation: kubminMeteorShoot 5s ease-in infinite; animation-delay: 0.5s; }
.kubmin-meteor-2 { top: 30%; right: -140px; animation: kubminMeteorShoot 5s ease-in infinite; animation-delay: 3s; }
.kubmin-meteor-3 { top: 50%; right: -140px; animation: kubminMeteorShoot 5s ease-in infinite; animation-delay: 5.5s; }

@keyframes kubminMeteorShoot {
  0% { transform: rotate(-35deg) translateX(0); opacity: 0; }
  5% { opacity: 1; }
  30% { opacity: 1; }
  60% { transform: rotate(-35deg) translateX(-100vw); opacity: 0; }
  100% { transform: rotate(-35deg) translateX(-100vw); opacity: 0; }
}

/* Aurora — amber/emerald color sweep */
.kubmin-aurora {
  background: linear-gradient(
    110deg,
    transparent 10%,
    rgba(245,158,11,0.08) 30%,
    rgba(16,185,129,0.12) 50%,
    rgba(245,158,11,0.08) 70%,
    transparent 90%
  );
  background-size: 300% 100%;
  animation: kubminAuroraSweep 7s ease-in-out infinite;
}
@keyframes kubminAuroraSweep {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}
</style>
