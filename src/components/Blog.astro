---
import Container from "./Container.astro"
import { blog } from "@/data/kli";
---

<div id="blog" class="py-24 bg-gradient-to-b from-background to-kli-muted relative overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute -right-20 top-0 w-96 h-96 bg-gradient-to-br from-kli-primary/10 to-kli-tech/5 rounded-full filter blur-3xl animate-float-slow"></div>
  <div class="absolute -left-20 bottom-0 w-96 h-96 bg-gradient-to-tr from-kli-primary/10 to-kli-secondary/5 rounded-full filter blur-3xl animate-float-delayed"></div>
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-kli-primary/30 to-transparent"></div>

  <Container>
      <div class="mb-20 space-y-4 text-center relative z-10">
        <span class="inline-flex items-center rounded-full px-4 py-1.5 text-sm font-medium bg-kli-accent text-kli-primary mb-6 border border-kli-primary/20">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5 2a1 1 0 011 1v1h1a1 1 0 010 2H6v1a1 1 0 01-2 0V6H3a1 1 0 010-2h1V3a1 1 0 011-1zm0 10a1 1 0 011 1v1h1a1 1 0 110 2H6v1a1 1 0 11-2 0v-1H3a1 1 0 110-2h1v-1a1 1 0 011-1zm7-10a1 1 0 01.707.293l.707.707L15.707 1a1 1 0 111.414 1.414L15.414 4l1.707 1.707a1 1 0 01-1.414 1.414L14 5.414l-1.707 1.707a1 1 0 01-1.414-1.414L12.586 4l-1.707-1.707A1 1 0 0112 1zm-7 8a1 1 0 01.707.293l.707.707L15.707 9a1 1 0 111.414 1.414l-1.707 1.707 1.707 1.707a1 1 0 01-1.414 1.414L14 13.414l-1.707 1.707a1 1 0 01-1.414-1.414l1.707-1.707-1.707-1.707A1 1 0 015 9z" clip-rule="evenodd" />
          </svg>
          {blog.badge}
        </span>
        <h2 class="text-4xl font-bold text-kli-foreground md:text-5xl lg:text-6xl tracking-tight">
          {blog.heading.split(' ').slice(0, 2).join(' ')} <span class="bg-gradient-to-r from-kli-primary to-kli-secondary bg-clip-text text-transparent">{blog.heading.split(' ')[2] || ''}</span> {blog.heading.split(' ').slice(3).join(' ')}
        </h2>
        <p class="mx-auto max-w-2xl text-xl text-kli-muted-foreground">
          {blog.subheading}
        </p>
      </div>

      <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-2">
        {blog.posts.map((post, index) => (
          <div class="group relative bg-kli-card rounded-2xl shadow-xl hover:shadow-2xl hover:-translate-y-2 transition-all duration-500 border border-kli-border overflow-hidden flex flex-col">
            <!-- Version badge -->
            <div class="absolute top-5 left-5 z-10">
              <span class:list={[
                "text-xs font-bold px-3 py-1.5 rounded-full shadow-lg backdrop-blur-sm",
                index % 2 === 0 ? "bg-gradient-to-r from-kli-primary to-kli-secondary text-white" : "bg-gradient-to-r from-kli-tech to-kli-secondary text-white"
              ]}>
                {post.version}
              </span>
            </div>
            <!-- Image container -->
            <div class="relative overflow-hidden h-64">
              <img
                src={post.image}
                alt={post.title}
                loading="lazy"
                class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-110"
              />
              <!-- Gradient overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            </div>

            <div class="flex-grow p-7 sm:p-9">
              <!-- Date -->
              <div class="flex items-center mb-3 text-kli-muted-foreground text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <time datetime={new Date(post.date).toISOString().split('T')[0]}>{post.date}</time>
              </div>

              <!-- Title -->
              <h3 class:list={[
                "text-2xl font-bold text-kli-foreground mb-4 transition-colors duration-300",
                index % 2 === 0 ? "group-hover:text-kli-primary" : "group-hover:text-kli-tech"
              ]}>
                {post.title}
              </h3>

              <!-- Description -->
              <p class="text-kli-muted-foreground mb-8">
                {post.description}
              </p>

              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mt-auto mb-6">
                {post.tags.map((tag, tagIndex) => {
                  let tagClass = "bg-kli-accent text-kli-primary text-xs font-medium px-3 py-1.5 rounded-full flex items-center shadow-sm";
                  let iconPath = "M5 13l4 4L19 7";
                  
                  if (tagIndex === 1) {
                    tagClass = "bg-kli-tech-muted text-kli-tech text-xs font-medium px-3 py-1.5 rounded-full flex items-center shadow-sm";
                    iconPath = "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z";
                  } else if (tagIndex === 2) {
                    tagClass = "bg-kli-step-muted text-kli-step text-xs font-medium px-3 py-1.5 rounded-full flex items-center shadow-sm";
                    iconPath = "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z";
                  }

                  return (
                    <span class={tagClass}>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPath} />
                      </svg>
                      {tag}
                    </span>
                  );
                })}
              </div>

              <!-- Call to action -->
              <a
                href={post.link}
                class:list={[
                  "inline-flex items-center px-4 py-2 rounded-lg font-medium transition-all group",
                  index % 2 === 0 ? "bg-kli-accent text-kli-primary hover:bg-kli-primary hover:text-white" : "bg-kli-tech-muted text-kli-tech hover:bg-kli-tech hover:text-white"
                ]}
              >
                Learn more
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Call to action section -->
      <div class="mt-20 text-center">
        <a
          href={blog.cta.href}
          class="inline-flex items-center px-8 py-4 rounded-full border-2 border-kli-primary/20 bg-gradient-to-r from-kli-primary/10 to-kli-secondary/10 text-kli-primary font-medium shadow-lg shadow-kli-primary/5 hover:border-kli-primary/50 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
        >
          <span class="text-lg">{blog.cta.text}</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
  </Container>
</div>
