---
import Container from "../shared/Container.astro";
import { measurementUnit as mu } from "@/data/kubmin";

const outputAccents = ["#f0d28a", "#b6d2d8", "#e8b4c0"];

// light YAML tinting: key before colon, value after
const codeLines = mu.annotation.split("\n").map((line) => {
  const m = line.match(/^(\s*)([^:\s][^:]*):(.*)$/);
  if (m) return { indent: m[1], key: m[2], value: m[3], raw: null };
  return { indent: "", key: null, value: null, raw: line };
});
---

<section id="measurement-unit" class="relative py-28 md:py-36 overflow-hidden km-invert scroll-mt-20">
  <div class="absolute inset-0 km-grain opacity-[0.2] pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="max-w-4xl">
      <span class="km-eyebrow">{mu.label}</span>
      <h2 class="mt-6 text-4xl md:text-6xl leading-[1.05] font-medium" style="color: var(--color-kubmin-base)">
        {mu.heading}<br />
        <span class="km-italic km-grad-gold">{mu.headingAccent}</span>
      </h2>
    </div>

    <div class="mt-16 grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      <div class="lg:col-span-5">
        <p class="text-lg md:text-xl leading-relaxed" style="color: rgb(250 244 237 / 0.85)">
          {mu.intro}
        </p>

        <div class="mt-10 km-mono text-xs uppercase tracking-[0.22em]" style="color: rgb(250 244 237 / 0.55)">
          {mu.unitsLabel}
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          {mu.units.map((unit) => (
            <span class="km-mono text-xs px-3.5 py-1.5 rounded-full" style="border: 1px solid rgb(250 244 237 / 0.25); color: rgb(250 244 237 / 0.85); letter-spacing: 0.04em;">
              {unit}
            </span>
          ))}
        </div>

        <p class="mt-10 text-sm leading-relaxed pl-5 border-l-2" style="color: rgb(250 244 237 / 0.7); border-color: #b6d2d8;">
          {mu.sciNote}
        </p>
      </div>

      <div class="lg:col-span-7 min-w-0">
        <div class="km-code">
          <div class="km-code-bar">
            <span>{mu.annotationTitle}</span>
            <span style="letter-spacing: 0.06em; text-transform: none;">{mu.annotationFile}</span>
          </div>
          <pre><code>{codeLines.map((line) => (
            <span class="block whitespace-pre">{line.raw !== null ? (
              <span class="tok-dim">{line.raw}</span>
            ) : (
              <>{line.indent}<span class="tok-key">{line.key}</span><span class="tok-dim">:</span><span class="tok-val">{line.value}</span></>
            )}</span>
          ))}</code></pre>
        </div>

        <a
          href={mu.prLink.href}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-2 km-mono text-xs px-3.5 py-1.5 rounded-full transition-colors hover:[border-color:rgb(250_244_237_/_0.6)] hover:[color:rgb(250_244_237)]"
          style="border: 1px solid rgb(250 244 237 / 0.25); color: rgb(250 244 237 / 0.75); letter-spacing: 0.04em;"
        >
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.19 1.76 1.19 1.03 1.76 2.69 1.25 3.35.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.38-5.26 5.66.41.35.77 1.05.77 2.12 0 1.53-.01 2.76-.01 3.14 0 .3.21.67.8.55A10.52 10.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z"/></svg>
          {mu.prLink.label}
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>

        <div class="mt-8 km-mono text-xs uppercase tracking-[0.22em]" style="color: rgb(250 244 237 / 0.55)">
          {mu.outputsTitle}
        </div>
        <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-6">
          {mu.outputs.map((out, i) => (
            <div class="pl-4" style={`border-left: 1px solid rgb(250 244 237 / 0.18);`}>
              <div class="km-mono text-lg md:text-xl tabular-nums leading-tight" style={`color: ${outputAccents[i % outputAccents.length]}`}>
                {out.value}
              </div>
              <div class="mt-2 text-xs leading-relaxed" style="color: rgb(250 244 237 / 0.6)">{out.note}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-24 pt-16" style="border-top: 1px solid rgb(250 244 237 / 0.12)">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-8 text-center">
        <div class="flex items-baseline gap-5">
          <span class="km-display italic text-5xl md:text-6xl font-medium" style="color: var(--color-kubmin-base)">{mu.formula.lead}</span>
          <span class="km-display text-4xl" style="color: rgb(250 244 237 / 0.5)">=</span>
        </div>
        <div class="flex flex-col items-center px-2">
          <span class="text-lg md:text-xl" style="color: rgb(250 244 237 / 0.85)">{mu.formula.numerator}</span>
          <span class="my-3 h-px w-full min-w-[16rem]" style="background: rgb(250 244 237 / 0.35)"></span>
          <span class="km-italic text-lg md:text-xl km-grad-gold">{mu.formula.denominator}</span>
        </div>
      </div>
      <p class="mt-10 text-center text-sm leading-relaxed max-w-xl mx-auto" style="color: rgb(250 244 237 / 0.55)">
        {mu.formula.caption}
      </p>
    </div>
  </Container>
</section>
