---
interface Props {
  imageSrc: string;
  imageAlt: string;
  loading?: 'lazy' | 'eager';
  className?: string;
  glowColor?: 'cost' | 'energy' | 'primary' | 'none';
  browserUrl?: string;
}

const {
  imageSrc,
  imageAlt,
  loading = 'lazy',
  className = '',
  glowColor = 'primary',
  browserUrl = 'kubmin.ksctl.com',
} = Astro.props;

const glowMap = {
  cost:    'rgb(234 157 52 / 0.32)',
  energy:  'rgb(86 148 159 / 0.32)',
  primary: 'rgb(144 122 169 / 0.40)',
  none:    'rgb(87 82 121 / 0.18)',
};
const glow = glowMap[glowColor];
---

<div class={`relative ${className}`}>
  <div
    class="absolute -inset-4 rounded-[28px] blur-3xl opacity-90 pointer-events-none"
    style={`background: radial-gradient(ellipse at 50% 80%, ${glow}, transparent 65%);`}
  ></div>

  <div class="relative km-browser">
    <div class="km-browser-bar">
      <span class="km-browser-dot" style="background:#e0a3a3"></span>
      <span class="km-browser-dot" style="background:#e6c890"></span>
      <span class="km-browser-dot" style="background:#a9c4b6"></span>
      <span class="km-browser-url">{browserUrl}</span>
      <span class="text-[10px] km-mono tracking-[0.18em] uppercase" style="color: var(--color-kubmin-subtle-text); opacity:0.55;">live</span>
    </div>
    <img
      src={imageSrc}
      alt={imageAlt}
      loading={loading}
      decoding="async"
      class="w-full h-auto block"
    />
  </div>
</div>
