---

<section class="km-section--raised reveal-on-scroll">
  <div class="km-divider"></div>
  <div class="km-container py-14 md:py-16">
    <p class="km-label text-center mb-10">Built on Proven Foundations</p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-16 max-w-[900px] mx-auto">
      <a href="https://sustainable-computing.io/" target="_blank" rel="noopener" class="flex items-start gap-4 group text-center md:text-left flex-col md:flex-row items-center md:items-start">
        <div class="w-11 h-11 rounded-xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center flex-shrink-0 group-hover:border-[#4ade80]/20 group-hover:bg-[#4ade80]/5 transition-all duration-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-zinc-600 group-hover:text-[#4ade80] transition-colors duration-300">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
          </svg>
        </div>
        <div>
          <p class="text-[13px] font-bold text-white mb-1">CNCF Project</p>
          <p class="text-[12px] text-zinc-600 leading-relaxed">Energy measurement powered by Kepler — kernel-level container energy attribution</p>
        </div>
      </a>

      <a href="https://sci.greensoftware.foundation/" target="_blank" rel="noopener" class="flex items-start gap-4 group text-center md:text-left flex-col md:flex-row items-center md:items-start">
        <div class="w-11 h-11 rounded-xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center flex-shrink-0 group-hover:border-[#4ade80]/20 group-hover:bg-[#4ade80]/5 transition-all duration-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-zinc-600 group-hover:text-[#4ade80] transition-colors duration-300">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
            <path d="M2 12h20"></path>
          </svg>
        </div>
        <div>
          <p class="text-[13px] font-bold text-white mb-1">Green Software Foundation</p>
          <p class="text-[12px] text-zinc-600 leading-relaxed">SCI-aligned sustainability scoring built on the GSF specification</p>
        </div>
      </a>

      <a href="https://github.com/ksctl" target="_blank" rel="noopener" class="flex items-start gap-4 group text-center md:text-left flex-col md:flex-row items-center md:items-start">
        <div class="w-11 h-11 rounded-xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center flex-shrink-0 group-hover:border-[#4ade80]/20 group-hover:bg-[#4ade80]/5 transition-all duration-300">
          <img src="/ksctl-logo.svg" alt="ksctl" class="w-5 h-5 opacity-40 group-hover:opacity-90 transition-opacity duration-300" />
        </div>
        <div>
          <p class="text-[13px] font-bold text-white mb-1">Open Source</p>
          <p class="text-[12px] text-zinc-600 leading-relaxed">Cluster management powered by ksctl — fully open source on GitHub</p>
        </div>
      </a>
    </div>
  </div>
  <div class="km-divider"></div>
</section>
