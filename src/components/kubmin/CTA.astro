---
import Container from "../shared/Container.astro";
import { finalCta } from "@/data/kubmin";
---

<section class="relative py-32 md:py-40 overflow-hidden" style="background: var(--color-kubmin-base);">
  <div class="km-blob km-blob-iris" style="width: 40rem; height: 40rem; top: -10rem; left: 50%; transform: translateX(-50%); opacity: .45"></div>
  <div class="km-blob km-blob-gold" style="width: 28rem; height: 28rem; bottom: -8rem; right: 10%; opacity: .35"></div>
  <div class="absolute inset-0 km-dotgrid opacity-60 pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="max-w-5xl mx-auto text-center">
      <span class="km-eyebrow" style="justify-content: center;">
        <span>finale</span>
        <span class="km-dot" style="color: var(--color-kubmin-cost)"></span>
        <span>The bill is running</span>
      </span>

      <h2 class="mt-10 text-5xl md:text-7xl lg:text-8xl leading-[0.95] font-medium" style="color: var(--color-kubmin-text)">
        {finalCta.headlinePrefix}<br/>
        <span class="km-italic km-grad-warm">{finalCta.headlineAccent}</span>
      </h2>

      <p class="mt-10 text-xl md:text-2xl km-italic max-w-2xl mx-auto" style="color: var(--color-kubmin-subtle-text)">
        {finalCta.subtitle}
      </p>

      <div class="mt-12 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={finalCta.primaryAction.href} class="km-btn km-btn-primary">
          {finalCta.primaryAction.text}
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </a>
        <a href={finalCta.secondaryAction.href} class="km-btn km-btn-ghost">
          {finalCta.secondaryAction.text}
        </a>
      </div>

      <div class="mt-20 km-hairline max-w-md mx-auto"></div>
      <div class="mt-6 km-mono text-[11px] uppercase tracking-[0.22em]" style="color: var(--color-kubmin-subtle-text)">
        kubmin.ksctl.com · sign in with github · setup ~10 min
      </div>
    </div>
  </Container>
</section>
