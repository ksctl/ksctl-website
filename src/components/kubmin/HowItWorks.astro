---
import Container from "../shared/Container.astro";
import { howItWorks } from "@/data/kubmin";

const stepAccents = [
  "var(--color-kubmin-iris)",
  "var(--color-kubmin-energy)",
  "var(--color-kubmin-cost)",
];
---

<section class="relative py-28 md:py-36 overflow-hidden" style="background: var(--color-kubmin-overlay);">
  <div class="absolute inset-0 km-grain opacity-[0.15] pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="km-eyebrow" style="justify-content: center;">{howItWorks.label} · ch. 04</span>
      <h2 class="mt-6 text-4xl md:text-6xl leading-[1.02] font-medium" style="color: var(--color-kubmin-text)">
        {howItWorks.heading}<br/>
        <span class="km-italic km-grad-iris">{howItWorks.headingAccent}</span>
      </h2>
    </div>

    <div class="relative max-w-6xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {howItWorks.steps.map((step, i) => (
          <article class="relative km-paper km-lift rounded-3xl p-8 md:p-9 flex flex-col">
            <div class="absolute inset-x-8 top-0 h-[2px] rounded-b" style={`background: ${stepAccents[i % stepAccents.length]}; opacity: 0.8;`}></div>
            <div class="flex items-baseline justify-between gap-4">
              <span class="km-display italic text-7xl md:text-8xl font-light leading-none" style={`color: color-mix(in srgb, ${stepAccents[i % stepAccents.length]} 45%, var(--color-kubmin-surface));`}>
                0{i + 1}
              </span>
              <span class="km-mono text-xs uppercase tracking-[0.22em]" style="color: var(--color-kubmin-subtle-text)">
                step
              </span>
            </div>
            <h3 class="mt-8 text-xl md:text-2xl font-medium leading-snug" style="color: var(--color-kubmin-text)">
              {step.title}
            </h3>
            <p class="mt-4 leading-relaxed text-sm md:text-base" style="color: var(--color-kubmin-subtle-text)">
              {step.body}
            </p>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-20 flex flex-col items-center gap-6">
      <a href={howItWorks.cta.href} class="km-btn km-btn-primary">
        {howItWorks.cta.text}
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </a>
      <p class="km-italic text-sm max-w-md text-center" style="color: var(--color-kubmin-subtle-text)">
        {howItWorks.disclaimer}
      </p>
    </div>
  </Container>
</section>
