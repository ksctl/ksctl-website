---
---

<section class="km-section--surface relative reveal-on-scroll overflow-hidden">
  <div class="km-divider"></div>

  <div class="km-container relative z-10" style="padding-top: var(--km-section-py); padding-bottom: var(--km-section-py);">
    <div class="mb-4">
      <p class="km-label">See It In Action</p>
    </div>
    <h2 class="km-heading text-[clamp(1.75rem,4vw,3rem)] mb-4 max-w-[650px]">
      Three Redis versions. Same workload. Wildly different efficiency.
    </h2>
    <p class="text-zinc-500 mb-12 max-w-[580px] text-[15px] leading-relaxed">
      We ran redis-benchmark across versions 8.6.1, 8.4.0, and 8.2.1. Here's what kubmin found — no other tool surfaces this.
    </p>

    <!-- Screenshot in browser frame -->
    <div class="relative mb-12">
      <div class="km-screenshot-glow">
        <div class="km-browser relative shadow-km-browser">
          <div class="km-browser-bar">
            <span class="km-browser-dot bg-[#ff5f57]/80"></span>
            <span class="km-browser-dot bg-[#febc2e]/80"></span>
            <span class="km-browser-dot bg-[#28c840]/80"></span>
            <span class="ml-4 text-[11px] text-zinc-600 font-mono tracking-wide">kubmin.ksctl.com/workloads/compareall</span>
          </div>
          <div class="overflow-x-auto">
            <img
              src="/kubmin/kubmin-workload-redis.png"
              alt="Kubmin multi-version comparison showing CPU, memory, energy, SCI, SEE, and cost differences across Redis 8.6.1, 8.4.0, and 8.2.1"
              loading="lazy"
              class="w-full block min-w-[600px]"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- 4 stat callouts -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 mb-12">
      <div class="text-center md:text-left">
        <p class="km-stat-num">63%</p>
        <p class="text-[13px] text-zinc-600 mt-2 leading-snug">more CPU — 8.4.0 vs 8.2.1<br/><span class="text-zinc-700">(243m vs 149m)</span></p>
      </div>
      <div class="text-center md:text-left">
        <p class="km-stat-num">31%</p>
        <p class="text-[13px] text-zinc-600 mt-2 leading-snug">more energy — 8.4.0 vs 8.6.1<br/><span class="text-zinc-700">(0.0085 vs 0.0064 kWh)</span></p>
      </div>
      <div class="text-center md:text-left">
        <p class="km-stat-num text-[clamp(1.5rem,3vw,2.25rem)]">$0.11 <span class="text-zinc-600 text-[0.6em]">vs</span> $0.18</p>
        <p class="text-[13px] text-zinc-600 mt-2 leading-snug">cost gap — 8.6.1 vs 8.4.0<br/>per tracked period</p>
      </div>
      <div class="text-center md:text-left">
        <p class="km-stat-num">31%</p>
        <p class="text-[13px] text-zinc-600 mt-2 leading-snug">more efficient — 8.2.1 vs 8.4.0<br/>on SEE score</p>
      </div>
    </div>

    <!-- Insight callout -->
    <div class="km-insight mb-10">
      <p class="text-[15px] text-zinc-300 leading-relaxed">
        8.4.0 uses 87.8% CPU but isn't the most expensive. 8.2.1 uses 51.2% CPU but costs more. No single metric tells the full story — you need cost, energy, and efficiency together. That's what kubmin gives you.
      </p>
    </div>

    <!-- Caption + CTA -->
    <p class="text-[13px] text-zinc-600 text-center mb-8 italic">
      This is one workload. Imagine what kubmin finds across your entire cluster.
    </p>

    <div class="text-center">
      <a href="https://kubmin.ksctl.com" target="_blank" rel="noopener" class="km-cta">
        Try It On Your Workloads <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</section>
