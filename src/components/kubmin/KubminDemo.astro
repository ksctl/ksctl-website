---
import Container from "../Container.astro";
import BrowserMockup from "../BrowserMockup.astro";
import { productDemo } from "@/data/kubmin";
---

<section class="py-32 relative bg-[#0a0a0a] overflow-hidden text-white">
  <!-- Gradient blobs — matching hero section, orange/yellow/green -->
  <div class="flex flex-col items-start absolute -left-60 top-1/4 blur-xl z-0 opacity-40">
    <div class="h-[10rem] rounded-full w-[60rem] bg-gradient-to-b blur-[6rem] from-amber-500 to-emerald-600"></div>
    <div class="h-[10rem] rounded-full w-[90rem] bg-gradient-to-b blur-[6rem] from-orange-800 to-yellow-400"></div>
  </div>

  <!-- Noise/grain texture overlay -->
  <div class="absolute inset-0 z-0 opacity-[0.35] pointer-events-none hero-noise"></div>
  
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/10 text-white/80 text-sm font-semibold tracking-wide uppercase mb-6 backdrop-blur-md">
        {productDemo.label}
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 text-balance">
        {productDemo.heading} <span class="text-transparent bg-clip-text bg-gradient-to-r from-amber-400 to-emerald-400">{productDemo.headingAccent}</span>
      </h2>
      <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto">
        {productDemo.body}
      </p>
    </div>

    <div class="relative max-w-5xl mx-auto mb-20">
      <BrowserMockup
        imageSrc={productDemo.screenshot.src}
        imageAlt={productDemo.screenshot.alt}
        addressBarText={productDemo.screenshot.browserUrl}
        className="shadow-[0_0_60px_rgba(16,185,129,0.15)] ring-1 ring-white/10"
      />
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-20 max-w-5xl mx-auto">
      {productDemo.stats.map((stat) => (
        <div class="flex flex-col items-center justify-center text-center p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:bg-white/[0.04] transition-colors h-full">
          <div class="text-4xl md:text-5xl font-extrabold tracking-tighter text-white mb-3 font-mono drop-shadow-md">
            {stat.value}
          </div>
          <div class="text-sm font-bold text-amber-400 mb-1">{stat.label}</div>
          <div class="text-xs text-gray-500 font-medium">{stat.detail}</div>
        </div>
      ))}
    </div>

    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="text-xl md:text-2xl font-medium text-white/80 font-['Instrument_Serif',serif] italic mb-10 border-l-2 border-emerald-500 pl-6 text-left leading-relaxed">
        "{productDemo.insight}"
      </blockquote>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6 bg-white/[0.03] border border-white/10 p-6 md:p-8 rounded-3xl backdrop-blur-sm shadow-xl">
        <p class="text-gray-400 text-sm m-0 text-left">{productDemo.caption}</p>
        <a href={productDemo.cta.href} class="whitespace-nowrap px-8 py-4 rounded-full bg-gradient-to-r from-amber-500 to-emerald-500 text-white font-bold hover:scale-105 transition-all shadow-[0_0_20px_rgba(16,185,129,0.3)]">
          {productDemo.cta.text}
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
/* Noise texture via SVG filter */
.hero-noise {
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px 128px;
}
</style>
