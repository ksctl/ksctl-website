---
import Container from "../Container.astro";
import BrowserMockup from '../BrowserMockup.astro';
import { productDemo } from '@/data/kubmin';
---

<section class="py-32 relative bg-kubmin-dark overflow-hidden text-white">
  <!-- Gradient blobs — matching hero section, orange/yellow/green -->
  <div class="flex flex-col items-start absolute -left-60 top-1/4 blur-xl z-0 opacity-40">
    <div class="h-[10rem] rounded-full w-[60rem] bg-gradient-to-b blur-[6rem] from-kubmin-cost to-kubmin-energy"></div>
    <div class="h-[10rem] rounded-full w-[90rem] bg-gradient-to-b blur-[6rem] from-kubmin-orange to-kubmin-yellow"></div>
  </div>

  <div class="absolute inset-0 z-0 opacity-[0.35] pointer-events-none hero-noise"></div>
  
  <Container class="relative z-10">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/10 text-white/80 text-sm font-semibold tracking-wide uppercase mb-6 backdrop-blur-md">
        {productDemo.label}
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-6 text-balance">
        {productDemo.heading} <span class="text-transparent bg-clip-text bg-gradient-to-r from-kubmin-cost to-kubmin-energy">{productDemo.headingAccent}</span>
      </h2>
      <p class="text-lg md:text-xl text-kubmin-neutral-400 max-w-2xl mx-auto">
        {productDemo.body}
      </p>
    </div>

    <div class="relative max-w-5xl mx-auto mb-20">
      <BrowserMockup
        imageSrc={productDemo.screenshot.src}
        imageAlt={productDemo.screenshot.alt}
        addressBarText={productDemo.screenshot.browserUrl}
        className="shadow-[--shadow-kubmin-energy-glow-soft] ring-1 ring-white/10"
      />
    </div>

    <!-- Stats Row -->
    <div 
      class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6 mb-20 max-w-5xl mx-auto"
      x-data="{ 
        animate(target, duration, callback) {
          const start = 0;
          const startTime = performance.now();
          
          const step = (currentTime) => {
            const progress = Math.min((currentTime - startTime) / duration, 1);
            // Ease out cubic
            const easedProgress = 1 - Math.pow(1 - progress, 3);
            const current = start + (target - start) * easedProgress;
            callback(current);
            if (progress < 1) {
              requestAnimationFrame(step);
            }
          };
          requestAnimationFrame(step);
        }
      }"
    >
      {productDemo.stats.map((stat, i) => {
        const colors = [
          'text-kubmin-cost', 
          'text-kubmin-energy', 
          'text-kubmin-cost', 
          'text-white'
        ];
        const color = colors[i % colors.length];
        
        return (
          <div 
            class="flex flex-col items-center justify-center text-center p-6 md:p-8 rounded-[2rem] bg-white/5 border border-white/10 backdrop-blur-md hover:bg-white/10 hover:border-white/20 transition-all duration-300 h-full"
            x-data={`{ 
              displayValue: '${stat.value}',
              isAnimated: false,
              startAnimation() {
                if (this.isAnimated) return;
                this.isAnimated = true;
                
                const val = '${stat.value}';
                if (val.includes(' vs ')) {
                  const parts = val.split(' vs ');
                  this.setupMulti(parts[0], parts[1]);
                } else {
                  this.setupSingle(val);
                }
              },
              setupSingle(val) {
                const match = val.match(/^([^\\d]*)(\\d+(?:\\.\\d+)?)([^\\d]*)$/);
                if (match) {
                  const prefix = match[1];
                  const target = parseFloat(match[2]);
                  const suffix = match[3];
                  const isDecimal = match[2].includes('.');
                  this.animate(target, 2000, (v) => {
                    this.displayValue = prefix + (isDecimal ? v.toFixed(2) : Math.floor(v)) + suffix;
                  });
                }
              },
              setupMulti(v1, v2) {
                const m1 = v1.match(/^([^\\d]*)(\\d+(?:\\.\\d+)?)([^\\d]*)$/);
                const m2 = v2.match(/^([^\\d]*)(\\d+(?:\\.\\d+)?)([^\\d]*)$/);
                if (m1 && m2) {
                  const p1 = m1[1], t1 = parseFloat(m1[2]), s1 = m1[3], d1 = m1[2].includes('.');
                  const p2 = m2[1], t2 = parseFloat(m2[2]), s2 = m2[3], d2 = m2[2].includes('.');
                  this.animate(1, 2000, (p) => {
                    const eased = 1 - Math.pow(1 - p, 3);
                    const cur1 = t1 * eased;
                    const cur2 = t2 * eased;
                    this.displayValue = \`\${p1}\${d1 ? cur1.toFixed(2) : Math.floor(cur1)}\${s1} vs \${p2}\${d2 ? cur2.toFixed(2) : Math.floor(cur2)}\${s2}\`;
                  });
                }
              }
            }`}
            x-intersect.once="startAnimation()"
          >
            <div class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-5 font-sans tabular-nums drop-shadow-sm flex flex-row items-center justify-center leading-none gap-2" x-text="displayValue">
              {stat.value}
            </div>
            <div class={`text-sm font-bold mb-1.5 tracking-wide ${color}`}>{stat.label}</div>
            <div class="text-xs text-kubmin-neutral-400 font-medium">{stat.detail}</div>
          </div>
        );
      })}
    </div>

    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="text-xl md:text-2xl font-medium text-white/80 italic mb-10 border-l-2 border-kubmin-energy pl-6 text-left leading-relaxed">
        {productDemo.insight}
      </blockquote>
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6 bg-white/[0.03] border border-white/10 p-6 md:p-8 rounded-3xl backdrop-blur-sm shadow-xl">
        <p class="text-kubmin-neutral-400 text-sm m-0 text-left">{productDemo.caption}</p>
        <a href={productDemo.cta.href} class="whitespace-nowrap px-8 py-4 rounded-full bg-gradient-to-r from-kubmin-cost to-kubmin-energy text-white font-bold hover:scale-105 transition-all shadow-[--shadow-kubmin-energy-glow]">
          {productDemo.cta.text}
        </a>
      </div>
    </div>
  </Container>
</section>

<style>
.hero-noise {
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-repeat: repeat;
  background-size: 128px 128px;
}
</style>
