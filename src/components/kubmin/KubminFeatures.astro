---
import Container from "../Container.astro";
import { coreFeatures } from "@/data/kubmin";
---

<section class="py-24 bg-kubmin-neutral-50">
  <Container>
    <div class="mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-kubmin-primary-50 border border-kubmin-primary-100 text-kubmin-primary-700 text-sm font-semibold tracking-wide uppercase mb-6">
        {coreFeatures.label}
      </div>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-kubmin-neutral-900 max-w-2xl text-balance">
        {coreFeatures.heading}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Feature 1: THE MOAT — span 2, primary accent to call out flagship differentiator without leaving the card family -->
      <div class="md:col-span-2 bg-gradient-to-br from-kubmin-primary-50/60 to-white rounded-3xl p-8 md:p-12 border-2 border-kubmin-primary-200 shadow-sm hover:shadow-xl hover:shadow-kubmin-primary-500/15 hover:-translate-y-1 flex flex-col justify-between group hover:border-kubmin-primary-300 transition-all duration-300">
        <div>
          <div class="flex items-center gap-2 mb-6">
            <span class="inline-block px-3 py-1 bg-kubmin-primary-100 text-kubmin-primary-700 rounded-full text-xs font-semibold">{coreFeatures.features[0].tag}</span>
            <span class="inline-block px-2 py-1 bg-kubmin-primary-600 text-white rounded-full text-[10px] font-bold uppercase tracking-wider">Flagship</span>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold text-kubmin-neutral-900 mb-4">{coreFeatures.features[0].title}</h3>
          <p class="text-kubmin-neutral-600 text-lg leading-relaxed max-w-xl">{coreFeatures.features[0].body}</p>
        </div>
      </div>

      <!-- Feature 2: Small -->
      <div class="bg-white rounded-3xl p-8 border border-kubmin-neutral-100 shadow-sm hover:shadow-xl hover:shadow-kubmin-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-kubmin-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-kubmin-neutral-100 text-kubmin-neutral-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[1].tag}</span>
          <h3 class="text-xl font-bold text-kubmin-neutral-900 mb-4">{coreFeatures.features[1].title}</h3>
          <p class="text-kubmin-neutral-500 leading-relaxed">{coreFeatures.features[1].body}</p>
        </div>
      </div>

      <!-- Feature 3: Small -->
      <div class="bg-white rounded-3xl p-8 border border-kubmin-neutral-100 shadow-sm hover:shadow-xl hover:shadow-kubmin-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-kubmin-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-kubmin-neutral-100 text-kubmin-neutral-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[2].tag}</span>
          <h3 class="text-xl font-bold text-kubmin-neutral-900 mb-4">{coreFeatures.features[2].title}</h3>
          <p class="text-kubmin-neutral-500 leading-relaxed">{coreFeatures.features[2].body}</p>
        </div>
      </div>

      <!-- Feature 4: Medium (span 2) -->
      <div class="md:col-span-2 bg-white rounded-3xl p-8 md:p-10 border border-kubmin-neutral-100 shadow-sm hover:shadow-xl hover:shadow-kubmin-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-kubmin-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-kubmin-neutral-100 text-kubmin-neutral-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[3].tag}</span>
          <h3 class="text-2xl font-bold text-kubmin-neutral-900 mb-4">{coreFeatures.features[3].title}</h3>
          <p class="text-kubmin-neutral-500 leading-relaxed max-w-2xl">{coreFeatures.features[3].body}</p>
        </div>
      </div>

      <!-- Feature 5: Medium (span 2) -->
      <div class="md:col-span-2 bg-white rounded-3xl p-8 md:p-10 border border-kubmin-neutral-100 shadow-sm hover:shadow-xl hover:shadow-kubmin-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-kubmin-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-kubmin-neutral-100 text-kubmin-neutral-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[4].tag}</span>
          <h3 class="text-2xl font-bold text-kubmin-neutral-900 mb-4">{coreFeatures.features[4].title}</h3>
          <p class="text-kubmin-neutral-500 leading-relaxed max-w-2xl">{coreFeatures.features[4].body}</p>
        </div>
      </div>

      <!-- Feature 6: Small — Quick Wins, same family as the rest -->
      <div class="bg-white rounded-3xl p-8 border border-kubmin-neutral-100 shadow-sm hover:shadow-xl hover:shadow-kubmin-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-kubmin-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-kubmin-neutral-100 text-kubmin-neutral-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[5].tag}</span>
          <h3 class="text-xl font-bold text-kubmin-neutral-900 mb-4">{coreFeatures.features[5].title}</h3>
          <p class="text-kubmin-neutral-500 leading-relaxed">{coreFeatures.features[5].body}</p>
        </div>
      </div>
    </div>
  </Container>
</section>
