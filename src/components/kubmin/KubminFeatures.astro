---
import Container from "../Container.astro";
import { coreFeatures } from "@/data/kubmin";
---

<section class="py-24 bg-gray-50">
  <Container>
    <div class="mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary-50 border border-primary-100 text-primary-700 text-sm font-semibold tracking-wide uppercase mb-6">
        {coreFeatures.label}
      </div>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-gray-900 max-w-2xl text-balance">
        {coreFeatures.heading}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Feature 1: Large -->
      <div class="md:col-span-2 bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[0].tag}</span>
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">{coreFeatures.features[0].title}</h3>
          <p class="text-gray-500 text-lg leading-relaxed max-w-xl">{coreFeatures.features[0].body}</p>
        </div>
      </div>

      <!-- Feature 2: Small -->
      <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[1].tag}</span>
          <h3 class="text-xl font-bold text-gray-900 mb-4">{coreFeatures.features[1].title}</h3>
          <p class="text-gray-500 leading-relaxed">{coreFeatures.features[1].body}</p>
        </div>
      </div>

      <!-- Feature 3: Small -->
      <div class="bg-white rounded-3xl p-8 border border-gray-100 shadow-sm hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[2].tag}</span>
          <h3 class="text-xl font-bold text-gray-900 mb-4">{coreFeatures.features[2].title}</h3>
          <p class="text-gray-500 leading-relaxed">{coreFeatures.features[2].body}</p>
        </div>
      </div>

      <!-- Feature 4: Large/Medium span 2 -->
      <div class="md:col-span-2 bg-white rounded-3xl p-8 md:p-12 border border-gray-100 shadow-sm hover:shadow-xl hover:shadow-primary-500/10 hover:-translate-y-1 flex flex-col justify-between group hover:border-primary-200 transition-all duration-300">
        <div>
          <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-xs font-medium mb-6">{coreFeatures.features[3].tag}</span>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">{coreFeatures.features[3].title}</h3>
          <p class="text-gray-500 text-lg leading-relaxed max-w-2xl">{coreFeatures.features[3].body}</p>
        </div>
      </div>
    </div>
  </Container>
</section>
