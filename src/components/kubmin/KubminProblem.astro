---
import Container from "../Container.astro";
import { problemStatement } from "@/data/kubmin";
---

<section class="py-24 bg-white relative">
  <Container>
    <div class="max-w-3xl mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-kubmin-amber-50 border border-kubmin-amber-100 text-kubmin-cost text-sm font-semibold tracking-wide uppercase mb-6">
        {problemStatement.label}
      </div>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-kubmin-neutral-900 text-balance">
        {problemStatement.heading}
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 relative z-10">
      {problemStatement.problems.map((problem, i) => (
        <div class="group relative bg-white p-8 rounded-2xl border border-kubmin-neutral-100 shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col gap-4 overflow-hidden">
          <div class="absolute top-0 left-0 bottom-0 w-1 bg-kubmin-cost transform origin-bottom scale-y-0 group-hover:scale-y-100 transition-transform duration-500 ease-out"></div>
          <div class="text-4xl font-extrabold text-kubmin-neutral-100 font-kubmin-accent italic mb-2">
            0{i + 1}
          </div>
          <h3 class="text-xl font-semibold text-kubmin-neutral-900">{problem.title}</h3>
          <p class="text-kubmin-neutral-500 leading-relaxed">{problem.body}</p>
        </div>
      ))}
    </div>
  </Container>
</section>
