---
import Container from "../shared/Container.astro";
import { faq } from "@/data/kubmin";
---

<section class="relative py-28 md:py-36" style="background: var(--color-kubmin-overlay);">
  <Container>
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-4">
        <span class="km-eyebrow">addendum</span>
        <h2 class="mt-6 text-4xl md:text-5xl leading-[1.02] font-medium" style="color: var(--color-kubmin-text)">
          Frequently<br/>
          <span class="km-italic" style="color: var(--color-kubmin-primary-700)">asked.</span>
        </h2>
        <p class="mt-6 leading-relaxed" style="color: var(--color-kubmin-subtle-text)">
          Honest answers, no marketing fluff. If we don't have the answer here, ask in Discord.
        </p>
      </div>

      <div class="lg:col-span-8 space-y-3">
        {faq.items.map((item, i) => (
          <div class="kubmin-faq-item rounded-2xl overflow-hidden km-paper transition-all">
            <button class="kubmin-faq-question w-full flex items-start justify-between p-6 md:p-7 text-left gap-6 focus:outline-none" aria-expanded="false">
              <div class="flex items-baseline gap-4">
                <span class="km-mono text-[10px] uppercase tracking-[0.22em] shrink-0" style="color: var(--color-kubmin-subtle-text)">Q.{String(i + 1).padStart(2, '0')}</span>
                <span class="text-lg md:text-xl font-medium leading-snug" style="color: var(--color-kubmin-text)">{item.q}</span>
              </div>
              <span class="kubmin-faq-icon shrink-0 w-8 h-8 rounded-full flex items-center justify-center transition-transform" style="background: var(--color-kubmin-overlay); color: var(--color-kubmin-primary-700);">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </span>
            </button>
            <div class="kubmin-faq-answer hidden">
              <div class="px-6 md:px-7 pb-7 -mt-1 leading-relaxed whitespace-pre-wrap" style="color: var(--color-kubmin-subtle-text); padding-left: calc(1.5rem + 4.2rem);">
                {item.a}
                {item.link && (
                  <div class="mt-5">
                    <a href={item.link.href} class="inline-flex items-center gap-1.5 text-sm font-medium" style="color: var(--color-kubmin-primary-700)">
                      {item.link.text}
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const items = document.querySelectorAll('.kubmin-faq-item');
    items.forEach((item) => {
      const q = item.querySelector('.kubmin-faq-question');
      const a = item.querySelector('.kubmin-faq-answer');
      const icon = item.querySelector('.kubmin-faq-icon');
      if (!q || !a || !icon) return;
      q.addEventListener('click', () => {
        const expanded = q.getAttribute('aria-expanded') === 'true';
        items.forEach((other) => {
          if (other === item) return;
          const oq = other.querySelector('.kubmin-faq-question');
          const oa = other.querySelector('.kubmin-faq-answer');
          const oi = other.querySelector('.kubmin-faq-icon');
          if (oq && oa && oi) {
            oq.setAttribute('aria-expanded', 'false');
            oa.classList.add('hidden');
            (oi as HTMLElement).style.transform = 'rotate(0deg)';
          }
        });
        q.setAttribute('aria-expanded', String(!expanded));
        if (!expanded) {
          a.classList.remove('hidden');
          (icon as HTMLElement).style.transform = 'rotate(180deg)';
        } else {
          a.classList.add('hidden');
          (icon as HTMLElement).style.transform = 'rotate(0deg)';
        }
      });
    });
  });
</script>
