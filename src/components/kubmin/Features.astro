---
import Container from "../shared/Container.astro";
import ModernMockup from "./ModernMockup.astro";
import { coreFeatures } from "@/data/kubmin";

const accents = [
  "var(--color-kubmin-iris)",
  "var(--color-kubmin-energy)",
  "var(--color-kubmin-efficiency)",
  "var(--color-kubmin-cost)",
  "var(--color-kubmin-primary-700)",
];

const features = coreFeatures.features;
const headingParts = coreFeatures.headingAccent
  ? coreFeatures.heading.split(coreFeatures.headingAccent)
  : [coreFeatures.heading];
---

<section id="features" class="relative py-28 md:py-36 overflow-hidden" style="background: var(--color-kubmin-overlay);">
  <div class="absolute inset-0 km-grain opacity-[0.18] pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="grid lg:grid-cols-12 gap-10 mb-14 md:mb-16 items-end">
      <div class="lg:col-span-7">
        <span class="km-eyebrow">{coreFeatures.label} · ch. 02</span>
        <h2 class="mt-6 text-4xl md:text-6xl leading-[1.02] font-medium" style="color: var(--color-kubmin-text)">
          {headingParts[0]}
          {coreFeatures.headingAccent && (
            <span class="km-italic" style="color: var(--color-kubmin-primary-700)">{coreFeatures.headingAccent}</span>
          )}
          {headingParts.slice(1).join(coreFeatures.headingAccent)}
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9">
        <div class="km-mono text-xs uppercase tracking-[0.22em] flex items-center gap-3" style="color: var(--color-kubmin-subtle-text)">
          <span class="km-dot" style="background: var(--color-kubmin-iris)"></span>
          {coreFeatures.sideLabel}
        </div>
        <p class="mt-4 text-base leading-relaxed" style="color: var(--color-kubmin-subtle-text)">
          {coreFeatures.description}
        </p>
      </div>
    </div>

    <!-- capability index: table of contents, anchors down to each chapter -->
    <nav aria-label={coreFeatures.label} class="mb-24 md:mb-32">
      <div class="km-hairline"></div>
      {features.map((f, i) => (
        <a
          href={`#feature-${f.id}`}
          class="group flex items-baseline gap-4 md:gap-6 py-4 md:py-5 border-b"
          style="border-color: var(--color-kubmin-border)"
        >
          <span class="km-mono text-xs shrink-0" style={`color: ${accents[i % accents.length]}`}>ch. {f.chapter}</span>
          <span class="km-display text-lg md:text-2xl font-medium leading-snug transition-colors group-hover:[color:var(--color-kubmin-primary-700)]" style="color: var(--color-kubmin-text)">
            {f.title}
          </span>
          <span class="km-mono text-xs shrink-0 hidden sm:inline lowercase sm:ml-auto" style="color: var(--color-kubmin-subtle-text)">{f.tag}</span>
          <svg class="w-4 h-4 shrink-0 self-center -translate-y-0.5 opacity-0 group-hover:opacity-100 transition-opacity" style="color: var(--color-kubmin-primary-700)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      ))}
    </nav>

    <!-- chapters: one dedicated spread per capability, alternating sides -->
    <div class="space-y-24 md:space-y-36">
      {features.map((f, i) => {
        const accent = accents[i % accents.length];
        const flip = i % 2 === 1;
        return (
          <article
            id={`feature-${f.id}`}
            class="grid lg:grid-cols-12 gap-10 lg:gap-14 items-center scroll-mt-28"
          >
            <div class={`lg:col-span-5 min-w-0 ${flip ? "lg:order-2 lg:col-start-8" : ""}`}>
              <span class="km-eyebrow" style={`color: ${accent}`}>ch. {f.chapter} · {f.tag}</span>
              <h3 class="mt-5 text-3xl md:text-4xl font-medium leading-tight" style="color: var(--color-kubmin-text)">
                {f.title}
              </h3>
              <p class="mt-5 leading-relaxed" style="color: var(--color-kubmin-subtle-text)">
                {f.body}
              </p>
              <div class="mt-7 flex flex-wrap items-center gap-3">
                <span class="km-chip" style={`border-color: color-mix(in srgb, ${accent} 45%, transparent); color: ${accent};`}>
                  <span class="km-dot" style={`background: ${accent}`}></span>
                  {f.metric}
                </span>
                {f.hasCrossRef && (
                  <a
                    href={coreFeatures.crossRef.href}
                    class="km-chip transition-colors hover:[border-color:var(--color-kubmin-primary-400)] hover:[color:var(--color-kubmin-primary-700)]"
                  >
                    {coreFeatures.crossRef.text}
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
                  </a>
                )}
              </div>
            </div>

            <div class={`lg:col-span-7 min-w-0 ${flip ? "lg:order-1" : ""}`}>
              <ModernMockup
                imageSrc={f.screenshot.src}
                imageAlt={f.screenshot.alt}
                browserUrl={f.screenshot.browserUrl}
                glowColor={f.glow as "cost" | "energy" | "primary"}
              />
            </div>
          </article>
        );
      })}
    </div>
  </Container>
</section>
