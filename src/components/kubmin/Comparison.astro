---
import Container from "../shared/Container.astro";
import { comparisonTable } from "@/data/kubmin";
---

<section class="relative py-28 md:py-36 overflow-hidden" style="background: var(--color-kubmin-base);">
  <Container class="relative z-10">
    <div class="grid lg:grid-cols-12 gap-10 mb-16 items-end">
      <div class="lg:col-span-7">
        <span class="km-eyebrow">{comparisonTable.label} · ch. 05</span>
        <h2 class="mt-6 text-4xl md:text-6xl leading-[1.02] font-medium" style="color: var(--color-kubmin-text)">
          What your current tools<br/>
          <span class="km-italic km-grad-iris">{comparisonTable.headingAccent}</span>
        </h2>
      </div>
      <div class="lg:col-span-4 lg:col-start-9">
        <p class="km-italic text-lg leading-relaxed" style="color: var(--color-kubmin-subtle-text)">
          We don't replace your monitoring stack. We see what your monitoring stack can't.
        </p>
      </div>
    </div>

    <div class="km-paper rounded-3xl overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse min-w-[820px]">
          <thead>
            <tr>
              <th class="p-6 align-bottom w-1/3"></th>
              {comparisonTable.competitors.map((comp, i) => {
                const isKubmin = i === comparisonTable.competitors.length - 1;
                return (
                  <th class={`p-6 align-bottom text-center w-1/6 ${isKubmin ? '' : ''}`}
                      style={isKubmin
                        ? `background: linear-gradient(180deg, var(--color-kubmin-primary-50), transparent); border-bottom: 2px solid var(--color-kubmin-primary-500); color: var(--color-kubmin-primary-700); font-weight: 600;`
                        : `border-bottom: 1px solid var(--color-kubmin-border); color: var(--color-kubmin-subtle-text); font-weight: 500;`}>
                    <div class="km-mono text-[10px] tracking-[0.2em] uppercase mb-2" style="opacity: 0.6">
                      {isKubmin ? 'us' : `vs ${String.fromCharCode(64 + i + 1)}`}
                    </div>
                    <div class="text-sm">{comp}</div>
                  </th>
                );
              })}
            </tr>
          </thead>
          <tbody>
            {comparisonTable.rows.map((row, ri) => (
              <tr style={`border-top: 1px solid var(--color-kubmin-border);`}>
                <td class="p-5 text-sm font-medium" style="color: var(--color-kubmin-text);">
                  <span class="km-mono text-[10px] mr-3" style="color: var(--color-kubmin-subtle-text)">
                    {String(ri + 1).padStart(2, '0')}
                  </span>
                  {row.capability}
                </td>
                {row.values.map((val, i) => {
                  const isKubmin = i === row.values.length - 1;
                  const isCheck = val.includes('✓');
                  const isCross = val.includes('✗');
                  const cellBg = isKubmin ? 'background: rgb(144 122 169 / 0.06);' : '';
                  return (
                    <td class="p-5 text-center text-sm" style={`${cellBg} color: var(--color-kubmin-subtle-text);`}>
                      {isCheck ? (
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium" style={`background: ${isKubmin ? 'var(--color-kubmin-primary-100)' : 'var(--color-kubmin-muted)'}; color: var(--color-kubmin-primary-700);`}>
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                          {val.replace('✓', '').trim() || 'Yes'}
                        </span>
                      ) : isCross ? (
                        <span style="color: var(--color-kubmin-border)">
                          <svg class="w-4 h-4 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                        </span>
                      ) : (
                        <span style={isKubmin ? 'color: var(--color-kubmin-primary-700); font-weight: 500;' : ''}>{val}</span>
                      )}
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-8 text-center km-italic text-base max-w-2xl mx-auto" style="color: var(--color-kubmin-subtle-text)">
      {comparisonTable.footer}
    </p>
  </Container>
</section>
