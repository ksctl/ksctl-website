---

<section class="km-section--card relative reveal-on-scroll overflow-hidden">
  <!-- Ambient glow -->
  <div class="km-glow km-glow--green w-[500px] h-[300px] top-0 left-1/2 -translate-x-1/2 opacity-15 pointer-events-none"></div>

  <!-- Dot grid -->
  <div class="absolute inset-0 km-dotgrid opacity-20 pointer-events-none"></div>

  <div class="max-w-[650px] mx-auto px-6 sm:px-8 text-center relative z-10" style="padding-top: var(--km-section-py); padding-bottom: var(--km-section-py);">
    <h2 class="km-heading km-heading--display text-[clamp(2rem,5vw,3.5rem)] mb-5">
      Every hour you wait, your clusters keep wasting.
    </h2>
    <p class="text-zinc-500 mb-10 text-[15px]">
      Sign up free. Connect a cluster. See your waste in minutes.
    </p>
    <a href="https://kubmin.ksctl.com" target="_blank" rel="noopener" class="km-cta text-base px-10 py-4">
      Start Free <span aria-hidden="true">&rarr;</span>
    </a>
    <p class="mt-8">
      <a
        href="https://discord.ksctl.com"
        target="_blank"
        rel="noopener"
        class="text-[13px] text-zinc-600 hover:text-zinc-400 transition-colors inline-flex items-center gap-1.5"
      >
        Questions? Join our Discord
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </p>
  </div>
</section>
