---
import Container from "../shared/Container.astro";
import { pricing } from "@/data/kubmin";
---

<section class="relative py-28 md:py-36 overflow-hidden" style="background: var(--color-kubmin-overlay);">
  <div class="km-blob km-blob-iris" style="width: 30rem; height: 30rem; top: -6rem; left: 30%; opacity: .3"></div>
  <div class="absolute inset-0 km-grain opacity-[0.15] pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <span class="km-eyebrow" style="justify-content: center;">{pricing.label} · ch. 06</span>
      <h2 class="mt-6 text-4xl md:text-6xl leading-[1.02] font-medium" style="color: var(--color-kubmin-text)">
        Start free.<br/>
        <span class="km-italic km-grad-warm">{pricing.headingAccent}</span>
      </h2>
      <p class="mt-8 text-lg leading-relaxed" style="color: var(--color-kubmin-subtle-text)">
        {pricing.subheading}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto items-stretch">
      {pricing.tiers.map((tier, i) => (
        <div
          class="relative rounded-3xl p-8 md:p-10 flex flex-col km-lift"
          style={tier.popular
            ? `background: var(--color-kubmin-text); color: var(--color-kubmin-base); border: 1px solid var(--color-kubmin-text); box-shadow: 0 30px 80px -30px rgb(87 82 121 / 0.45);`
            : `background: var(--color-kubmin-surface); border: 1px solid var(--color-kubmin-border); box-shadow: var(--shadow-kubmin-paper);`}
        >
          {tier.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="km-mono text-[10px] uppercase tracking-[0.22em] px-4 py-1.5 rounded-full" style="background: var(--color-kubmin-cost); color: var(--color-kubmin-text);">
                most popular
              </span>
            </div>
          )}

          <div class="flex items-center justify-between mb-8 mt-2">
            <h3 class="km-display text-2xl font-medium italic" style={tier.popular ? '' : 'color: var(--color-kubmin-text)'}>
              {tier.name}
            </h3>
            <span class="km-mono text-[10px] uppercase tracking-[0.22em]" style={tier.popular ? 'color: var(--color-kubmin-primary-300)' : 'color: var(--color-kubmin-subtle-text)'}>
              tier {String(i + 1).padStart(2, '0')}
            </span>
          </div>

          <div class="flex items-baseline gap-1 mb-2">
            <span class="km-mono text-5xl font-medium tabular-nums tracking-tight">{tier.price}</span>
            <span class="text-sm" style={tier.popular ? 'color: var(--color-kubmin-primary-300)' : 'color: var(--color-kubmin-subtle-text)'}>{tier.period}</span>
          </div>

          <div class="mt-8 mb-10 km-hairline" style={tier.popular ? 'background: linear-gradient(90deg, transparent, rgb(255 255 255 / 0.18), transparent);' : ''}></div>

          <ul class="space-y-3.5 mb-10 flex-1">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-3 text-sm">
                <span class="shrink-0 mt-1 w-4 h-4 rounded-full flex items-center justify-center" style={tier.popular ? 'background: var(--color-kubmin-cost); color: var(--color-kubmin-text);' : 'background: var(--color-kubmin-primary-100); color: var(--color-kubmin-primary-700);'}>
                  <svg class="w-2.5 h-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </span>
                <span style={tier.popular ? 'color: var(--color-kubmin-primary-200)' : 'color: var(--color-kubmin-subtle-text)'}>{feature}</span>
              </li>
            ))}
          </ul>

          <a
            href="#"
            class="w-full text-center px-6 py-3.5 rounded-full font-semibold text-sm transition-all"
            style={tier.popular
              ? 'background: var(--color-kubmin-cost); color: var(--color-kubmin-text);'
              : 'background: var(--color-kubmin-text); color: var(--color-kubmin-base);'}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <p class="mt-12 text-center text-sm km-italic" style="color: var(--color-kubmin-subtle-text)">
      {pricing.footer}
    </p>
  </Container>
</section>
