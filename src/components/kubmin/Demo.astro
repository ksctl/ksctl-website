---
import Container from "../shared/Container.astro";
import ModernMockup from "./ModernMockup.astro";
import { productDemo } from "@/data/kubmin";

const accents = ["cost", "energy", "iris", "pine"] as const;
const accentVar = (k: typeof accents[number]) => ({
  cost: "var(--color-kubmin-cost)",
  energy: "var(--color-kubmin-energy)",
  iris: "var(--color-kubmin-iris)",
  pine: "var(--color-kubmin-efficiency)",
}[k]);
---

<section id="demo" class="relative py-28 md:py-36 overflow-hidden" style="background: var(--color-kubmin-base);">
  <div class="km-blob km-blob-foam" style="width: 32rem; height: 32rem; top: 10%; left: -8rem; opacity: .35"></div>
  <div class="km-blob km-blob-iris" style="width: 28rem; height: 28rem; bottom: 0; right: -6rem; opacity: .35"></div>
  <div class="absolute inset-0 km-dotgrid opacity-60 pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="max-w-3xl mb-16">
      <span class="km-eyebrow">{productDemo.label} · field test</span>
      <h2 class="mt-6 text-4xl md:text-6xl leading-[1.02] font-medium" style="color: var(--color-kubmin-text)">
        Three Redis versions.<br/>
        Same workload.<br/>
        <span class="km-italic km-grad-iris">Wildly different efficiency.</span>
      </h2>
      <p class="mt-8 text-lg md:text-xl leading-relaxed max-w-2xl" style="color: var(--color-kubmin-subtle-text)">
        {productDemo.body}
      </p>
    </div>

    <div class="relative max-w-6xl mx-auto mb-20">
      <ModernMockup
        imageSrc={productDemo.screenshot.src}
        imageAlt={productDemo.screenshot.alt}
        glowColor="energy"
        browserUrl={productDemo.screenshot.browserUrl}
      />
    </div>

    <!-- editorial stats: numeric typography ledger -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px overflow-hidden rounded-3xl km-paper"
      x-data="{
        animate(target, duration, callback) {
          const startTime = performance.now();
          const step = (now) => {
            const p = Math.min((now - startTime) / duration, 1);
            const e = 1 - Math.pow(1 - p, 3);
            callback(target * e);
            if (p < 1) requestAnimationFrame(step);
          };
          requestAnimationFrame(step);
        }
      }"
    >
      {productDemo.stats.map((stat, i) => {
        const k = accents[i % accents.length];
        return (
          <div
            class="relative p-8 md:p-10"
            style={`background: var(--color-kubmin-surface); outline: 1px solid var(--color-kubmin-border); outline-offset: -1px;`}
            x-data={`{
              displayValue: '${stat.value}',
              isAnimated: false,
              startAnimation() {
                if (this.isAnimated) return;
                this.isAnimated = true;
                const val = '${stat.value}';
                if (val.includes(' vs ')) {
                  const parts = val.split(' vs ');
                  this.setupMulti(parts[0], parts[1]);
                } else { this.setupSingle(val); }
              },
              setupSingle(val) {
                const m = val.match(/^([^\\d]*)(\\d+(?:\\.\\d+)?)([^\\d]*)$/);
                if (m) {
                  const pre = m[1], target = parseFloat(m[2]), suf = m[3];
                  const dec = m[2].includes('.');
                  this.animate(target, 1800, (v) => {
                    this.displayValue = pre + (dec ? v.toFixed(2) : Math.floor(v)) + suf;
                  });
                }
              },
              setupMulti(v1, v2) {
                const a = v1.match(/^([^\\d]*)(\\d+(?:\\.\\d+)?)([^\\d]*)$/);
                const b = v2.match(/^([^\\d]*)(\\d+(?:\\.\\d+)?)([^\\d]*)$/);
                if (a && b) {
                  const p1=a[1],t1=parseFloat(a[2]),s1=a[3],d1=a[2].includes('.');
                  const p2=b[1],t2=parseFloat(b[2]),s2=b[3],d2=b[2].includes('.');
                  this.animate(1, 1800, (p) => {
                    const e = 1 - Math.pow(1 - p, 3);
                    this.displayValue = \`\${p1}\${d1?(t1*e).toFixed(2):Math.floor(t1*e)}\${s1} vs \${p2}\${d2?(t2*e).toFixed(2):Math.floor(t2*e)}\${s2}\`;
                  });
                }
              }
            }`}
            x-intersect.once="startAnimation()"
          >
            <div class="flex items-start justify-between mb-6">
              <span class="km-mono text-[10px] tracking-[0.22em] uppercase" style="color: var(--color-kubmin-subtle-text)">
                fig. {String(i + 1).padStart(2, '0')}
              </span>
              <span class="km-dot" style={`background: ${accentVar(k)}`}></span>
            </div>
            <div
              class="km-mono font-medium tabular-nums leading-none mb-5"
              style={`color: ${accentVar(k)}; font-size: clamp(1.75rem, 3.2vw, 2.6rem);`}
              x-text="displayValue"
            >
              {stat.value}
            </div>
            <div class="text-base font-medium leading-snug mb-1" style="color: var(--color-kubmin-text)">
              {stat.label}
            </div>
            <div class="text-xs km-mono" style="color: var(--color-kubmin-subtle-text)">
              {stat.detail}
            </div>
          </div>
        );
      })}
    </div>

    <div class="mt-20 grid lg:grid-cols-12 gap-8 items-start">
      <blockquote class="lg:col-span-7 km-italic text-2xl md:text-3xl leading-snug pl-6 border-l-2" style="color: var(--color-kubmin-text); border-color: var(--color-kubmin-cost)">
        {productDemo.insight}
      </blockquote>
      <div class="lg:col-span-5 km-paper rounded-3xl p-8 flex flex-col gap-6">
        <p class="text-sm" style="color: var(--color-kubmin-subtle-text)">{productDemo.caption}</p>
        <a href={productDemo.cta.href} class="km-btn km-btn-primary self-start">
          {productDemo.cta.text}
          <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
        </a>
      </div>
    </div>
  </Container>
</section>
