---
import Container from "../shared/Container.astro";
import { whyEnergy } from "@/data/kubmin";

const { exhibit } = whyEnergy;
const legendSwatch: Record<string, string> = {
  energy: "var(--color-kubmin-cost)",
  cpu: "var(--color-kubmin-subtle-text)",
  work: "var(--color-kubmin-energy)",
};
---

<section class="relative py-28 md:py-36 overflow-hidden" style="background: var(--color-kubmin-base);">
  <div class="km-blob km-blob-foam" style="width: 30rem; height: 30rem; top: -6rem; right: -6rem; opacity: .4"></div>
  <div class="km-blob km-blob-iris" style="width: 26rem; height: 26rem; bottom: -8rem; left: -6rem; opacity: .35"></div>

  <Container class="relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-start">
      <div class="lg:col-span-7">
        <span class="km-eyebrow">why energy · ch. 03</span>
        <h2 class="mt-6 text-5xl md:text-7xl leading-[0.98] font-medium" style="color: var(--color-kubmin-text)">
          {whyEnergy.displayHeading.line1.text}
          <span class="km-italic" style="color: var(--color-kubmin-love)">{whyEnergy.displayHeading.line1.accent}</span><br/>
          {whyEnergy.displayHeading.line2.text}
          <span class="km-italic km-grad-iris">{whyEnergy.displayHeading.line2.accent}</span>
        </h2>

        <p class="mt-10 text-xl leading-relaxed font-medium max-w-2xl" style="color: var(--color-kubmin-text)">
          {whyEnergy.intro}
        </p>

        <!-- the lie, plotted -->
        <figure
          class="km-chart mt-10 km-paper rounded-3xl overflow-hidden max-w-2xl"
          x-data
          x-intersect.once="$el.classList.add('is-drawn')"
        >
          <div class="flex items-center justify-between gap-4 px-6 py-3.5" style="background: var(--color-kubmin-overlay); border-bottom: 1px solid var(--color-kubmin-border);">
            <span class="km-mono text-xs uppercase tracking-[0.22em]" style="color: var(--color-kubmin-subtle-text)">{exhibit.figLabel}</span>
            <span class="km-mono text-xs uppercase tracking-[0.22em] hidden sm:inline" style="color: var(--color-kubmin-subtle-text)">{exhibit.figMeta}</span>
          </div>

          <div class="px-4 pt-5 sm:px-6">
            <svg viewBox="0 0 640 290" class="w-full h-auto block" role="img" aria-label="Chart of one node over 24 hours: energy draw rises and falls with CPU utilization but never drops near zero — overnight, requests hit zero and CPU idles, yet the node still draws well over half its peak power. Six hours of idle burn.">
              <!-- gridlines -->
              {[60, 108, 156, 204].map((y) => (
                <line x1="16" y1={y} x2="624" y2={y} stroke="var(--color-kubmin-subtle)" stroke-width="1" stroke-dasharray="2 7" />
              ))}
              <line x1="16" y1="252" x2="624" y2="252" stroke="var(--color-kubmin-border)" stroke-width="1" />

              <!-- idle burn band: 00h–06h -->
              <g class="km-chart-band">
                <rect x="16" y="24" width="152" height="228" fill="rgb(180 99 122 / 0.07)" />
                <line x1="168" y1="24" x2="168" y2="252" stroke="var(--color-kubmin-love)" stroke-width="1" stroke-dasharray="4 5" opacity="0.45" />
                <text x="26" y="46" class="km-mono" font-size="13" letter-spacing="2" fill="var(--color-kubmin-love)" style="text-transform: uppercase;">{exhibit.bandLabel[0]}</text>
                <text x="26" y="64" class="km-mono" font-size="11" fill="rgb(180 99 122 / 0.75)">{exhibit.bandLabel[1]}</text>
              </g>

              <!-- requests served (work) — collapses overnight -->
              <path
                class="km-chart-fill"
                d="M16,246 L100,246 C130,246 150,240 168,232 C210,210 250,150 320,132 C380,118 430,124 480,140 C520,152 570,190 624,210 L624,252 L16,252 Z"
                fill="rgb(86 148 159 / 0.16)"
              />
              <path
                class="km-chart-line"
                pathLength="1"
                d="M16,246 L100,246 C130,246 150,240 168,232 C210,210 250,150 320,132 C380,118 430,124 480,140 C520,152 570,190 624,210"
                fill="none" stroke="var(--color-kubmin-energy)" stroke-width="1.8" stroke-linecap="round"
              />

              <!-- cpu utilization — rises and falls with the work -->
              <path
                class="km-chart-fill"
                d="M16,238 C60,240 120,239 168,232 C220,215 260,165 320,152 C380,142 430,150 480,166 C540,182 590,196 624,202"
                fill="none" stroke="var(--color-kubmin-subtle-text)" stroke-width="1.4" stroke-dasharray="5 5" stroke-linecap="round" opacity="0.75"
              />

              <!-- energy draw — follows cpu, but floors far above zero -->
              <path
                class="km-chart-line"
                pathLength="1"
                d="M16,152 C60,153 120,152 168,148 C220,138 260,106 320,96 C380,88 430,94 480,106 C540,118 590,126 624,130"
                fill="none" stroke="var(--color-kubmin-cost)" stroke-width="2" stroke-linecap="round"
              />

              <!-- time axis -->
              {[
                { x: 16, t: "00h", a: "start" },
                { x: 168, t: "06h", a: "middle" },
                { x: 320, t: "12h", a: "middle" },
                { x: 472, t: "18h", a: "middle" },
                { x: 624, t: "24h", a: "end" },
              ].map(({ x, t, a }) => (
                <text x={x} y="276" text-anchor={a} class="km-mono" font-size="11" fill="var(--color-kubmin-subtle-text)">{t}</text>
              ))}
            </svg>
          </div>

          <div class="px-6 pb-3 pt-2 flex flex-wrap gap-x-5 gap-y-1.5">
            {exhibit.legend.map((item) => (
              <span class="inline-flex items-center gap-2 km-mono text-xs tracking-[0.08em]" style="color: var(--color-kubmin-subtle-text)">
                <span
                  class="inline-block w-4 h-0 border-t-2 shrink-0"
                  style={`border-color: ${legendSwatch[item.key]}; ${item.key === "cpu" ? "border-top-style: dashed;" : ""}`}
                ></span>
                {item.label}
              </span>
            ))}
          </div>

          <figcaption class="km-italic text-sm leading-relaxed px-6 pb-6" style="color: var(--color-kubmin-subtle-text)">
            {exhibit.caption}
          </figcaption>
        </figure>

        <p class="mt-10 leading-relaxed max-w-2xl" style="color: var(--color-kubmin-subtle-text)">
          {whyEnergy.kepler}
        </p>

        <div class="mt-10 rounded-2xl p-6 flex items-start gap-4" style="background: var(--color-kubmin-overlay); border: 1px solid var(--color-kubmin-border);">
          <div class="shrink-0 w-9 h-9 rounded-full flex items-center justify-center mt-0.5" style="background: var(--color-kubmin-primary-100); color: var(--color-kubmin-primary-700); border: 1px solid var(--color-kubmin-primary-200);">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          </div>
          <div>
            <div class="km-mono text-xs uppercase tracking-[0.22em] mb-2" style="color: var(--color-kubmin-primary-700)">a note on accuracy</div>
            <p class="text-sm leading-relaxed" style="color: var(--color-kubmin-text)">
              {whyEnergy.accuracyNote}
            </p>
          </div>
        </div>

        <div class="mt-10">
          <a href="/manifesto/vrapl" target="_blank" rel="noopener noreferrer" class="km-btn km-btn-primary">
            Read the Open VM Energy Manifesto
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>

      <aside class="lg:col-span-5 lg:sticky lg:top-28">
        <div class="km-paper rounded-3xl p-8 md:p-10">
          <div class="km-mono text-xs tracking-[0.22em] uppercase mb-8" style="color: var(--color-kubmin-subtle-text)">
            {whyEnergy.metricsIntro}
          </div>

          <div class="space-y-5">
            {whyEnergy.metrics.map((m, i) => (
              <div class="rounded-2xl p-6" style={`background: ${i === 0 ? 'var(--color-kubmin-overlay)' : 'var(--color-kubmin-muted)'}; border: 1px solid var(--color-kubmin-border);`}>
                <div class="flex items-baseline gap-4 mb-3">
                  <span class="km-display text-5xl font-medium" style="color: var(--color-kubmin-primary-700); font-style: italic;">{m.name}</span>
                  <span class="text-sm font-medium tracking-wide" style="color: var(--color-kubmin-text)">{m.full}</span>
                </div>
                <p class="text-sm leading-relaxed" style="color: var(--color-kubmin-subtle-text)">{m.description}</p>
              </div>
            ))}
          </div>

          <p class="mt-8 km-italic text-base leading-relaxed pl-4 border-l-2" style="color: var(--color-kubmin-text); border-color: var(--color-kubmin-energy)">
            {whyEnergy.combined}
          </p>
        </div>
      </aside>
    </div>
  </Container>
</section>
