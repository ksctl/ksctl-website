---
import Container from "../Container.astro";
import { howItWorks } from "@/data/kubmin";
---

<section class="py-24 bg-gray-50 relative border-t border-gray-200/50">
  <Container>
    <div class="text-center max-w-2xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-50 border border-emerald-100 text-emerald-700 text-sm font-semibold tracking-wide uppercase mb-6">
        {howItWorks.label}
      </div>
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-gray-900">
        {howItWorks.heading} <span class="text-emerald-600">{howItWorks.headingAccent}</span>
      </h2>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <!-- Connecting Line -->
      <div class="hidden md:block absolute top-12 left-12 right-12 h-0.5 bg-gradient-to-r from-emerald-100 via-emerald-300 to-emerald-100 z-0"></div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 relative z-10">
        {howItWorks.steps.map((step, i) => (
          <div class="relative flex flex-col items-center text-center group">
            <div class="w-24 h-24 rounded-full bg-white border-4 border-emerald-50 flex items-center justify-center shadow-sm mb-6 group-hover:scale-110 group-hover:border-emerald-100 transition-all duration-300">
              <span class="text-3xl font-extrabold text-emerald-600 font-mono">0{i+1}</span>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">{step.title}</h3>
            <p class="text-gray-500 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-20 flex flex-col items-center">
      <a href={howItWorks.cta.href} class="h-14 px-8 rounded-full bg-gray-900 text-white font-medium flex items-center gap-2 hover:bg-gray-800 transition-colors shadow-lg shadow-gray-900/20">
        {howItWorks.cta.text}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
      </a>
      <p class="mt-6 text-sm text-gray-400 max-w-md text-center">{howItWorks.disclaimer}</p>
    </div>
  </Container>
</section>
