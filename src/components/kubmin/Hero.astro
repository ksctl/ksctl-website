---
import Container from "../shared/Container.astro";
import ModernMockup from "./ModernMockup.astro";
import { hero } from "@/data/kubmin";
---

<section class="relative overflow-hidden km-wash-tl" id="home" style="background: var(--color-kubmin-base);">
  <div class="km-blob km-blob-iris" style="width: 38rem; height: 38rem; top: -10rem; left: -8rem;"></div>
  <div class="km-blob km-blob-gold" style="width: 30rem; height: 30rem; top: 4rem; right: -8rem; opacity: .35"></div>
  <div class="km-blob km-blob-foam" style="width: 28rem; height: 28rem; bottom: -10rem; left: 30%;  opacity: .35"></div>

  <div class="absolute inset-0 km-dotgrid pointer-events-none"></div>
  <div class="absolute inset-0 km-grain opacity-[0.18] pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="pt-28 md:pt-36 pb-12">

      <div class="km-stagger km-stagger-1 flex items-center justify-between gap-4 mb-12 flex-wrap">
        <a href="/product/kubmin" class="inline-flex items-center gap-3">
          <img src={hero.logo} alt="kubmin logo" class="h-9 md:h-10 w-auto" />
          <span class="km-display text-3xl md:text-4xl font-semibold leading-none" style="color: var(--color-kubmin-text); font-style: normal;">{hero.productName}</span>
          <span class="km-mono text-[10px] uppercase tracking-[0.22em] pl-3 ml-1 border-l" style="color: var(--color-kubmin-subtle-text); border-color: var(--color-kubmin-border)">
            by ksctl
          </span>
        </a>
        <span class="km-eyebrow">
          <span>The kubmin dispatch</span>
          <span class="km-dot" style="color: var(--color-kubmin-cost)"></span>
          <span>Vol. 01 · Cost &amp; Efficiency</span>
        </span>
      </div>

      <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-end">

        <div class="lg:col-span-8">
          <h1 class="km-stagger km-stagger-2 text-[3rem] sm:text-[4rem] md:text-[5.25rem] lg:text-[6rem] leading-[0.95] tracking-tight font-semibold" style="color: var(--color-kubmin-text)">
            Deploy fast<span class="km-italic" style="font-weight:300; color: var(--color-kubmin-subtle-text)">,</span><br/>
            and know<br/>
            what each one
            <span class="km-italic km-grad-warm">costs</span>
            <span style="color: var(--color-kubmin-subtle-text)" class="km-italic">in</span>
            <span class="km-underline km-underline-gold">money</span>
            <span style="color: var(--color-kubmin-subtle-text)" class="km-italic">&amp;</span>
            <span class="km-underline">efficiency</span><span class="km-italic" style="color: var(--color-kubmin-cost)">.</span>
          </h1>

          <p class="km-stagger km-stagger-3 mt-10 text-xl md:text-2xl leading-snug max-w-2xl" style="color: var(--color-kubmin-text)">
            Everyone ships faster with AI. Nobody checks the cost.
            <span class="km-italic" style="color: var(--color-kubmin-primary-700)">Kubmin does.</span>
          </p>

          <p class="km-stagger km-stagger-3 mt-5 text-base md:text-lg leading-relaxed max-w-xl" style="color: var(--color-kubmin-subtle-text)">
            {hero.explain}
          </p>

          <div class="km-stagger km-stagger-4 mt-10 flex flex-wrap items-center gap-4">
            <a href={hero.cta.href} target="_blank" rel="noopener noreferrer" class="km-btn km-btn-primary">
              {hero.cta.text}
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <a href="#demo" class="km-btn km-btn-ghost">
              See the Redis comparison
            </a>
          </div>

          <div class="km-stagger km-stagger-4 mt-8 flex flex-wrap items-center gap-2">
            {hero.trustBadges.map((badge, i) => (
              <>
                {i > 0 && <span class="text-xs" style="color: var(--color-kubmin-border)">/</span>}
                <span class="text-xs km-mono tracking-wider uppercase" style="color: var(--color-kubmin-subtle-text)">{badge}</span>
              </>
            ))}
          </div>
        </div>

        <aside class="km-stagger km-stagger-3 lg:col-span-4 lg:pl-6 lg:border-l" style="border-color: var(--color-kubmin-border)">
          <div class="km-mono text-[10px] tracking-[0.22em] uppercase mb-4" style="color: var(--color-kubmin-subtle-text)">
            <span class="km-dot mr-2" style="color: var(--color-kubmin-cost)"></span>
            Field note
          </div>
          <p class="km-italic text-2xl leading-snug mb-6" style="color: var(--color-kubmin-text)">
            "AWS shows the bill. Kubecost guesses pods. Neither tells you what a single container actually burns."
          </p>
          <div class="grid grid-cols-3 gap-4 pt-4 border-t" style="border-color: var(--color-kubmin-border)">
            <div>
              <div class="km-mono text-2xl tabular-nums" style="color: var(--color-kubmin-cost)">$0.18</div>
              <div class="text-[11px] mt-1" style="color: var(--color-kubmin-subtle-text)">/ workload</div>
            </div>
            <div>
              <div class="km-mono text-2xl tabular-nums" style="color: var(--color-kubmin-energy)">0.0085</div>
              <div class="text-[11px] mt-1" style="color: var(--color-kubmin-subtle-text)">kWh / hr</div>
            </div>
            <div>
              <div class="km-mono text-2xl tabular-nums" style="color: var(--color-kubmin-iris)">63%</div>
              <div class="text-[11px] mt-1" style="color: var(--color-kubmin-subtle-text)">CPU drift</div>
            </div>
          </div>
        </aside>
      </div>

      <div class="km-stagger km-stagger-5 relative max-w-6xl mx-auto mt-20">
        <ModernMockup
          imageSrc={hero.screenshot.src}
          imageAlt={hero.screenshot.alt}
          loading="eager"
          glowColor="primary"
          browserUrl={hero.screenshot.browserUrl}
        />
      </div>

      <div class="km-stagger km-stagger-5 mt-16 km-hairline"></div>
      <div class="km-stagger km-stagger-5 mt-6 flex flex-wrap items-center justify-between gap-x-6 gap-y-2 km-mono text-[11px] uppercase tracking-[0.2em]" style="color: var(--color-kubmin-subtle-text)">
        <span>per-workload visibility</span>
        <span>·</span>
        <span>release-vs-release diff</span>
        <span>·</span>
        <span>SCI + SEE scoring</span>
        <span>·</span>
        <span>quick wins, kubectl-ready</span>
      </div>
    </div>
  </Container>
</section>
