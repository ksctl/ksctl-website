---
import Container from "../shared/Container.astro";
import ModernMockup from "./ModernMockup.astro";
import { hero } from "@/data/kubmin";

const { displayHeadline } = hero;
const punchlineParts = hero.punchlineAccent
  ? hero.punchline.split(hero.punchlineAccent)
  : [hero.punchline];
---

<section class="relative overflow-hidden km-wash-tl" id="home" style="background: var(--color-kubmin-base);">
  <div class="km-blob km-blob-iris" style="width: 38rem; height: 38rem; top: -10rem; left: -8rem;"></div>
  <div class="km-blob km-blob-gold" style="width: 30rem; height: 30rem; top: 4rem; right: -8rem; opacity: .35"></div>
  <div class="km-blob km-blob-foam" style="width: 28rem; height: 28rem; bottom: -10rem; left: 30%;  opacity: .35"></div>

  <div class="absolute inset-0 km-dotgrid pointer-events-none"></div>
  <div class="absolute inset-0 km-grain opacity-[0.18] pointer-events-none"></div>

  <Container class="relative z-10">
    <div class="pt-28 md:pt-36 pb-12">

      <div class="km-stagger km-stagger-1 flex items-center justify-between gap-4 mb-12 flex-wrap">
        <a href="/product/kubmin" class="inline-flex items-center gap-3">
          <img src={hero.logo} alt="kubmin logo" class="h-9 md:h-10 w-auto" />
          <span class="km-display text-3xl md:text-4xl font-semibold leading-none" style="color: var(--color-kubmin-text); font-style: normal;">{hero.productName}</span>
          <span class="km-mono text-xs uppercase tracking-[0.22em] pl-3 ml-1 border-l" style="color: var(--color-kubmin-subtle-text); border-color: var(--color-kubmin-border)">
            by ksctl
          </span>
        </a>
        <span class="km-eyebrow">
          <span>{hero.dispatch.title}</span>
          <span class="km-dot" style="color: var(--color-kubmin-cost)"></span>
          <span>{hero.dispatch.meta}</span>
        </span>
      </div>

      <div class="grid lg:grid-cols-12 gap-10 lg:gap-12 items-end">

        <div class="lg:col-span-8">
          <h1 class="km-stagger km-stagger-2 text-5xl sm:text-6xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight font-semibold" style="color: var(--color-kubmin-text)">
            {displayHeadline.lines.map((line) => (
              <>
                {line}<br />
              </>
            ))}
            <span style="color: var(--color-kubmin-subtle-text)">{displayHeadline.bridge}</span><br />
            <span class="km-grad-warm">{displayHeadline.accent}</span><span style="color: var(--color-kubmin-cost)">{displayHeadline.terminal}</span>
          </h1>

          <p class="km-stagger km-stagger-3 mt-10 text-xl md:text-2xl leading-snug max-w-2xl" style="color: var(--color-kubmin-text)">
            {punchlineParts[0]}
            {hero.punchlineAccent && (
              <span class="km-italic" style="color: var(--color-kubmin-primary-700)">{hero.punchlineAccent}</span>
            )}
            {punchlineParts.slice(1).join(hero.punchlineAccent)}
          </p>

          <p class="km-stagger km-stagger-3 mt-5 text-base md:text-lg leading-relaxed max-w-xl" style="color: var(--color-kubmin-subtle-text)">
            {hero.explain}
          </p>

          <div class="km-stagger km-stagger-4 mt-10 flex flex-wrap items-center gap-4">
            <a href={hero.cta.href} target="_blank" rel="noopener noreferrer" class="km-btn km-btn-primary">
              {hero.cta.text}
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
            <a href={hero.secondaryCta.href} class="km-btn km-btn-ghost">
              {hero.secondaryCta.text}
            </a>
          </div>

          <div class="km-stagger km-stagger-4 mt-8 flex flex-wrap items-center gap-2">
            {hero.trustBadges.map((badge, i) => (
              <>
                {i > 0 && <span class="text-xs" style="color: var(--color-kubmin-border)">/</span>}
                <span class="text-xs km-mono tracking-wider uppercase" style="color: var(--color-kubmin-subtle-text)">{badge}</span>
              </>
            ))}
          </div>
        </div>

        <aside class="km-stagger km-stagger-3 lg:col-span-4 lg:self-center">
          <div
            class="km-paper rounded-3xl overflow-hidden km-pipeline"
            x-data={`{
              shown: 0, settled: 0,
              run() {
                const n = ${hero.releaseReport.rows.length}, start = 500, step = 420, spin = 320;
                if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) { this.shown = n; this.settled = n; return; }
                this.$el.classList.add('is-animating');
                for (let i = 0; i < n; i++) {
                  setTimeout(() => this.shown++, start + i * step);
                  setTimeout(() => this.settled++, start + i * step + spin);
                }
                setTimeout(() => this.$el.classList.add('is-done'), start + (n - 1) * step + spin + 200);
              }
            }`}
            x-init="run()"
          >
            <div class="flex items-center justify-between gap-4 px-6 py-4" style="background: var(--color-kubmin-overlay); border-bottom: 1px solid var(--color-kubmin-border);">
              <span class="km-mono text-xs uppercase tracking-[0.22em] inline-flex items-center gap-2" style="color: var(--color-kubmin-subtle-text)">
                <span class="km-dot" style="background: var(--color-kubmin-cost)"></span>
                {hero.releaseReport.label}
              </span>
              <span class="km-mono text-xs truncate" style="color: var(--color-kubmin-subtle-text)">{hero.releaseReport.release}</span>
            </div>
            <div class="px-6 py-4">
              {hero.releaseReport.rows.map((row, i) => (
                <div
                  class={`km-report-row ${row.pass ? 'is-pass' : 'is-fail'}`}
                  x-bind:class={`{ 'is-shown': shown > ${i}, 'is-settled': settled > ${i} }`}
                >
                  <svg class="km-spin w-3.5 h-3.5 shrink-0 animate-spin" style="color: var(--color-kubmin-subtle-text)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" stroke-linecap="round"><path d="M12 3a9 9 0 1 1-9 9"/></svg>
                  {row.pass ? (
                    <svg class="km-mark w-3.5 h-3.5 shrink-0" style="color: var(--color-kubmin-efficiency)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  ) : (
                    <svg class="km-mark w-3.5 h-3.5 shrink-0" style="color: var(--color-kubmin-love)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                  )}
                  <span class="km-report-name shrink-0">{row.name}</span>
                  <span class="km-report-leader" aria-hidden="true"></span>
                  <span class="km-report-value shrink-0 tabular-nums">{row.value}</span>
                </div>
              ))}
            </div>
            <p class="km-caption km-italic text-sm leading-relaxed px-6 pb-6" style="color: var(--color-kubmin-subtle-text)">
              {hero.releaseReport.caption}
            </p>
          </div>
        </aside>
      </div>

      <div class="km-stagger km-stagger-5 relative max-w-6xl mx-auto mt-20">
        <ModernMockup
          imageSrc={hero.screenshot.src}
          imageAlt={hero.screenshot.alt}
          loading="eager"
          glowColor="primary"
          browserUrl={hero.screenshot.browserUrl}
        />
      </div>

      <div class="km-stagger km-stagger-5 mt-16 km-hairline"></div>
      <div class="km-stagger km-stagger-5 mt-6 flex flex-wrap items-center justify-between gap-x-6 gap-y-2 km-mono text-xs uppercase tracking-[0.2em]" style="color: var(--color-kubmin-subtle-text)">
        {hero.proofPoints.map((point, i) => (
          <>
            {i > 0 && <span>·</span>}
            <span>{point}</span>
          </>
        ))}
      </div>
    </div>
  </Container>
</section>
