---
import Container from "../shared/Container.astro";
import { products } from "@/data/home";

const { items } = products;
---

<section id="products" class="relative py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-ksctl-foreground mb-4">
        {products.heading.split(' ')[0]} <span class="text-ksctl-primary">{products.heading.split(' ').slice(1).join(' ')}</span>
      </h2>
      <p class="text-lg text-ksctl-muted-foreground max-w-2xl mx-auto">
        {products.subheading}
      </p>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-6xl mx-auto">
      {items.map((product) => (
        <div class:list={[
          "group relative overflow-hidden h-full flex flex-col rounded-2xl border p-8 md:p-10 transition-all duration-300",
          product.available
            ? "bg-ksctl-card border-ksctl-border hover:shadow-2xl hover:-translate-y-2"
            : "bg-ksctl-muted border-ksctl-border/50 hover:shadow-xl hover:-translate-y-1"
        ]}>
          <!-- Primary overlay on hover -->
          <div class="absolute inset-0 rounded-2xl bg-ksctl-primary opacity-0 group-hover:opacity-5 transition-opacity duration-300"></div>

          <!-- Top Border Accent -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 h-1 w-16 bg-ksctl-primary rounded-b-full opacity-50 group-hover:opacity-100 group-hover:w-24 transition-all duration-300"></div>

          <!-- Badge for Coming Soon -->
          {(product as any).badge && (
            <div class="absolute top-6 right-6">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-ksctl-primary text-primary-foreground animate-pulse">
                {(product as any).badge}
              </span>
            </div>
          )}

          <!-- Logo & Name -->
          <div class="flex items-center mb-6">
            <img
              src={product.logo}
              alt={`${product.name} logo`}
              class:list={[
                "h-16 w-auto mr-4",
                !product.available && "opacity-50"
              ]}
            />
            <h3 class:list={[
              "text-3xl font-bold",
              product.available
                ? "text-ksctl-foreground"
                : "text-ksctl-muted-foreground"
            ]}>
              {product.name}
            </h3>
          </div>

          <!-- Tagline -->
          <p class:list={[
            "text-xl font-semibold mb-4",
            product.available
              ? "text-ksctl-primary"
              : "text-ksctl-muted-foreground"
          ]}>
            {product.tagline}
          </p>

          <!-- Description -->
          <p class:list={[
            "text-base mb-6 leading-relaxed",
            product.available
              ? "text-ksctl-muted-foreground"
              : "text-ksctl-muted-foreground/70"
          ]}>
            {product.description}
          </p>

          <!-- Features List -->
          <ul class="space-y-3 mb-8 flex-grow">
            {product.features.map((feature) => (
              <li class="flex items-start">
                <svg xmlns="http://www.w3.org/2000/svg" class:list={[
                  "h-6 w-6 mr-2 flex-shrink-0 mt-0.5",
                  product.available
                    ? "text-ksctl-primary"
                    : "text-ksctl-muted-foreground"
                ]} fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                <span class:list={[
                  "text-base",
                  product.available
                    ? "text-ksctl-muted-foreground"
                    : "text-ksctl-muted-foreground/70"
                ]}>
                  {feature}
                </span>
              </li>
            ))}
          </ul>

          <!-- CTA Button -->
          <a
            href={product.ctaLink}
            class:list={[
              "relative z-10 block w-full text-center py-4 px-6 rounded-lg font-medium transition-all duration-300",
              product.available
                ? "bg-ksctl-primary text-[var(--color-ksctl-primary-foreground)] shadow-lg shadow-ksctl-primary/30 hover:shadow-xl hover:shadow-ksctl-primary/40 hover:translate-y-[-2px] active:translate-y-[1px]"
                : "bg-ksctl-muted text-[var(--color-ksctl-muted-foreground)] cursor-not-allowed"
            ]}
            aria-disabled={!product.available}
          >
            {product.ctaText}
          </a>

          <!-- Decorative Element for Available Products -->
          {product.available && (
            <div class="absolute bottom-0 right-0 w-32 h-32 bg-gradient-to-tl from-ksctl-primary/10 to-transparent rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl"></div>
          )}
        </div>
      ))}
    </div>
  </Container>
</section>
