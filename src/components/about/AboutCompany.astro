---
import Container from "../shared/Container.astro";
import { aboutCompany } from "@/data/about";

const { story } = aboutCompany;
---

<section class="relative py-24">
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-ksctl-foreground mb-4">
        {aboutCompany.heading.split(' ')[0]} <span class="text-ksctl-primary">{aboutCompany.heading.split(' ').slice(1).join(' ')}</span>
      </h2>
      <p class="text-lg text-ksctl-muted-foreground max-w-2xl mx-auto">
        {aboutCompany.subheading}
      </p>
    </div>

    <!-- Founding Story -->
    <div class="max-w-4xl mx-auto mb-20">
      <div class="bg-ksctl-card rounded-2xl border border-ksctl-border p-8 md:p-12">
        <div class="flex items-start mb-6">
          <div class="flex-shrink-0 w-16 h-16 rounded-xl bg-ksctl-primary flex items-center justify-center shadow-lg shadow-ksctl-primary/30 mr-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-ksctl-foreground mb-4">{story.title}</h3>
            {story.paragraphs.map((p, i) => (
              <p class={`text-lg text-ksctl-muted-foreground leading-relaxed ${i !== story.paragraphs.length - 1 ? 'mb-4' : ''}`}>
                {p}
              </p>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
