<style>
.bg-grid-pattern {
  background-image:
    radial-gradient(circle, rgba(63, 103, 102, 0.3) 1px, transparent 1px);
  background-size: 30px 30px;
}

@keyframes blob-slow {
  0% {
    transform: translate(0px, 0px) scale(1);
  }
  33% {
    transform: translate(30px, -30px) scale(1.1);
  }
  66% {
    transform: translate(-20px, 20px) scale(0.9);
  }
  100% {
    transform: translate(0px, 0px) scale(1);
  }
}

@keyframes blob-slow-delay {
  0% {
    transform: translate(0px, 0px) scale(1);
  }
  33% {
    transform: translate(-30px, 30px) scale(1.1);
  }
  66% {
    transform: translate(20px, -20px) scale(0.9);
  }
  100% {
    transform: translate(0px, 0px) scale(1);
  }
}

@keyframes blob-slow-delay-more {
  0% {
    transform: translate(0px, 0px) scale(1);
  }
  33% {
    transform: translate(20px, 20px) scale(1.05);
  }
  66% {
    transform: translate(-15px, -25px) scale(0.95);
  }
  100% {
    transform: translate(0px, 0px) scale(1);
  }
}

@keyframes float-duration {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

@keyframes pulse-duration {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.animate-blob-slow {
  animation: blob-slow 10s infinite;
}

.animate-blob-slow-delay {
  animation: blob-slow-delay 10s infinite;
  animation-delay: 3s;
}

.animate-blob-slow-delay-more {
  animation: blob-slow-delay-more 14s infinite;
  animation-delay: 2s;
}

.animate-float-slow {
  animation: float-duration 6s ease-in-out infinite;
}

.animate-pulse-slow {
  animation: pulse-duration 3s ease-in-out infinite;
}

.btn-hover-effect::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.2),
    transparent
  );
  transition: left 0.7s;
  border-radius: 0.75rem;
}

.btn-hover-effect:hover::before {
  left: 100%;
}
</style>
