---
import Container from "./Container.astro";
import { aboutCompany } from "@/data/about";

const { timeline, impact, story } = aboutCompany;
---

<section class="relative py-24 bg-gradient-to-b from-background to-muted/30">
  <Container>
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold text-foreground mb-4">
        {aboutCompany.heading.split(' ')[0]} <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">{aboutCompany.heading.split(' ').slice(1).join(' ')}</span>
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        {aboutCompany.subheading}
      </p>
    </div>

    <!-- Founding Story -->
    <div class="max-w-4xl mx-auto mb-20">
      <div class="bg-card rounded-2xl border border-border p-8 md:p-12">
        <div class="flex items-start mb-6">
          <div class="flex-shrink-0 w-16 h-16 rounded-xl bg-gradient-to-br from-primary to-secondary flex items-center justify-center shadow-lg shadow-primary/30 mr-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-foreground mb-4">{story.title}</h3>
            {story.paragraphs.map((p, i) => (
              <p class={`text-lg text-muted-foreground leading-relaxed ${i !== story.paragraphs.length - 1 ? 'mb-4' : ''}`}>
                {p}
              </p>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Timeline -->
    <div class="max-w-5xl mx-auto">
      <h3 class="text-3xl font-bold text-foreground text-center mb-12">
        {aboutCompany.journeyHeading}
      </h3>

      <div class="relative">
        <!-- Vertical Line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-0.5 bg-gradient-to-b from-primary to-secondary opacity-30"></div>

        <!-- Timeline Items -->
        <div class="space-y-12">
          {timeline.map((item, index) => (
            <div class:list={[
              "relative flex items-center",
              index % 2 === 0 ? "justify-start" : "justify-end"
            ]}>
              <!-- Content -->
              <div class:list={[
                "w-5/12",
                index % 2 === 0 ? "pr-8 text-right" : "pl-8 text-left"
              ]}>
                <div class="group bg-card rounded-xl border border-border p-6 transition-all duration-300 hover:shadow-xl hover:-translate-y-1">
                  <span class="inline-block text-primary font-bold text-lg mb-2">{item.year}</span>
                  <h4 class="text-xl font-bold text-foreground mb-2">
                    {item.title}
                  </h4>
                  <p class="text-muted-foreground">
                    {item.description}
                  </p>
                </div>
              </div>

              <!-- Center Dot -->
              <div class="absolute left-1/2 transform -translate-x-1/2 w-6 h-6 rounded-full bg-gradient-to-br from-primary to-secondary border-4 border-background shadow-lg z-10"></div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Community Impact -->
    <div class="mt-20 max-w-5xl mx-auto">
      <div class="bg-gradient-to-br from-primary/5 to-secondary/5 rounded-2xl border border-primary/20 p-8 md:p-12">
        <h3 class="text-2xl md:text-3xl font-bold text-foreground text-center mb-8">
          {impact.heading}
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {impact.stats.map(stat => (
            <div class="text-center">
              <div class="text-4xl md:text-5xl font-bold text-primary mb-2">{stat.value}</div>
              <p class="text-muted-foreground">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Container>
</section>
