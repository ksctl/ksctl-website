---
import Container from "./Container.astro";
---

<section id="cta" class="py-16 sm:py-24">
  <Container>
    <div class="p-8 sm:p-16 rounded-2xl bg-primary text-black text-center space-y-8 max-w-5xl mx-auto">
      <h2 class="text-3xl sm:text-5xl font-mono font-bold leading-tight">
        Your clusters are wasting money and energy right now. Find out how much.
      </h2>
      <div class="pt-4">
        <a href="#" class="inline-block px-8 py-4 rounded bg-black text-primary font-mono font-bold text-xl hover:bg-gray-900 transition-colors">
          Get Started Free
        </a>
      </div>
    </div>
  </Container>
</section>
